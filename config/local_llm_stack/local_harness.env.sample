# Copy to local_harness.env for machine-local overrides. Do not commit secrets.
LOCAL_QWEN_MODEL=qwen-local
LOCAL_QWEN_BASE=http://127.0.0.1:1234
LOCAL_QWEN_CODEX_CONTEXT_WINDOW=32768
LOCAL_QWEN_CODEX_AUTO_COMPACT_LIMIT=28672
LOCAL_QWEN_GUARD_PROFILE=balanced
CODEX_TEXTGEN_MAX_OUTPUT_TOKENS=2048
CODEX_TEXTGEN_TOOL_TEMPERATURE=0.15
# Optional: set an explicit reviewed prompt file. The bridge has no hidden
# machine-local prompt dependency when this is unset.
# CODEX_TEXTGEN_SYSTEM_PROMPT_FILE=/path/to/reviewed-system-prompt.txt
