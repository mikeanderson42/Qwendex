{
  "schema_version": 1,
  "name": "Qwendex LLMStack",
  "tmux_session": "qwendex-llmstack",
  "repo_root": "{repo_root}",
  "safe_runtime_dir": "{home}/.local/state/qwendex/local_llm_stack",
  "transcript_dir": "{home}/.local/state/qwendex/local_llm_stack/transcripts",
  "prompt_template_roots": [
    "{repo_root}/templates",
    "{repo_root}/prompts"
  ],
  "user_state_file": "{home}/.local/state/qwendex/local_llm_projects.json",
  "default_project": "{repo_root}",
  "managed_scope": "operator UX, local infrastructure, and guarded local-model routing",
  "default_backend_profile": "example-llamacpp-qwen-coder-gguf-32k",
  "active_backend_profile": "example-llamacpp-qwen-coder-gguf-32k",
  "context_presets": [
    20480,
    32768,
    49152,
    65536
  ],
  "chat_interfaces": {
    "open-webui": {
      "display_name": "Open WebUI",
      "windows_start_script": "{repo_root}/scripts/windows/open.ps1",
      "url": "http://127.0.0.1:7070",
      "backend_url": "http://127.0.0.1:4000/v1",
      "backend_profile": "example-llamacpp-qwen-coder-gguf-32k",
      "webui_name": "Local Qwen",
      "notes": "Bring your own Open WebUI install and point it at the LiteLLM proxy."
    }
  },
  "backend_profiles": [
    {
      "name": "example-llamacpp-qwen-coder-gguf-32k",
      "display_name": "Example llama.cpp GGUF 32k",
      "backend_kind": "llamacpp-gguf",
      "model_alias": "qwen-local",
      "model_path": "{home}/models/qwen-coder/example-model.gguf",
      "mtp_expected": false,
      "notes": "Copy to stack_manager.local.json and set LLAMACPP_MODEL_PATH or model_path to your local GGUF.",
      "service_overrides": {
        "textgen": {
          "display_name": "llama.cpp OpenAI-compatible backend",
          "window_name": "llamacpp",
          "provider_type": "llama.cpp OpenAI-compatible backend",
          "command": "LLAMACPP_MODEL_PATH='{home}/models/qwen-coder/example-model.gguf' LLAMACPP_MODEL_ALIAS='qwen-local' LLAMACPP_CTX_SIZE=32768 CODEX_TEXTGEN_CONTEXT_LIMIT_TOKENS=32768 scripts/run_llamacpp_qwopucode_gguf.sh",
          "health_url": "http://127.0.0.1:5000/v1/models",
          "models_url": "http://127.0.0.1:5000/v1/models",
          "port": 5000,
          "startup_timeout_seconds": 900,
          "notes": "Serves a GGUF through llama.cpp on the standard backend port."
        },
        "bridge": {
          "command": "CODEX_TEXTGEN_CONTEXT_LIMIT_TOKENS=32768 scripts/run_codex_textgen_bridge.sh",
          "notes": "Codex bridge context limit follows the selected backend profile."
        }
      }
    },
    {
      "name": "example-textgen-exl3-32k",
      "display_name": "Example TextGen EXL3 32k",
      "backend_kind": "textgen-exl3",
      "model_alias": "qwen-local",
      "model_path": "{home}/Text-Generation-WebUI/user_data/models/example-qwen-coder",
      "mtp_expected": false,
      "notes": "Copy locally and set TEXTGEN_MODEL or model_path to your TextGen model directory.",
      "service_overrides": {
        "textgen": {
          "display_name": "TextGen OpenAI-compatible backend",
          "window_name": "textgen",
          "provider_type": "TextGen OpenAI-compatible backend",
          "command": "TEXTGEN_MODEL='example-qwen-coder' TEXTGEN_CTX_SIZE=32768 TEXTGEN_CACHE_TYPE=q8 TEXTGEN_CHAT_TEMPLATE={repo_root}/config/local_llm_stack/qwen3_codex_tool_plain.jinja scripts/run_textgen_qwen_exl3.sh",
          "health_url": "http://127.0.0.1:5000/v1/models",
          "models_url": "http://127.0.0.1:5000/v1/models",
          "port": 5000,
          "startup_timeout_seconds": 900,
          "notes": "Serves a TextGen model on the standard backend port."
        }
      }
    }
  ],
  "services": [
    {
      "name": "textgen",
      "display_name": "OpenAI-compatible model backend",
      "window_name": "backend",
      "provider_type": "model backend",
      "working_dir": "{repo_root}",
      "command": "scripts/run_llamacpp_qwopucode_gguf.sh",
      "health_url": "http://127.0.0.1:5000/v1/models",
      "models_url": "http://127.0.0.1:5000/v1/models",
      "port": 5000,
      "startup_timeout_seconds": 900,
      "log_lines": 200,
      "notes": "Backends are bring-your-own-runtime; copy the sample config to stack_manager.local.json and set paths before starting."
    },
    {
      "name": "litellm",
      "display_name": "LiteLLM proxy",
      "window_name": "litellm",
      "provider_type": "OpenAI-compatible proxy",
      "working_dir": "{repo_root}",
      "command": "scripts/run_litellm_local_proxy.sh",
      "health_url": "http://127.0.0.1:4000/v1/models",
      "models_url": "http://127.0.0.1:4000/v1/models",
      "port": 4000,
      "startup_timeout_seconds": 120,
      "depends_on": [
        "textgen"
      ],
      "log_lines": 200,
      "notes": "Routes the public qwen-local alias to the active backend."
    },
    {
      "name": "bridge",
      "display_name": "Codex local-provider bridge",
      "window_name": "bridge",
      "provider_type": "Codex Responses bridge",
      "working_dir": "{repo_root}",
      "command": "scripts/run_codex_textgen_bridge.sh",
      "health_url": "http://127.0.0.1:1234/v1/models",
      "models_url": "http://127.0.0.1:1234/v1/models",
      "status_url": "http://127.0.0.1:1234/status",
      "port": 1234,
      "startup_timeout_seconds": 120,
      "depends_on": [
        "litellm"
      ],
      "log_lines": 200,
      "notes": "Codex-facing Responses bridge with guard and marker handling."
    }
  ],
  "provider_profiles": [
    {
      "name": "local-qwen-codex",
      "display_name": "Local Qwen Codex",
      "type": "local bridge",
      "launch_command": "LOCAL_QWEN_MODEL=qwen-local scripts/run_local_qwen_codex.sh --cwd {project}",
      "base_url": "http://127.0.0.1:1234",
      "models_url": "http://127.0.0.1:1234/v1/models",
      "tmux_session": "local-qwen-codex",
      "window_name": "codex",
      "open_new_terminal": true,
      "auto_start_services": true,
      "requires_services": [
        "bridge"
      ]
    },
    {
      "name": "normal-codex",
      "display_name": "Normal Codex",
      "type": "codex",
      "launch_command": "codex -C {project}",
      "tmux_session": "gpt-codex",
      "window_name": "codex",
      "open_new_terminal": true,
      "allow_codex_auth_file": true
    },
    {
      "name": "textgen-api",
      "display_name": "Backend API",
      "type": "OpenAI-compatible backend",
      "base_url": "http://127.0.0.1:5000",
      "models_url": "http://127.0.0.1:5000/v1/models"
    },
    {
      "name": "litellm",
      "display_name": "LiteLLM",
      "type": "OpenAI-compatible proxy",
      "base_url": "http://127.0.0.1:4000",
      "models_url": "http://127.0.0.1:4000/v1/models"
    }
  ],
  "model_profiles": [
    {
      "name": "qwen-local",
      "provider": "litellm",
      "default": true
    }
  ],
  "task_prompt_policy": {
    "max_output_tokens": 2048,
    "tool_temperature": 0.15,
    "rules": [
      "Use bounded commands and compact reads.",
      "Stop on LOCAL_MODEL_* guard markers.",
      "Keep local-model outputs receipt-backed and reviewable."
    ]
  }
}
