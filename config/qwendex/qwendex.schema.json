{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qwendex.local/schema/qwendex.config.v1.json",
  "title": "Qwendex Config",
  "type": "object",
  "required": ["schema_version", "version", "default_seat", "routing", "context", "guard", "sandbox", "qdex", "receipts", "state", "eval", "learning", "orchestration", "seats"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "qwendex.config.v1"},
    "version": {"type": "string"},
    "default_seat": {"enum": ["primary", "qwen", "audit", "release", "sandbox"]},
    "routing": {
      "type": "object",
      "required": ["mode", "prefer_local_qwen_when_available", "local_probe_url", "local_model", "fallback_seat", "probe_timeout_seconds", "prefer_for_task_classes", "primary_required_for_task_classes"],
      "additionalProperties": false,
      "properties": {
        "mode": {"enum": ["manual", "token_saver", "primary_only"]},
        "prefer_local_qwen_when_available": {"type": "boolean"},
        "local_probe_url": {"type": "string", "pattern": "^https?://"},
        "local_model": {"type": "string", "minLength": 1},
        "fallback_seat": {"enum": ["primary", "audit", "release"]},
        "probe_timeout_seconds": {"type": "number", "exclusiveMinimum": 0, "maximum": 30},
        "prefer_for_task_classes": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "primary_required_for_task_classes": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "context": {
      "type": "object",
      "required": ["compact_limit", "max_output_tokens", "tool_output_token_limit", "reminder_tool_call_threshold", "reminder_repeat_interval", "phase_boundary_labels"],
      "additionalProperties": false,
      "properties": {
        "compact_limit": {"type": "integer", "minimum": 1024},
        "max_output_tokens": {"type": "integer", "minimum": 256},
        "tool_output_token_limit": {"type": "integer", "minimum": 256},
        "reminder_tool_call_threshold": {"type": "integer", "minimum": 1},
        "reminder_repeat_interval": {"type": "integer", "minimum": 1},
        "phase_boundary_labels": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "guard": {
      "type": "object",
      "required": ["max_wall_time_seconds", "max_tool_calls", "markers"],
      "additionalProperties": false,
      "properties": {
        "max_wall_time_seconds": {"type": "integer", "minimum": -1},
        "max_tool_calls": {"type": "integer", "minimum": -1},
        "markers": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "sandbox": {
      "type": "object",
      "required": ["mode"],
      "additionalProperties": false,
      "properties": {
        "mode": {"enum": ["workspace-write", "read-only"]}
      }
    },
    "qdex": {
      "type": "object",
      "required": ["permission_mode"],
      "additionalProperties": false,
      "properties": {
        "permission_mode": {"enum": ["workspace-write", "yolo"]}
      }
    },
    "receipts": {
      "type": "object",
      "required": ["dir", "ledger"],
      "additionalProperties": false,
      "properties": {
        "dir": {"type": "string", "minLength": 1},
        "ledger": {"type": "string", "minLength": 1}
      }
    },
    "state": {
      "type": "object",
      "required": ["db"],
      "additionalProperties": false,
      "properties": {
        "db": {"type": "string", "minLength": 1}
      }
    },
    "performance": {
      "type": "object",
      "required": ["capture", "retention_days", "max_events", "query_fingerprints"],
      "additionalProperties": false,
      "properties": {
        "capture": {"enum": ["off", "metadata"]},
        "retention_days": {"type": "integer", "minimum": 1, "maximum": 3650},
        "max_events": {"type": "integer", "minimum": 1, "maximum": 5000000},
        "query_fingerprints": {"type": "boolean"}
      }
    },
    "eval": {
      "type": "object",
      "required": ["default_case"],
      "additionalProperties": false,
      "properties": {
        "default_case": {"type": "string", "minLength": 1}
      }
    },
    "learning": {
      "type": "object",
      "required": ["mode", "default_backend"],
      "additionalProperties": false,
      "properties": {
        "mode": {"enum": ["stage_only", "disabled"]},
        "default_backend": {"enum": ["mock", "codex"]}
      }
    },
    "orchestration": {
      "type": "object",
      "required": ["mode", "manager_deploy_policy", "local_subagents", "kaveman", "mode_profiles", "local_qwen_eligibility", "escalation_thresholds", "stale_session_thresholds_minutes"],
      "additionalProperties": false,
      "properties": {
        "mode": {"enum": ["manual", "off", "auto", "lite", "medium", "heavy", "manager", "manager_only"]},
        "manager_deploy_policy": {"enum": ["auto", "disabled"]},
        "local_subagents": {
          "type": "object",
          "required": ["enabled"],
          "additionalProperties": false,
          "properties": {
            "enabled": {"type": "boolean"}
          }
        },
        "kaveman": {
          "type": "object",
          "required": ["enabled", "directive"],
          "additionalProperties": false,
          "properties": {
            "enabled": {"type": "boolean"},
            "directive": {"type": "string", "minLength": 1}
          }
        },
        "mode_profiles": {
          "type": "object",
          "required": ["off", "auto", "lite", "medium", "heavy", "manager"],
          "additionalProperties": false,
          "properties": {
            "off": {"$ref": "#/$defs/managerModeProfile"},
            "auto": {"$ref": "#/$defs/managerModeProfile"},
            "lite": {"$ref": "#/$defs/managerModeProfile"},
            "medium": {"$ref": "#/$defs/managerModeProfile"},
            "heavy": {"$ref": "#/$defs/managerModeProfile"},
            "manager": {"$ref": "#/$defs/managerModeProfile"}
          }
        },
        "local_qwen_eligibility": {
          "type": "object",
          "required": ["allowed_task_classes", "denied_task_classes", "max_risk"],
          "additionalProperties": false,
          "properties": {
            "allowed_task_classes": {
              "type": "array",
              "items": {"type": "string", "minLength": 1}
            },
            "denied_task_classes": {
              "type": "array",
              "items": {"type": "string", "minLength": 1}
            },
            "max_risk": {"enum": ["low", "medium", "high"]}
          }
        },
        "escalation_thresholds": {
          "type": "object",
          "required": ["high", "xhigh"],
          "additionalProperties": false,
          "properties": {
            "high": {
              "type": "array",
              "items": {"type": "string", "minLength": 1}
            },
            "xhigh": {
              "type": "array",
              "items": {"type": "string", "minLength": 1}
            }
          }
        },
        "stale_session_thresholds_minutes": {
          "type": "object",
          "required": ["off", "auto", "lite", "medium", "heavy", "manager"],
          "additionalProperties": false,
          "properties": {
            "off": {"type": "integer", "minimum": 5, "maximum": 240},
            "auto": {"type": "integer", "minimum": 5, "maximum": 240},
            "lite": {"type": "integer", "minimum": 5, "maximum": 240},
            "medium": {"type": "integer", "minimum": 5, "maximum": 240},
            "heavy": {"type": "integer", "minimum": 5, "maximum": 240},
            "manager": {"type": "integer", "minimum": 5, "maximum": 240}
          }
        }
      }
    },
    "seats": {
      "type": "object",
      "required": ["primary", "qwen", "audit", "release", "sandbox"],
      "additionalProperties": false,
      "properties": {
        "primary": {"$ref": "#/$defs/primarySeat"},
        "qwen": {"$ref": "#/$defs/qwenSeat"},
        "audit": {"$ref": "#/$defs/auditSeat"},
        "release": {"$ref": "#/$defs/releaseSeat"},
        "sandbox": {"$ref": "#/$defs/sandboxSeat"}
      }
    }
  },
  "$defs": {
    "managerModeProfile": {
      "type": "object",
      "required": ["label", "max_subagents"],
      "additionalProperties": false,
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "max_subagents": {"type": "integer", "minimum": 0, "maximum": 8}
      }
    },
    "primarySeat": {
      "type": "object",
      "required": ["model", "authority", "backend", "context_window", "guard_profile"],
      "additionalProperties": false,
      "properties": {
        "model": {"type": "string", "minLength": 1},
        "authority": {"const": "release_review"},
        "backend": {"const": "codex"},
        "context_window": {"type": "integer", "minimum": 1024},
        "compact_limit": {"type": "integer", "minimum": 1024},
        "guard_profile": {"enum": ["balanced", "max_safety"]}
      }
    },
    "qwenSeat": {
      "type": "object",
      "required": ["authority", "backend", "context_window", "compact_limit", "guard_profile"],
      "additionalProperties": false,
      "properties": {
        "authority": {"const": "bounded_operator"},
        "backend": {"const": "local-responses-adapter"},
        "context_window": {"type": "integer", "minimum": 1024},
        "compact_limit": {"type": "integer", "minimum": 1024},
        "guard_profile": {"enum": ["balanced", "max_safety"]}
      }
    },
    "auditSeat": {
      "type": "object",
      "required": ["model", "authority", "backend", "context_window", "guard_profile"],
      "additionalProperties": false,
      "properties": {
        "model": {"type": "string", "minLength": 1},
        "authority": {"const": "read_only_review"},
        "backend": {"const": "codex"},
        "context_window": {"type": "integer", "minimum": 1024},
        "compact_limit": {"type": "integer", "minimum": 1024},
        "guard_profile": {"enum": ["balanced", "max_safety"]}
      }
    },
    "releaseSeat": {
      "type": "object",
      "required": ["model", "authority", "backend", "context_window", "guard_profile"],
      "additionalProperties": false,
      "properties": {
        "model": {"type": "string", "minLength": 1},
        "authority": {"const": "public_release_acceptance"},
        "backend": {"const": "codex"},
        "context_window": {"type": "integer", "minimum": 1024},
        "compact_limit": {"type": "integer", "minimum": 1024},
        "guard_profile": {"enum": ["balanced", "max_safety"]}
      }
    },
    "sandboxSeat": {
      "type": "object",
      "required": ["authority", "backend", "context_window", "compact_limit", "guard_profile"],
      "additionalProperties": false,
      "properties": {
        "authority": {"const": "isolated_probe"},
        "backend": {"const": "local-responses-adapter"},
        "context_window": {"type": "integer", "minimum": 1024},
        "compact_limit": {"type": "integer", "minimum": 1024},
        "guard_profile": {"enum": ["balanced", "max_safety"]}
      }
    }
  }
}
