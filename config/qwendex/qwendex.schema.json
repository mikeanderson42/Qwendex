{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qwendex.local/schema/qwendex.config.v1.json",
  "title": "Qwendex Config",
  "type": "object",
  "required": ["schema_version", "version", "default_seat", "routing", "seats", "guard", "receipts", "state", "eval", "learning", "orchestration"],
  "properties": {
    "schema_version": {
      "const": "qwendex.config.v1"
    },
    "version": {
      "type": "string"
    },
    "default_seat": {
      "enum": ["primary", "qwen", "audit", "release", "sandbox"]
    },
    "routing": {
      "type": "object",
      "required": ["mode", "prefer_local_qwen_when_available", "local_probe_url", "local_model", "fallback_seat", "probe_timeout_seconds", "prefer_for_task_classes", "primary_required_for_task_classes"],
      "properties": {
        "mode": {"enum": ["manual", "token_saver", "primary_only"]},
        "prefer_local_qwen_when_available": {"type": "boolean"},
        "local_probe_url": {"type": "string", "pattern": "^https?://"},
        "local_model": {"type": "string", "minLength": 1},
        "fallback_seat": {"enum": ["primary", "qwen", "audit", "release", "sandbox"]},
        "probe_timeout_seconds": {"type": "number", "exclusiveMinimum": 0, "maximum": 30},
        "prefer_for_task_classes": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "primary_required_for_task_classes": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "context": {
      "type": "object",
      "properties": {
        "compact_limit": {"type": "integer", "minimum": 1024},
        "max_output_tokens": {"type": "integer", "minimum": 256},
        "tool_output_token_limit": {"type": "integer", "minimum": 256},
        "reminder_tool_call_threshold": {"type": "integer", "minimum": 1},
        "reminder_repeat_interval": {"type": "integer", "minimum": 1},
        "phase_boundary_labels": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "guard": {
      "type": "object",
      "required": ["profile", "max_wall_time_seconds", "max_tool_calls"],
      "properties": {
        "profile": {"enum": ["balanced", "max_safety"]},
        "max_wall_time_seconds": {"type": "integer"},
        "max_tool_calls": {"type": "integer"},
        "markers": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "sandbox": {
      "type": "object",
      "properties": {
        "mode": {"enum": ["workspace-write", "read-only"]},
        "trusted_roots": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "receipts": {
      "type": "object",
      "required": ["dir", "ledger"],
      "properties": {
        "dir": {"type": "string"},
        "ledger": {"type": "string"}
      }
    },
    "state": {
      "type": "object",
      "required": ["db"],
      "properties": {
        "db": {"type": "string"}
      }
    },
    "eval": {
      "type": "object",
      "required": ["mode", "default_case"],
      "properties": {
        "mode": {"enum": ["offline-first", "live-required"]},
        "default_case": {"type": "string"},
        "live_requires_running_stack": {"type": "boolean"}
      }
    },
    "learning": {
      "type": "object",
      "required": ["mode", "default_backend", "codex_budget_requires_approval"],
      "properties": {
        "mode": {"enum": ["stage_only", "manual", "disabled"]},
        "default_backend": {"enum": ["mock", "codex"]},
        "auto_harvest": {"type": "boolean"},
        "auto_stage_safe_proposals": {"type": "boolean"},
        "codex_budget_requires_approval": {"type": "boolean"}
      }
    },
    "orchestration": {
      "type": "object",
      "required": ["mode", "manager_deploy_policy", "manager_only_available", "shortcut", "shortcut_command", "max_subagents", "stale_after_minutes", "local_subagents", "kaveman", "mode_order", "mode_profiles", "estimator", "local_qwen_eligibility", "escalation_thresholds", "stale_session_thresholds_minutes", "close_stale_policy"],
      "properties": {
        "mode": {"enum": ["manual", "off", "auto", "lite", "medium", "heavy", "manager", "manager_only"]},
        "manager_deploy_policy": {"enum": ["auto", "disabled"]},
        "manager_only_available": {"type": "boolean"},
        "shortcut": {"type": "string"},
        "shortcut_command": {"type": "string"},
        "max_subagents": {"type": "integer", "minimum": 1, "maximum": 10},
        "stale_after_minutes": {"type": "integer", "minimum": 5, "maximum": 240},
        "local_subagents": {
          "type": "object",
          "required": ["enabled", "shortcut", "shortcut_command"],
          "properties": {
            "enabled": {"type": "boolean"},
            "shortcut": {"type": "string"},
            "shortcut_command": {"type": "string"}
          }
        },
        "kaveman": {
          "type": "object",
          "required": ["enabled", "shortcut", "shortcut_command", "directive"],
          "properties": {
            "enabled": {"type": "boolean"},
            "shortcut": {"type": "string"},
            "shortcut_command": {"type": "string"},
            "directive": {"type": "string", "minLength": 1}
          }
        },
        "mode_order": {
          "type": "array",
          "prefixItems": [
            {"const": "off"},
            {"const": "auto"},
            {"const": "lite"},
            {"const": "medium"},
            {"const": "heavy"},
            {"const": "manager"}
          ],
          "minItems": 6,
          "maxItems": 6
        },
        "mode_profiles": {
          "type": "object",
          "required": ["off", "auto", "lite", "medium", "heavy", "manager"],
          "additionalProperties": false,
          "properties": {
            "off": {"$ref": "#/$defs/managerModeProfile"},
            "auto": {"$ref": "#/$defs/managerModeProfile"},
            "lite": {"$ref": "#/$defs/managerModeProfile"},
            "medium": {"$ref": "#/$defs/managerModeProfile"},
            "heavy": {"$ref": "#/$defs/managerModeProfile"},
            "manager": {"$ref": "#/$defs/managerModeProfile"}
          }
        },
        "estimator": {
          "type": "object",
          "required": ["enabled", "skill", "model", "reasoning", "max_input_tokens", "max_output_tokens"],
          "properties": {
            "enabled": {"type": "boolean"},
            "skill": {"type": "string"},
            "model": {"type": "string"},
            "reasoning": {"enum": ["low", "medium", "high", "xhigh"]},
            "max_input_tokens": {"type": "integer", "minimum": 64, "maximum": 20000},
            "max_output_tokens": {"type": "integer", "minimum": 64, "maximum": 20000}
          }
        },
        "local_qwen_eligibility": {
          "type": "object",
          "required": ["allowed_task_classes", "denied_task_classes", "max_risk"],
          "properties": {
            "allowed_task_classes": {
              "type": "array",
              "items": {"type": "string", "minLength": 1}
            },
            "denied_task_classes": {
              "type": "array",
              "items": {"type": "string", "minLength": 1}
            },
            "max_risk": {"enum": ["low", "medium", "high"]}
          }
        },
        "escalation_thresholds": {
          "type": "object",
          "properties": {
            "high": {
              "type": "array",
              "items": {"type": "string", "minLength": 1}
            },
            "xhigh": {
              "type": "array",
              "items": {"type": "string", "minLength": 1}
            }
          }
        },
        "stale_session_thresholds_minutes": {
          "type": "object",
          "required": ["auto", "lite", "medium", "heavy", "manager"],
          "properties": {
            "auto": {"type": "integer", "minimum": 5, "maximum": 240},
            "lite": {"type": "integer", "minimum": 5, "maximum": 240},
            "medium": {"type": "integer", "minimum": 5, "maximum": 240},
            "heavy": {"type": "integer", "minimum": 5, "maximum": 240},
            "manager": {"type": "integer", "minimum": 5, "maximum": 240}
          }
        },
        "close_stale_policy": {"type": "string"},
        "auto_deploy_when": {
          "type": "array",
          "items": {"type": "string"}
        },
        "manager_responsibilities": {
          "type": "array",
          "items": {"type": "string"}
        },
        "borrowed_patterns": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "mcp_tools": {
      "type": "array",
      "items": {"type": "string"}
    },
    "seats": {
      "type": "object",
      "required": ["primary", "qwen", "audit", "release", "sandbox"],
      "additionalProperties": {
        "type": "object",
        "required": ["model", "authority", "backend", "context_window", "guard_profile"],
        "properties": {
          "model": {"type": "string"},
          "authority": {"type": "string"},
          "backend": {"type": "string"},
          "context_window": {"type": "integer", "minimum": 1024},
          "compact_limit": {"type": "integer", "minimum": 1024},
          "guard_profile": {"enum": ["balanced", "max_safety"]},
          "prompt_template": {"type": "string"}
        }
      }
    }
  },
  "$defs": {
    "managerModeProfile": {
      "type": "object",
      "required": ["label", "offload_target", "max_subagents"],
      "properties": {
        "label": {"type": "string"},
        "offload_target": {"type": "string"},
        "max_subagents": {"type": "integer", "minimum": 1, "maximum": 10}
      }
    }
  },
  "additionalProperties": false
}
