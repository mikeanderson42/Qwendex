#!/usr/bin/env bash
set -euo pipefail

QWENDEX_DEV_ROOT="${QWENDEX_DEV_ROOT:-$HOME/qwendex-dev}"
QWENDEX_ENV="$QWENDEX_DEV_ROOT/.qwendex-dev/env.sh"
QWENDEX_YOLO_FLAG="${QWENDEX_YOLO_FLAG:---dangerously-bypass-approvals-and-sandbox}"
QWENDEX_HOOK_TRUST_FLAG="${QWENDEX_HOOK_TRUST_FLAG:---dangerously-bypass-hook-trust}"
QWENDEX_CODEX_MAX_CONCURRENT_THREADS=9
QWENDEX_CODEX_MAX_WAIT_TIMEOUT_MS=120000
caller_cwd="$PWD"

# A generation pin is valid only after the stable selector has transferred
# control to that generation's immutable Qdex copy.  Do not let a value left
# in a login shell make a fresh top-level launch reuse a stale generation.
launcher_qdex="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || true)"
pinned_qdex=""
if [[ -n "${QWENDEX_RUNTIME_TREE:-}" ]]; then
  pinned_qdex="$(readlink -f "$QWENDEX_RUNTIME_TREE/scripts/qdex" 2>/dev/null || true)"
fi
if [[ "${QWENDEX_RUNTIME_PINNED:-0}" == "1" && ( -z "$launcher_qdex" || -z "$pinned_qdex" || "$launcher_qdex" != "$pinned_qdex" ) ]]; then
  unset QWENDEX_RUNTIME_PINNED
  unset QWENDEX_RUNTIME_GENERATION_ID
  unset QWENDEX_RUNTIME_GENERATION_DIR
  unset QWENDEX_RUNTIME_TREE
  unset QWENDEX_RUNTIME_CONTRACT_SHA256
  unset QWENDEX_HOOK_GENERATION
  unset QWENDEX_CODEX_HOME
  unset QWENDEX_CODEX_RUNTIME
  unset QWENDEX_RUNTIME_ROOT
  unset QWENDEX_ROOT
fi

# The installed launcher is a stable selector.  It reads one atomically
# replaced selection record, validates the selected generation boundary, then
# transfers control to the immutable Qdex copy in that generation.  A process
# that has already crossed this boundary never rereads the selector, so later
# activation affects new sessions only.
if [[ "${QWENDEX_RUNTIME_PINNED:-0}" != "1" ]]; then
  runtime_selection="$QWENDEX_DEV_ROOT/.qwendex-dev/runtime/current.json"
  if [[ -f "$runtime_selection" ]]; then
    runtime_fields=()
    while IFS= read -r runtime_field; do
      runtime_fields+=("$runtime_field")
    done < <(python3 - "$runtime_selection" "$QWENDEX_DEV_ROOT/.qwendex-dev/runtime" <<'PY'
import json
import hashlib
import sys
from pathlib import Path


def canonical_digest(value):
    payload = json.dumps(
        value,
        sort_keys=True,
        separators=(",", ":"),
        ensure_ascii=False,
    ).encode("utf-8")
    return hashlib.sha256(payload).hexdigest()


def sha256_file(path):
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()

selection_path = Path(sys.argv[1])
runtime_root = Path(sys.argv[2]).resolve()
try:
    selection = json.loads(selection_path.read_text(encoding="utf-8"))
    if selection.get("schema_version") != "qwendex.runtime_selection.v1":
        raise ValueError("unsupported selector schema")
    generation_id = str(selection.get("current") or "")
    if not generation_id.startswith("rtg-"):
        raise ValueError("missing selected generation")
    generation = (runtime_root / "generations" / generation_id).resolve()
    generation.relative_to((runtime_root / "generations").resolve())
    manifest = json.loads((generation / "generation.json").read_text(encoding="utf-8"))
    if (
        manifest.get("schema_version") != "qwendex.runtime_generation.v1"
        or manifest.get("generation_id") != generation_id
        or manifest.get("status") != "validated"
        or manifest.get("result") != "pass"
    ):
        raise ValueError("selected generation is not validated")
    required = (
        generation / "tree" / "scripts" / "qdex",
        generation / "tree" / "scripts" / "qwendex",
        generation / "bin" / "codex-runtime",
        generation / "codex_home" / "hooks.json",
    )
    if not all(path.is_file() for path in required):
        raise ValueError("selected generation is incomplete")
    seal_payload = dict(manifest)
    expected_seal = str(seal_payload.pop("manifest_sha256", ""))
    if not expected_seal or canonical_digest(seal_payload) != expected_seal:
        raise ValueError("selected generation manifest seal is invalid")
    contract = manifest.get("contract") or {}
    if canonical_digest(contract) != str(manifest.get("contract_sha256") or ""):
        raise ValueError("selected generation contract digest is invalid")
    tree_contract = {
        str(item.get("path") or ""): item
        for item in manifest.get("tree_manifest") or []
    }
    for relative in ("scripts/qdex", "scripts/qwendex"):
        entry = tree_contract.get(relative) or {}
        path = generation / "tree" / relative
        if sha256_file(path) != str(entry.get("sha256") or ""):
            raise ValueError(f"selected generation source digest drifted: {relative}")
    codex_contract = manifest.get("codex") or {}
    for path, key in (
        (generation / "bin" / "codex", "binary_sha256"),
        (generation / "bin" / "codex-code-mode-host", "code_mode_host_sha256"),
    ):
        if sha256_file(path) != str(codex_contract.get(key) or ""):
            raise ValueError(f"selected generation executable digest drifted: {path.name}")
    hook = generation / "codex_home" / "hooks.json"
    if sha256_file(hook) != str((manifest.get("hooks") or {}).get("sha256") or ""):
        raise ValueError("selected generation hook digest drifted")
except Exception as exc:
    print(f"ERROR:{exc}")
    raise SystemExit(0)
print(generation_id)
print(generation)
print(generation / "tree")
print(manifest.get("contract_sha256", ""))
print(generation / "codex_home")
print(generation / "bin" / "codex-runtime")
PY
)
    if [[ "${runtime_fields[0]:-}" == ERROR:* || "${#runtime_fields[@]}" -ne 6 ]]; then
      printf 'qdex: runtime generation selection is invalid: %s\n' "${runtime_fields[0]#ERROR:}" >&2
      printf 'qdex: recover from a shell with %s/.qwendex-dev/bin/qwendex-runtime-recovery rollback --json\n' "$QWENDEX_DEV_ROOT" >&2
      printf 'qdex: ordinary stock codex remains available.\n' >&2
      exit 127
    fi
    export QWENDEX_RUNTIME_PINNED=1
    export QWENDEX_RUNTIME_GENERATION_ID="${runtime_fields[0]}"
    export QWENDEX_RUNTIME_GENERATION_DIR="${runtime_fields[1]}"
    export QWENDEX_RUNTIME_TREE="${runtime_fields[2]}"
    export QWENDEX_RUNTIME_CONTRACT_SHA256="${runtime_fields[3]}"
    export QWENDEX_HOOK_GENERATION="${runtime_fields[0]}"
    export QWENDEX_CODEX_HOME="${runtime_fields[4]}"
    export QWENDEX_CODEX_RUNTIME="${runtime_fields[5]}"
    export QWENDEX_RUNTIME_ROOT="$QWENDEX_DEV_ROOT/.qwendex-dev/runtime"
    exec "$QWENDEX_RUNTIME_TREE/scripts/qdex" "$@"
  elif [[ "${QWENDEX_RUNTIME_GENERATION_REQUIRED:-0}" == "1" ]]; then
    printf 'qdex: no validated runtime generation is selected.\n' >&2
    printf 'qdex: run scripts/qwendex runtime build --json from stock Codex or a shell.\n' >&2
    exit 127
  fi
fi

pinned_runtime_generation_id="${QWENDEX_RUNTIME_GENERATION_ID:-}"
pinned_runtime_generation_dir="${QWENDEX_RUNTIME_GENERATION_DIR:-}"
pinned_runtime_tree="${QWENDEX_RUNTIME_TREE:-}"
pinned_runtime_contract="${QWENDEX_RUNTIME_CONTRACT_SHA256:-}"
pinned_runtime_codex_home="${QWENDEX_CODEX_HOME:-}"
pinned_runtime_codex="${QWENDEX_CODEX_RUNTIME:-}"

toml_string() {
  python3 - "$1" <<'PY'
import json
import sys

print(json.dumps(sys.argv[1], ensure_ascii=False))
PY
}

resolve_qdex_permission_mode() {
  local cli_value="$1"
  local published_config="${QWENDEX_ROOT:-$QWENDEX_DEV_ROOT}/config/qwendex/qwendex.json"
  local operator_config="${XDG_CONFIG_HOME:-$HOME/.config}/qwendex/qdex.json"
  python3 - "$cli_value" "$published_config" "$operator_config" <<'PY'
import json
import os
import sys
from pathlib import Path


VALID = {"workspace-write", "yolo"}
cli_value, published_path, operator_path = sys.argv[1:]


def fail(scope, value):
    print(
        f"qdex: invalid permission_mode from {scope}: {value!r}; "
        "expected workspace-write or yolo",
        file=sys.stderr,
    )
    raise SystemExit(2)


def read_object(path, scope):
    try:
        data = json.loads(Path(path).read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        print(f"qdex: cannot read {scope} permission config: {exc}", file=sys.stderr)
        raise SystemExit(2) from exc
    if not isinstance(data, dict):
        print(f"qdex: {scope} permission config must be a JSON object", file=sys.stderr)
        raise SystemExit(2)
    return data


def emit(mode, source):
    if mode not in VALID:
        fail(source, mode)
    print(mode)
    print(source)
    raise SystemExit(0)


if cli_value:
    emit(cli_value, "cli")
if "QWENDEX_QDEX_PERMISSION_MODE" in os.environ:
    emit(os.environ["QWENDEX_QDEX_PERMISSION_MODE"].strip(), "environment")
if Path(operator_path).exists():
    operator = read_object(operator_path, "operator")
    emit(operator.get("permission_mode"), "operator-config")
if Path(published_path).exists():
    published = read_object(published_path, "published")
    qdex = published.get("qdex")
    if qdex is not None:
        if not isinstance(qdex, dict):
            print("qdex: published qdex config must be a JSON object", file=sys.stderr)
            raise SystemExit(2)
        if "permission_mode" in qdex:
            emit(qdex["permission_mode"], "published-config")
emit("workspace-write", "default")
PY
}

if [[ ! -f "$QWENDEX_ENV" ]]; then
  printf 'qdex: missing Qwendex env: %s\n' "$QWENDEX_ENV" >&2
  printf 'qdex: run %s/scripts/qwendex_dev_env sync first.\n' "$QWENDEX_DEV_ROOT" >&2
  exit 127
fi

# shellcheck disable=SC1090
source "$QWENDEX_ENV"
if [[ "${QWENDEX_RUNTIME_PINNED:-0}" == "1" ]]; then
  export QWENDEX_RUNTIME_GENERATION_ID="$pinned_runtime_generation_id"
  export QWENDEX_RUNTIME_GENERATION_DIR="$pinned_runtime_generation_dir"
  export QWENDEX_RUNTIME_TREE="$pinned_runtime_tree"
  export QWENDEX_RUNTIME_CONTRACT_SHA256="$pinned_runtime_contract"
  export QWENDEX_HOOK_GENERATION="$pinned_runtime_generation_id"
  export QWENDEX_CODEX_HOME="$pinned_runtime_codex_home"
  export QWENDEX_CODEX_RUNTIME="$pinned_runtime_codex"
  export QWENDEX_RUNTIME_ROOT="$QWENDEX_DEV_ROOT/.qwendex-dev/runtime"
  export QWENDEX_ROOT="$pinned_runtime_tree"
fi
if [[ -z "${QWENDEX_CODEX_HOME:-}" || -z "${QWENDEX_CODEX_RUNTIME:-}" ]]; then
  printf 'qdex: generated environment is missing the isolated home or internal runtime.\n' >&2
  exit 127
fi
export CODEX_HOME="$QWENDEX_CODEX_HOME"
QWENDEX_QWENDEX_COMMAND="${QWENDEX_RUNTIME_TREE:-$QWENDEX_DEV_ROOT}/scripts/qwendex"
if [[ ! -x "$QWENDEX_QWENDEX_COMMAND" ]]; then
  printf 'qdex: selected Qwendex command is not executable: %s\n' "$QWENDEX_QWENDEX_COMMAND" >&2
  exit 127
fi
# The patched TUI dispatches Alt+M/K/L through `qwendex` on PATH. Put this
# launch's immutable runtime tree first so a source-tree wrapper cannot change
# the policy or status authority of an already-pinned Qdex process.
export PATH="$(dirname "$QWENDEX_QWENDEX_COMMAND"):$PATH"
# Dynamic Manager identities belong to one qdex launch. Never let a caller's
# stale child-process environment select or collide with a prior lease.
unset \
  QWENDEX_MANAGER_SESSION_ID \
  QWENDEX_MANAGER_LEDGER_ID \
  QWENDEX_MANAGER_ROOT_AGENT_ID \
  QWENDEX_MANAGER_LAUNCH_PID \
  QWENDEX_MANAGER_LAUNCH_START_TICKS \
  QWENDEX_MANAGER_LAUNCH_NONCE \
  QWENDEX_MANAGER_LAUNCH_KEY \
  QWENDEX_MANAGER_STATE_DB_IDENTITY \
  QWENDEX_MANAGER_LEDGER_DB_IDENTITY \
  QWENDEX_MANAGER_RUNTIME_IDENTITY \
  QWENDEX_MANAGER_POLICY_HASH \
  QWENDEX_MANAGER_STOP_STATUS \
  QWENDEX_MANAGER_SESSION_STATE_FILE \
  QWENDEX_QDEX_LAUNCH_ID \
  QWENDEX_QDEX_LAUNCH_POLICY_HASH \
  QWENDEX_QDEX_LAUNCH_MODE \
  QWENDEX_QDEX_LAUNCH_AGENT_USE \
  QWENDEX_QDEX_LAUNCH_MAX_WORKERS \
  QWENDEX_QDEX_LAUNCH_LOCAL_ENABLED \
  QWENDEX_NATIVE_PROACTIVE_SOURCE \
  QWENDEX_RUN_ID

export QWENDEX_MANAGER_LAUNCH_PID="$$"
QWENDEX_MANAGER_LAUNCH_START_TICKS="$(python3 - "$$" <<'PY'
import sys
from pathlib import Path

pid = sys.argv[1]
try:
    stat = Path(f"/proc/{pid}/stat").read_text(encoding="utf-8")
except OSError:
    print("")
    raise SystemExit(0)
closing = stat.rfind(")")
fields = stat[closing + 2:].split() if closing >= 0 else []
if len(fields) <= 19:
    print("")
    raise SystemExit(0)
print(fields[19])
PY
)" || {
  printf 'qdex: cannot establish launcher process identity.\n' >&2
  exit 127
}
export QWENDEX_MANAGER_LAUNCH_START_TICKS
export QWENDEX_MANAGER_LAUNCH_NONCE="$(python3 - <<'PY'
import uuid

print(uuid.uuid4().hex)
PY
)"

manager_preflight_dry_run=0
json_output=0
target_repo=""
codex_args=()
codex_sets_cwd=0
qdex_sets_repo=0
parse_qdex_options=1
cli_permission_mode=""

if [[ "${QWENDEX_QDEX_DRY_RUN:-0}" == "1" ]]; then
  manager_preflight_dry_run=1
fi

while [[ $# -gt 0 ]]; do
  if [[ "$parse_qdex_options" == "0" ]]; then
    codex_args+=("$1")
    shift
    continue
  fi
  case "$1" in
    --)
      codex_args+=("--")
      parse_qdex_options=0
      shift
      ;;
    --qdex-permission-mode)
      shift
      if [[ $# -eq 0 || ( "$1" != "yolo" && "$1" != "workspace-write" ) ]]; then
        printf 'qdex: --qdex-permission-mode requires yolo or workspace-write\n' >&2
        exit 2
      fi
      cli_permission_mode="$1"
      shift
      ;;
    --manager-preflight-dry-run)
      manager_preflight_dry_run=1
      shift
      ;;
    --qdex-json)
      json_output=1
      shift
      ;;
    --json)
      if [[ "$manager_preflight_dry_run" == "1" ]]; then
        # Backward-compatible dry-run rendering. Outside a Qdex dry run this
        # is Codex's own flag (for example `codex exec --json`) and must pass
        # through unchanged.
        json_output=1
      else
        codex_args+=("$1")
      fi
      shift
      ;;
    --repo)
      shift
      if [[ $# -eq 0 ]]; then
        printf 'qdex: --repo requires a path\n' >&2
        exit 2
      fi
      target_repo="$1"
      qdex_sets_repo=1
      shift
      ;;
    -C|--cd)
      cwd_option="$1"
      codex_args+=("$1")
      shift
      if [[ $# -eq 0 ]]; then
        printf 'qdex: %s requires a path\n' "$cwd_option" >&2
        exit 2
      fi
      target_repo="$1"
      codex_args+=("$1")
      codex_sets_cwd=1
      shift
      ;;
    --cd=*)
      target_repo="${1#--cd=}"
      codex_args+=("$1")
      codex_sets_cwd=1
      shift
      ;;
    *)
      codex_args+=("$1")
      shift
      ;;
  esac
done

# Codex 0.145 introduces memory persistence and configurable agent roles.
# Qdex owns an isolated runtime boundary, so it keeps those stateful or
# role-specific controls out of ordinary Qwendex launches until a dedicated
# retention and lifecycle contract exists.  Keep the legacy thread-cap aliases
# available: the explicit V2 ceiling appended below remains authoritative.
reject_deferred_codex_controls() {
  local arg_index
  local config_override
  local config_key
  local feature_name
  for ((arg_index = 0; arg_index < ${#codex_args[@]}; arg_index++)); do
    case "${codex_args[$arg_index]}" in
      --)
        break
        ;;
      -p|--profile|--profile=*)
        printf 'qdex: Codex --profile is unavailable while Qwendex defers native role configuration.\n' >&2
        exit 2
        ;;
      --remote|--remote=*)
        printf 'qdex: Codex remote app-server connections are unavailable while Qwendex defers history and memory lifecycle controls.\n' >&2
        exit 2
        ;;
      --enable)
        feature_name="${codex_args[$((arg_index + 1))]:-}"
        ;;
      --enable=*)
        feature_name="${codex_args[$arg_index]#--enable=}"
        ;;
      *)
        feature_name=""
        ;;
    esac
    case "${feature_name,,}" in
      memories|memory_tool|external_agent_memory_import|chronicle|telepathy)
        printf 'qdex: experimental Codex memories are disabled by the Qwendex release policy.\n' >&2
        exit 2
        ;;
    esac

    config_override=""
    case "${codex_args[$arg_index]}" in
      -c|--config)
        config_override="${codex_args[$((arg_index + 1))]:-}"
        ;;
      --config=*)
        config_override="${codex_args[$arg_index]#--config=}"
        ;;
    esac
    [[ "$config_override" == *=* ]] || continue
    config_key="${config_override%%=*}"
    config_key="${config_key//[[:space:]]/}"
    case "$config_key" in
      features.memories|features.memories.*|features.memory_tool|features.memory_tool.*|features.external_agent_memory_import|features.external_agent_memory_import.*|features.chronicle|features.chronicle.*|features.telepathy|features.telepathy.*)
        printf 'qdex: experimental Codex memories are disabled by the Qwendex release policy.\n' >&2
        exit 2
        ;;
      memories|memories.*|history|history.*)
        printf 'qdex: experimental Codex history and memory controls are disabled by the Qwendex release policy.\n' >&2
        exit 2
        ;;
      features.multi_agent_v2.expose_spawn_agent_model_overrides|features.multi_agent_v2.hide_spawn_agent_metadata)
        printf 'qdex: native role-driven model and reasoning controls are deferred by the Qwendex release policy.\n' >&2
        exit 2
        ;;
      agents|agents.*)
        case "$config_key" in
          agents.max_threads|agents.max_concurrent_threads_per_session)
            ;;
          *)
            printf 'qdex: native [agents] role and default controls are deferred by the Qwendex release policy.\n' >&2
            exit 2
            ;;
        esac
        ;;
    esac
  done
}

reject_deferred_app_server_command() {
  local arg_index=0
  local arg
  # Find only the top-level Codex subcommand.  Once an ordinary command or
  # interactive prompt starts, later words are its arguments and must retain
  # their normal meaning (for example, `qdex exec app-server`).
  while (( arg_index < ${#codex_args[@]} )); do
    arg="${codex_args[$arg_index]}"
    case "$arg" in
      --)
        return
        ;;
      app-server|remote-control)
        printf 'qdex: Codex app-server access is unavailable while Qwendex defers history and memory lifecycle controls.\n' >&2
        exit 2
        ;;
      -c|--config|--enable|--disable|--remote|--remote-auth-token-env|-i|--image|-m|--model|-p|--profile|-s|--sandbox|-C|--cd|--add-dir|-a|--ask-for-approval)
        arg_index=$((arg_index + 2))
        continue
        ;;
      --config=*|--enable=*|--disable=*|--remote=*|--remote-auth-token-env=*|--image=*|--model=*|--profile=*|--sandbox=*|--cd=*|--add-dir=*|--ask-for-approval=*)
        arg_index=$((arg_index + 1))
        continue
        ;;
      -*)
        arg_index=$((arg_index + 1))
        continue
        ;;
      *)
        return
        ;;
    esac
  done
}

# Metadata/help calls are Codex CLI inspection, not agent sessions. Keep them
# byte-for-byte compatible and free of Qwendex policy checks, status writes, or
# manager ledger mutations.
informational_only=0
if [[ "${codex_args[0]:-}" == "help" ]]; then
  informational_only=1
fi
for arg in "${codex_args[@]}"; do
  case "$arg" in
    -h|--help|-V|--version)
      informational_only=1
      break
      ;;
  esac
done
if [[ "$informational_only" != "1" ]]; then
  reject_deferred_codex_controls
  reject_deferred_app_server_command
fi
permission_resolution="$(resolve_qdex_permission_mode "$cli_permission_mode")" || exit $?
mapfile -t permission_fields <<< "$permission_resolution"
permission_mode="${permission_fields[0]:-}"
permission_source="${permission_fields[1]:-}"
if [[ -z "$permission_mode" || -z "$permission_source" ]]; then
  printf 'qdex: permission-mode resolution returned incomplete data\n' >&2
  exit 2
fi
export QWENDEX_QDEX_PERMISSION_MODE="$permission_mode"
export QWENDEX_QDEX_PERMISSION_SOURCE="$permission_source"

# Codex V2 derives its built-in proactive multi-agent mode from Ultra
# reasoning only when no custom multi_agent_mode_hint_text is configured.
# Detect an explicit per-launch reasoning override so Qwendex can preserve
# native Ultra while retaining its own lane limits, ledger, and child policy.
codex_reasoning_effort=""
for ((arg_index = 0; arg_index < ${#codex_args[@]}; arg_index++)); do
  config_override=""
  case "${codex_args[$arg_index]}" in
    -c|--config)
      if (( arg_index + 1 < ${#codex_args[@]} )); then
        config_override="${codex_args[$((arg_index + 1))]}"
      fi
      ;;
    --config=*)
      config_override="${codex_args[$arg_index]#--config=}"
      ;;
  esac
  if [[ -n "$config_override" && "$config_override" == *=* ]]; then
    config_key="${config_override%%=*}"
    config_key="${config_key//[[:space:]]/}"
    if [[ "$config_key" == "model_reasoning_effort" ]]; then
      config_value="${config_override#*=}"
      config_value="${config_value//[[:space:]]/}"
      config_value="${config_value//\"/}"
      config_value="${config_value//\'/}"
      codex_reasoning_effort="${config_value,,}"
    fi
  fi
done
if [[ "$codex_reasoning_effort" == "ultra" ]]; then
  export QWENDEX_NATIVE_PROACTIVE_SOURCE="native_ultra"
fi

if [[ -z "$target_repo" ]]; then
  target_repo="$PWD"
fi

target_repo="$(cd "$target_repo" && pwd)"

reject_deferred_project_role_controls() {
  local project_root="$1"
  # The 0.145 role loader discovers roles in every trusted project config
  # layer, including a plain .codex/agents directory with no matching table in
  # config.toml. Qdex deliberately has no native-role lifecycle contract, so
  # reject those project-local surfaces before a Qwendex launch can trust them.
  # Only the generic reason is emitted: do not copy repository paths or config
  # contents into terminal output, launch metadata, or receipts.
  if ! python3 - "$project_root" <<'PY'
import subprocess
import sys
import tomllib
from pathlib import Path


target = Path(sys.argv[1]).resolve()
try:
    git_root = subprocess.run(
        ["git", "-C", str(target), "rev-parse", "--show-toplevel"],
        check=True,
        capture_output=True,
        text=True,
        timeout=5,
    ).stdout.strip()
    root = Path(git_root).resolve()
    target.relative_to(root)
except (OSError, subprocess.SubprocessError, ValueError):
    root = target

current = target
while True:
    dot_codex = current / ".codex"
    config_path = dot_codex / "config.toml"
    if config_path.is_file():
        try:
            config = tomllib.loads(config_path.read_text(encoding="utf-8"))
        except (OSError, UnicodeDecodeError, tomllib.TOMLDecodeError):
            # A malformed trusted project config is rejected later by Codex;
            # it cannot contribute a parsed native role declaration here.
            config = {}
        if isinstance(config, dict) and "agents" in config:
            raise SystemExit(1)
    if (dot_codex / "agents").is_dir():
        raise SystemExit(1)
    if current == root:
        break
    parent = current.parent
    if parent == current:
        break
    current = parent
PY
  then
    printf 'qdex: project-native Codex role configuration is unavailable while Qwendex defers role lifecycle controls.\n' >&2
    exit 2
  fi
}
target_repo_toml="$(python3 - "$target_repo" <<'PY'
import json
import sys

print(json.dumps(sys.argv[1]))
PY
)"
export QWENDEX_MANAGER_TARGET_REPO="$target_repo"
export QWENDEX_EXEC_CWD="$target_repo"
# Runtime generations seal their source tree read-only. Keep mutable Manager
# lifecycle artifacts in the writable operator root while hooks and code stay
# pinned to the immutable generation selected for this process.
export QWENDEX_AGENT_ARTIFACT_ROOT="$QWENDEX_DEV_ROOT/.qwendex"
export QWENDEX_MCP_TRUSTED_ROOTS="$target_repo"
export LOCAL_QWEN_CODEX_CWD="$target_repo"
export LOCAL_QWEN_CODEX_ADD_DIRS="$target_repo"
export LOCAL_QWEN_LOCAL_HARNESS_TRUSTED_ROOTS="$target_repo"
export ARTIFACT_QUEUE_MCP_TRUSTED_ROOTS="$target_repo"

if [[ ! -x "$QWENDEX_CODEX_RUNTIME" ]]; then
  printf 'qdex: missing Qwendex internal Codex runtime: %s\n' "$QWENDEX_CODEX_RUNTIME" >&2
  printf 'qdex: run qwendex-dev doctor from a shell that has sourced %s.\n' "$QWENDEX_ENV" >&2
  exit 127
fi

if [[ "$informational_only" == "1" ]]; then
  if [[ "$codex_sets_cwd" == "1" ]]; then
    cd "$caller_cwd"
  else
    cd "$target_repo"
  fi
  exec "$QWENDEX_CODEX_RUNTIME" "${codex_args[@]}"
fi

reject_deferred_project_role_controls "$target_repo"

# A run id is an opaque per-launch correlation value. Performance hooks HMAC it
# locally before persistence; never create it for help/version inspection.
export QWENDEX_RUN_ID="$(python3 - <<'PY'
import uuid

print(uuid.uuid4().hex)
PY
)"
qdex_launch_meta_root="$QWENDEX_META_ROOT/qdex/$QWENDEX_RUN_ID"
mkdir -p "$qdex_launch_meta_root"
export QWENDEX_QDEX_LAUNCH_ID="$QWENDEX_RUN_ID"
export QWENDEX_MANAGER_SESSION_STATE_FILE="$qdex_launch_meta_root/manager_session_state.json"
export QWENDEX_CODEX_STATUS_FILE="$qdex_launch_meta_root/codex_status.json"
codex_status_write_file="$qdex_launch_meta_root/codex_status_write.json"
codex_status_fields_file="$qdex_launch_meta_root/codex_status_fields.txt"

codex_status_rc=0
"$QWENDEX_QWENDEX_COMMAND" codex-status \
  --write "$QWENDEX_CODEX_STATUS_FILE" \
  --json > "$codex_status_write_file" || codex_status_rc=$?

qwendex_status_fields=()
if [[ "$codex_status_rc" -eq 0 ]] && python3 - "$codex_status_write_file" > "$codex_status_fields_file" <<'PY'
import json
import sys
with open(sys.argv[1], encoding="utf-8") as handle:
    payload = json.load(handle)
data = payload.get("data", {})
print(data.get("agent_use", ""))
policy = data.get("agent_policy", {})
if not isinstance(policy, dict):
    policy = {}
print(policy.get("mode", ""))
print(policy.get("max_threads", ""))
print(policy.get("native_max_concurrent_threads", ""))
print(policy.get("wait_timeout_ms", ""))
print("1" if data.get("manager_preflight_required") else "0")
print(data.get("agent_policy_hash", policy.get("policy_hash", "")))
print("1" if data.get("local_enabled") else "0")
PY
then
  mapfile -t qwendex_status_fields < "$codex_status_fields_file"
else
  printf 'Qwendex Agent Manager status: advisory (continuing with safe delegation defaults)\n' >&2
fi
agent_use="${qwendex_status_fields[0]:-}"
agent_mode="${qwendex_status_fields[1]:-}"
agent_policy_max_threads="${qwendex_status_fields[2]:-}"
agent_policy_native_max_threads="${qwendex_status_fields[3]:-}"
agent_policy_wait_timeout_ms="${qwendex_status_fields[4]:-}"
manager_preflight_required="${qwendex_status_fields[5]:-0}"
agent_policy_hash="${qwendex_status_fields[6]:-}"
agent_policy_local_enabled="${qwendex_status_fields[7]:-0}"
export QWENDEX_QDEX_LAUNCH_POLICY_HASH="$agent_policy_hash"

if [[ -z "$agent_mode" ]]; then
  agent_mode="${agent_use,,}"
fi
agent_mode="${agent_mode// /_}"
agent_mode="${agent_mode%-mode}"
case "$agent_mode" in
  manager_mode)
    agent_mode="manager"
    ;;
  off|auto|lite|medium|heavy|manager)
    ;;
  *)
    agent_mode="auto"
    ;;
esac
export QWENDEX_QDEX_LAUNCH_MODE="$agent_mode"
export QWENDEX_QDEX_LAUNCH_AGENT_USE="$agent_use"
export QWENDEX_QDEX_LAUNCH_MAX_WORKERS="$agent_policy_max_threads"
export QWENDEX_QDEX_LAUNCH_LOCAL_ENABLED="$agent_policy_local_enabled"

# Codex's V2 cap counts the root thread, while AgentPolicy max_threads counts
# workers. Prefer the resolved native value, derive it from the worker cap when
# needed, and keep even a malformed status payload inside Qwendex's product
# ceiling (eight workers plus the root).
if [[ "$agent_policy_native_max_threads" =~ ^[0-9]+$ ]]; then
  codex_native_max_threads="$agent_policy_native_max_threads"
elif [[ "$agent_policy_max_threads" =~ ^[0-9]+$ ]]; then
  codex_native_max_threads="$((agent_policy_max_threads + 1))"
else
  case "$agent_mode" in
    off)
      codex_native_max_threads=1
      ;;
    lite)
      codex_native_max_threads=2
      ;;
    medium)
      codex_native_max_threads=3
      ;;
    heavy)
      codex_native_max_threads=4
      ;;
    manager)
      codex_native_max_threads=5
      ;;
    *)
      codex_native_max_threads=1
      ;;
  esac
fi
if (( codex_native_max_threads < 1 )); then
  codex_native_max_threads=1
elif (( codex_native_max_threads > QWENDEX_CODEX_MAX_CONCURRENT_THREADS )); then
  codex_native_max_threads="$QWENDEX_CODEX_MAX_CONCURRENT_THREADS"
fi
codex_worker_cap="$((codex_native_max_threads - 1))"

# Keep native collaboration waits inside the immutable AgentPolicy lifecycle
# budget. Codex otherwise permits one wait call to last up to an hour, which
# can strand a root after all receivers have already completed.
if [[ "$agent_policy_wait_timeout_ms" =~ ^[0-9]+$ ]]; then
  codex_wait_timeout_ms="$agent_policy_wait_timeout_ms"
else
  case "$agent_mode" in
    off)
      codex_wait_timeout_ms=0
      ;;
    lite|heavy)
      codex_wait_timeout_ms=90000
      ;;
    auto|medium)
      codex_wait_timeout_ms=120000
      ;;
    manager)
      codex_wait_timeout_ms=60000
      ;;
    *)
      codex_wait_timeout_ms=60000
      ;;
  esac
fi
if (( codex_wait_timeout_ms > QWENDEX_CODEX_MAX_WAIT_TIMEOUT_MS )); then
  codex_wait_timeout_ms="$QWENDEX_CODEX_MAX_WAIT_TIMEOUT_MS"
fi
if (( codex_wait_timeout_ms == 0 )); then
  codex_wait_min_timeout_ms=0
  codex_wait_default_timeout_ms=0
else
  if (( codex_wait_timeout_ms < 10000 )); then
    codex_wait_timeout_ms=10000
  fi
  codex_wait_min_timeout_ms=10000
  codex_wait_default_timeout_ms=30000
  if (( codex_wait_default_timeout_ms > codex_wait_timeout_ms )); then
    codex_wait_default_timeout_ms="$codex_wait_timeout_ms"
  fi
fi

case "$agent_mode" in
  auto)
    multi_agent_mode_hint="Qwendex Auto delegation is active independently of reasoning effort. Use task complexity, independence, and your judgment to delegate bounded exploration, research, or verification when it saves root context or user tokens. Stay direct for small or tightly coupled tasks, and use no more than ${codex_worker_cap} workers."
    ;;
  medium)
    multi_agent_mode_hint="Qwendex Medium delegation is active independently of reasoning effort. Opportunistically delegate independent read-heavy mapping, focused investigation, or verification when it materially helps. Use no more than ${codex_worker_cap} bounded workers, keep direct work for small or tightly coupled tasks, and state the direct-work reason when useful."
    ;;
  heavy)
    multi_agent_mode_hint="Qwendex Heavy delegation is active independently of reasoning effort. Proactively delegate independent, purpose-specific lanes when they save context or improve quality. An explorer or verifier is often useful, but the user instruction and task needs decide the team. Use no more than ${codex_worker_cap} workers."
    ;;
  manager)
    multi_agent_mode_hint="Qwendex Manager delegation is active independently of reasoning effort. For complex tasks, use bounded independent workers when they save root context or tokens. Plans, lifecycle records, and verification are advisory aids and never override the user's instruction. Use no more than ${codex_worker_cap} workers."
    ;;
  lite)
    multi_agent_mode_hint="Qwendex Lite uses explicit-only delegation. Work directly unless the user, applicable AGENTS.md instructions, or an active skill explicitly requires a bounded worker. Never create a proactive worker team."
    ;;
  *)
    multi_agent_mode_hint="Qwendex ${agent_use:-Off} uses explicit-only delegation. Do not proactively spawn workers; delegate only when the user, applicable AGENTS.md instructions, or an active skill explicitly requires it."
    ;;
esac

root_agent_usage_hint="You are the root Qwendex orchestrator operating under the ${agent_use:-Off} AgentPolicy. Keep the root as the default sole writer and integrator. Delegate independent, purpose-specific lanes within the ${codex_worker_cap}-worker ceiling when doing so saves context or improves quality, then integrate their results. Qwendex plans and lifecycle records are advisory; follow the user's instruction and your task judgment. Do not ask workers to delegate recursively. Call wait_agent only while list_agents shows a running worker. After a wait timeout, inspect list_agents once; if no worker is running, integrate available evidence or finalize. If verifier evidence becomes stale after a root edit, consider a bounded follow-up to that verifier when it would be useful."
subagent_usage_hint="You are a bounded Qwendex worker. Execute the assigned lane, do not spawn or manage subagents, and respect any explicitly read-only scope. Return a concise outcome with evidence, changed paths, validation, blockers, and remaining risk when available. A structured FINAL_REPORT is optional; ordinary clear output is accepted."

cmd=(
  "$QWENDEX_CODEX_RUNTIME"
  --no-alt-screen
)
codex_policy_args=(
  --config "suppress_unstable_features_warning=true"
  --config "features.memories=false"
  --config "features.external_agent_memory_import=false"
  --config "features.chronicle=false"
  --config "history.persistence=\"none\""
  --config "memories.disable_on_external_context=true"
  --config "memories.generate_memories=false"
  --config "memories.use_memories=false"
  --config "memories.dedicated_tools=false"
  --config "features.multi_agent_v2.enabled=true"
  --config "features.multi_agent_v2.max_concurrent_threads_per_session=$codex_native_max_threads"
  --config "features.multi_agent_v2.min_wait_timeout_ms=$codex_wait_min_timeout_ms"
  --config "features.multi_agent_v2.max_wait_timeout_ms=$codex_wait_timeout_ms"
  --config "features.multi_agent_v2.default_wait_timeout_ms=$codex_wait_default_timeout_ms"
  --config "features.multi_agent_v2.hide_spawn_agent_metadata=true"
  --config "features.multi_agent_v2.expose_spawn_agent_model_overrides=false"
  --config "features.multi_agent_v2.root_agent_usage_hint_text=$(toml_string "$root_agent_usage_hint")"
  --config "features.multi_agent_v2.subagent_usage_hint_text=$(toml_string "$subagent_usage_hint")"
)
if [[ "${QWENDEX_NATIVE_PROACTIVE_SOURCE:-}" != "native_ultra" ]]; then
  codex_policy_args+=(--config "features.multi_agent_v2.multi_agent_mode_hint_text=$(toml_string "$multi_agent_mode_hint")")
fi
if [[ "$permission_mode" == "yolo" ]]; then
  yolo_present=0
  for arg in "${codex_args[@]}"; do
    [[ "$arg" == "$QWENDEX_YOLO_FLAG" ]] && yolo_present=1
  done
  [[ "$yolo_present" == "1" ]] || cmd+=("$QWENDEX_YOLO_FLAG")
else
  cmd+=(--sandbox workspace-write)
fi
if [[ "$manager_preflight_required" == "1" ]]; then
  # Manager preflight verifies the generated Qwendex hook set before launch;
  # tell Codex not to stop at a second interactive trust dialog.
  hook_trust_present=0
  for arg in "${codex_args[@]}"; do
    [[ "$arg" == "$QWENDEX_HOOK_TRUST_FLAG" ]] && hook_trust_present=1
  done
  [[ "$hook_trust_present" == "1" ]] || cmd+=("$QWENDEX_HOOK_TRUST_FLAG")
fi
codex_policy_args+=(--config "projects={$target_repo_toml={trust_level=\"trusted\"}}")
# Normal Qdex launches inherit the caller's working directory exactly like
# Codex. Keep the older Qdex-only --repo option as a compatibility alias that
# still needs an injected native -C; an operator-supplied -C/--cd is already in
# codex_args and must remain byte-for-byte pass-through.
if [[ "$codex_sets_cwd" == "0" && "$qdex_sets_repo" == "1" ]]; then
  cmd+=(-C "$target_repo")
fi

# Codex 0.144 treats a global `--config` group before `exec` as lower-precedence
# input and can discard that group when any `-c` appears after the subcommand.
# Append the immutable Qwendex policy after all caller options instead. When a
# caller uses the `--` option barrier, insert immediately before it so the
# remaining values keep their exact positional meaning. This also prevents a
# caller-local config flag from silently weakening the launch snapshot.
policy_insert_at="${#codex_args[@]}"
for ((arg_index = 0; arg_index < ${#codex_args[@]}; arg_index++)); do
  if [[ "${codex_args[$arg_index]}" == "--" ]]; then
    policy_insert_at="$arg_index"
    break
  fi
done
final_cmd=("${cmd[@]}")
if (( policy_insert_at > 0 )); then
  final_cmd+=("${codex_args[@]:0:policy_insert_at}")
fi
final_cmd+=("${codex_policy_args[@]}")
if (( policy_insert_at < ${#codex_args[@]} )); then
  final_cmd+=("${codex_args[@]:policy_insert_at}")
fi

preflight_file="$qdex_launch_meta_root/manager_preflight.json"

if [[ "$manager_preflight_required" == "1" ]]; then
  preflight_rc=0
  preflight_args=(manager preflight --interactive-prompt-unknown --json)
  if [[ "$manager_preflight_dry_run" == "1" ]]; then
    preflight_args+=(--dry-run)
  fi
  QWENDEX_MANAGER_TARGET_REPO="$target_repo" \
    "$QWENDEX_QWENDEX_COMMAND" "${preflight_args[@]}" > "$preflight_file" || preflight_rc=$?

  if [[ "$manager_preflight_dry_run" == "1" || "${QWENDEX_QDEX_DRY_RUN:-0}" == "1" ]]; then
    if [[ "$json_output" == "1" ]]; then
    python3 - "$preflight_file" "$target_repo" "${final_cmd[@]}" <<'PY'
import json
import sys
preflight_path = sys.argv[1]
target_repo = sys.argv[2]
command = sys.argv[3:]
with open(preflight_path, encoding="utf-8") as handle:
    preflight = json.load(handle)
print(json.dumps({
    "schema_version": "qwendex.qdex.dry_run.v1",
    "target_repo": target_repo,
    "manager_target_repo": target_repo,
    "codex_home": __import__("os").environ.get("CODEX_HOME", ""),
    "internal_runtime": __import__("os").environ.get("QWENDEX_CODEX_RUNTIME", ""),
    "permission_mode": __import__("os").environ.get("QWENDEX_QDEX_PERMISSION_MODE", "workspace-write"),
    "qdex_permission_mode": __import__("os").environ.get("QWENDEX_QDEX_PERMISSION_MODE", "workspace-write"),
    "qdex_permission_source": __import__("os").environ.get("QWENDEX_QDEX_PERMISSION_SOURCE", "default"),
    "selected_target": command[0] if command else "",
    "command": command,
    "manager_preflight": preflight,
}, indent=2, sort_keys=True))
PY
    else
      python3 - "$preflight_file" <<'PY'
import json
import sys
with open(sys.argv[1], encoding="utf-8") as handle:
    payload = json.load(handle)
data = payload.get("data", {})
route = data.get("routing_decision", {})
hook = data.get("hook_status", {})
print(f"Qwendex Manager preflight: {'ready' if data.get('ok') else 'advisory'}")
print(f"ledger: {data.get('ledger_id', '')}")
print(f"root: {data.get('root_agent_id', '')}")
print(f"route: {route.get('selected_route', '')}")
print(f"hooks: {'override' if hook.get('override') else 'verified' if hook.get('verified') else 'missing'}")
print(f"verifier: {'suggested' if route.get('verifier_suggested') else 'not_suggested'}")
print(f"stop: {data.get('stop_status', '')}")
PY
    fi
    exit 0
  fi

  if ! python3 - "$preflight_file" "$agent_policy_hash" <<'PY'
import json
import sys
with open(sys.argv[1], encoding="utf-8") as handle:
    payload = json.load(handle)
data = payload.get("data", {})
exports = data.get("exports", {})
root_agent_id = str(exports.get("QWENDEX_MANAGER_ROOT_AGENT_ID") or "").strip()
status_policy_hash = str(sys.argv[2] or "").strip()
preflight_policy_hash = str(exports.get("QWENDEX_MANAGER_POLICY_HASH") or "").strip()
bound = bool(status_policy_hash and preflight_policy_hash == status_policy_hash)
sys.exit(0 if data.get("ok") and root_agent_id and bound else 1)
PY
  then
    if [[ "$preflight_rc" -eq 0 ]]; then
      preflight_rc=1
    fi
    python3 - "$preflight_file" "$agent_policy_hash" >&2 <<'PY' || true
import json
import sys
with open(sys.argv[1], encoding="utf-8") as handle:
    payload = json.load(handle)
data = payload.get("data", {})
hook = data.get("hook_status", {})
print("Qwendex Manager preflight: advisory")
exports = data.get("exports", {})
root_agent_id = str(exports.get("QWENDEX_MANAGER_ROOT_AGENT_ID") or "").strip()
reason = data.get('routing_decision', {}).get('routing_reason', '')
if data.get("ok") and not root_agent_id:
    reason = "manager preflight did not establish a trusted root identity"
status_policy_hash = str(sys.argv[2] or "").strip()
preflight_policy_hash = str(exports.get("QWENDEX_MANAGER_POLICY_HASH") or "").strip()
if data.get("ok") and root_agent_id and (
    not status_policy_hash or preflight_policy_hash != status_policy_hash
):
    reason = "manager preflight policy hash does not match the qdex launch policy"
print(f"reason: {reason}")
print(f"install: {hook.get('install_command', '')}")
print(f"verify: {hook.get('verify_command', '')}")
print(f"continuing without Manager bookkeeping; stop: {data.get('stop_status', '')}")
PY
  else
    eval "$(python3 - "$preflight_file" <<'PY'
import json
import shlex
import sys
with open(sys.argv[1], encoding="utf-8") as handle:
    payload = json.load(handle)
exports = payload.get("data", {}).get("exports", {})
for key, value in exports.items():
    print(f"export {key}={shlex.quote(str(value))}")
PY
)"

  python3 - "$preflight_file" >&2 <<'PY'
import json
import sys
with open(sys.argv[1], encoding="utf-8") as handle:
    payload = json.load(handle)
data = payload.get("data", {})
route = data.get("routing_decision", {})
hook = data.get("hook_status", {})
print("Qwendex Manager preflight: ready")
print(f"ledger: {data.get('ledger_id', '')}")
print(f"root: {data.get('root_agent_id', '')}")
print(f"route: {route.get('selected_route', '')}")
print(f"hooks: {'override' if hook.get('override') else 'verified' if hook.get('verified') else 'missing'}")
print(f"verifier: {'suggested' if route.get('verifier_suggested') else 'not_suggested'}")
PY
  fi
elif [[ "$manager_preflight_dry_run" == "1" || "${QWENDEX_QDEX_DRY_RUN:-0}" == "1" ]]; then
  if [[ "$json_output" == "1" ]]; then
    python3 - "$codex_status_write_file" "$target_repo" "${final_cmd[@]}" <<'PY'
import json
import sys
status_path = sys.argv[1]
target_repo = sys.argv[2]
command = sys.argv[3:]
with open(status_path, encoding="utf-8") as handle:
    codex_status = json.load(handle)
print(json.dumps({
    "schema_version": "qwendex.qdex.dry_run.v1",
    "target_repo": target_repo,
    "manager_target_repo": target_repo,
    "codex_home": __import__("os").environ.get("CODEX_HOME", ""),
    "internal_runtime": __import__("os").environ.get("QWENDEX_CODEX_RUNTIME", ""),
    "permission_mode": __import__("os").environ.get("QWENDEX_QDEX_PERMISSION_MODE", "workspace-write"),
    "qdex_permission_mode": __import__("os").environ.get("QWENDEX_QDEX_PERMISSION_MODE", "workspace-write"),
    "qdex_permission_source": __import__("os").environ.get("QWENDEX_QDEX_PERMISSION_SOURCE", "default"),
    "selected_target": command[0] if command else "",
    "command": command,
    "manager_preflight": {"skipped": True, "reason": "manager preflight is not required by selected or effective mode"},
    "codex_status": codex_status,
}, indent=2, sort_keys=True))
PY
  else
    printf 'QWENDEX_DEV_ROOT=%s\n' "$QWENDEX_DEV_ROOT"
    printf 'CODEX_HOME=%s\n' "$CODEX_HOME"
    printf 'QWENDEX_CODEX_STATUS_FILE=%s\n' "$QWENDEX_CODEX_STATUS_FILE"
    printf 'target_repo=%s\n' "$target_repo"
    printf 'command:'
    printf ' %q' "${final_cmd[@]}"
    printf '\n'
  fi
  exit 0
fi

if [[ "$codex_sets_cwd" == "1" ]]; then
  cd "$caller_cwd"
else
  cd "$target_repo"
fi
exec "${final_cmd[@]}"
