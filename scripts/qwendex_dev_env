#!/usr/bin/env bash
set -euo pipefail

SCRIPT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"
if [[ -f "$SCRIPT_ROOT/.qwendex-dev/source-root" ]]; then
  DEFAULT_SOURCE_ROOT="$(<"$SCRIPT_ROOT/.qwendex-dev/source-root")"
else
  DEFAULT_SOURCE_ROOT="$SCRIPT_ROOT"
fi

SOURCE_ROOT="${QWENDEX_DEV_SOURCE_ROOT:-$DEFAULT_SOURCE_ROOT}"
DEV_ROOT="${QWENDEX_DEV_ROOT:-$HOME/qwendex-dev}"
WORK_ROOT="$DEV_ROOT/.qwendex-dev"
STATE_DB="$WORK_ROOT/state/qwendex.sqlite"
PERFORMANCE_DB="$WORK_ROOT/state/qwendex-performance.sqlite"
RESULTS_ROOT="$WORK_ROOT/results/qwendex"
META_ROOT="$WORK_ROOT/results/meta"
CODEX_HOME_DIR="$WORK_ROOT/codex_home"
QWENDEX_CODEX_RUNTIME="$WORK_ROOT/bin/qwendex-codex-runtime"
QWENDEX_RUNTIME_ROOT="$WORK_ROOT/runtime"
QWENDEX_RUNTIME_RECOVERY="$WORK_ROOT/bin/qwendex-runtime-recovery"
STATUS_FILE="$WORK_ROOT/codex_status.json"
LEDGER_DB="$WORK_ROOT/state/qwendex_ledger.sqlite"
LOCAL_HARNESS_LEDGER_DB="$WORK_ROOT/state/local_qwen_harness.sqlite"
BOOTSTRAP_JSON="$META_ROOT/bootstrap.json"
INSTALL_DEPS_JSON="$META_ROOT/install_deps.json"
DEV_STATUS_JSON="$META_ROOT/dev_status.json"
RELEASE_SUMMARY_JSON="$META_ROOT/release_validation_summary.json"
DEV_CODEX_DEFAULT="$WORK_ROOT/codex-build/bin/codex"
DEV_CODE_MODE_HOST_DEFAULT="$WORK_ROOT/codex-build/bin/codex-code-mode-host"
CODEX_SOURCE_DIR="$WORK_ROOT/codex-source/codex"
QWENDEX_CODEX_YOLO_FLAG="--dangerously-bypass-approvals-and-sandbox"
QWENDEX_RELEASE_CODEX_SOURCE_REPO="https://github.com/openai/codex.git"
QWENDEX_CODEX_SOURCE_REPO="${QWENDEX_CODEX_SOURCE_REPO:-$QWENDEX_RELEASE_CODEX_SOURCE_REPO}"
QWENDEX_RELEASE_CODEX_VERSION="0.144.0"
QWENDEX_RELEASE_CODEX_SOURCE_COMMIT="767822446c7a594caa19609ca435281a9ec67e0d"
QWENDEX_RELEASE_CODEX_PATCH_SHA256="3e370b67c71cc5ee4589112c78fe1dc88b672b4c0f018c5206b3de68f863683c"
QWENDEX_RELEASE_CODEX_CARGO_LOCK_SHA256="2a3f5a7bd2b571e94cf39e35180e88567989421893f2b600607026d7896ad9c6"
QWENDEX_CODEX_SOURCE_REF="${QWENDEX_CODEX_SOURCE_REF:-rust-v$QWENDEX_RELEASE_CODEX_VERSION}"
QWENDEX_MODELS_CACHE_FILE="models_cache.qwendex-$QWENDEX_RELEASE_CODEX_VERSION.json"

resolve_main_codex_bin() {
  local dev_wrapper=""
  if [[ -d "$DEV_ROOT/bin" ]]; then
    dev_wrapper="$(cd -P "$DEV_ROOT/bin" && pwd)/codex"
  fi
  if [[ -n "${QWENDEX_MAIN_CODEX_BIN:-}" ]]; then
    local configured_dir
    local configured_path
    configured_dir="$(cd -P "$(dirname "$QWENDEX_MAIN_CODEX_BIN")" 2>/dev/null && pwd || true)"
    configured_path="${configured_dir:+$configured_dir/$(basename "$QWENDEX_MAIN_CODEX_BIN")}"
    if [[ -z "$dev_wrapper" || "$configured_path" != "$dev_wrapper" ]]; then
      printf '%s\n' "$QWENDEX_MAIN_CODEX_BIN"
      return
    fi
  fi
  local candidate
  local candidate_dir
  local candidate_path
  while IFS= read -r candidate; do
    [[ -n "$candidate" ]] || continue
    candidate_dir="$(cd -P "$(dirname "$candidate")" && pwd)"
    candidate_path="$candidate_dir/$(basename "$candidate")"
    if [[ -z "$dev_wrapper" || "$candidate_path" != "$dev_wrapper" ]]; then
      printf '%s\n' "$candidate_path"
      return
    fi
  done < <(type -aP codex 2>/dev/null || true)
}

MAIN_CODEX_BIN="$(resolve_main_codex_bin)"
MANAGED_RSYNC_EXCLUDES=(
  --exclude '.git'
  --exclude '.git/'
  --exclude '.pytest_cache/'
  --exclude '.ruff_cache/'
  --exclude '.qwendex-dev/'
  --exclude 'results/'
  --exclude 'state/'
  --exclude '__pycache__/'
  --exclude '*.pyc'
  --exclude '/bin/'
  --exclude '/open.ps1'
)
MANAGED_GIT_PATHS=(
  .gitignore
  AGENTS.md
  QWENDEX_STARTUP.md
  README.md
  RELEASE.md
  .codex
  llmstack
  config
  docs
  public
  scripts
  tests
)

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

shell_quote() {
  printf '%q' "$1"
}

toml_quote() {
  python3 - "$1" <<'PY'
import json
import sys

print(json.dumps(sys.argv[1], ensure_ascii=False))
PY
}

guard_dev_root() {
  [[ -n "$DEV_ROOT" ]] || die "QWENDEX_DEV_ROOT resolved to an empty path"
  [[ "$DEV_ROOT" != "/" ]] || die "refusing to use / as QWENDEX_DEV_ROOT"
  [[ "$DEV_ROOT" != "$HOME" ]] || die "refusing to use HOME as QWENDEX_DEV_ROOT"
}

ensure_layout() {
  guard_dev_root
  mkdir -p "$WORK_ROOT/state" "$WORK_ROOT/bin" "$RESULTS_ROOT" "$META_ROOT" "$CODEX_HOME_DIR/logs"
  mkdir -p "$WORK_ROOT/codex-source" "$WORK_ROOT/codex-build/bin" "$DEV_ROOT/bin"
}

sync_project() {
  guard_dev_root
  [[ -d "$SOURCE_ROOT" ]] || die "source root does not exist: $SOURCE_ROOT"
  if [[ "$(cd "$SOURCE_ROOT" && pwd)" == "$(mkdir -p "$DEV_ROOT" && cd "$DEV_ROOT" && pwd)" ]]; then
    die "source root and dev root are the same; set QWENDEX_DEV_SOURCE_ROOT to the tracked repo"
  fi
  rsync -a --delete \
    --omit-dir-times \
    "${MANAGED_RSYNC_EXCLUDES[@]}" \
    "$SOURCE_ROOT/" "$DEV_ROOT/"
}

source_is_git_repo() {
  git -C "$SOURCE_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

dev_is_git_repo() {
  git -C "$DEV_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

utc_stamp() {
  date -u +%Y%m%dT%H%M%SZ
}

write_codex_config() {
  local dev_root_toml
  local source_root_toml
  dev_root_toml="$(toml_quote "$DEV_ROOT")"
  source_root_toml="$(toml_quote "$SOURCE_ROOT")"
  cat > "$CODEX_HOME_DIR/config.toml" <<EOF
model = "gpt-5.6-terra"
model_reasoning_effort = "max"
approval_policy = "never"
sandbox_mode = "workspace-write"
persistent_instructions = "Qwendex dev environment active. Act as the senior Qwendex product maintainer: keep changes scoped, verify before staging, use qwendex-dev doctor/verify/review/stage, protect public/private boundaries, and keep generated .qwendex-dev state out of public artifacts. QWENDEX_ROOT, QWENDEX_STATE_DB, QWENDEX_PERFORMANCE_DB, QWENDEX_LEDGER_DB, QWENDEX_RESULTS_ROOT, QWENDEX_CODEX_STATUS_FILE, and QWENDEX_DEV_ROOT are set by the launcher. Use qwendex, qwendex-dev, and llmstack for harness controls. After context compaction, resume from the newest user request, re-run the Qwendex posture checks, and inspect existing diffs/state before editing; use qwendex-dev snapshot and scripts/qwendex context snapshot/reminder/compact-plan at phase boundaries or before manual compaction so the next session has objective, decisions, evidence, open files, blockers, and next actions. At the start of substantial tasks, check Agent Manager/Kaveman/Local state. When Agent Manager is in Manager Mode, use manager planning/preflight first. Spawn bounded subagents only when current tool policy, task shape, and write-surface separation make delegation safe; keep critical-path implementation local, avoid duplicate/conflicting writes, treat subagent output as advisory until integrated and verified, and close spawned agents and matching Qwendex manager sessions after integration. If subagents are not used, record or state the direct-work reason and validation path. When QWENDEX_CODEX_STATUS_FILE reports kaveman_enabled true, keep output terse and direct."

[features]
multi_agent = true

[features.multi_agent_v2]
enabled = true
max_concurrent_threads_per_session = 1
multi_agent_mode_hint_text = "Qwendex uses explicit-only delegation until Qdex applies the immutable launch AgentPolicy. Do not proactively spawn workers; delegate only when the user, applicable AGENTS.md instructions, or an active skill explicitly requires it."
root_agent_usage_hint_text = "You are the root Qwendex orchestrator. Keep the root as the default sole writer and integrator, delegate only bounded independent lanes authorized by the active AgentPolicy, and do not ask workers to delegate recursively."
subagent_usage_hint_text = "You are a bounded Qwendex worker. Execute only the assigned lane, do not spawn or manage subagents, and return a concise FINAL_REPORT with evidence, validation, and blockers."

[projects.$dev_root_toml]
trust_level = "trusted"
EOF

  if [[ "$(cd -P "$SOURCE_ROOT" && pwd)" != "$(cd -P "$DEV_ROOT" && pwd)" ]]; then
    cat >> "$CODEX_HOME_DIR/config.toml" <<EOF

[projects.$source_root_toml]
trust_level = "trusted"
EOF
  fi

  if [[ -x "$DEV_CODEX_DEFAULT" || -n "${QWENDEX_DEV_CODEX_BIN:-}" ]]; then
    cat >> "$CODEX_HOME_DIR/config.toml" <<'EOF'

[tui]
status_line = ["model-with-reasoning", "current-dir", "qwendex-manager"]
EOF
    if [[ "${QWENDEX_DEV_ENABLE_PATCHED_TUI_CONFIG:-0}" == "1" ]]; then
      cat >> "$CODEX_HOME_DIR/config.toml" <<'EOF'

[tui.keymap.global]
qwendex_toggle_manager = "alt-m"
qwendex_toggle_kaveman = "alt-k"
qwendex_toggle_local = "alt-l"
EOF
    fi
  fi

  cat > "$CODEX_HOME_DIR/patched-tui.example.toml" <<'EOF'
# Copy these sections into config.toml only after running a patched Codex build.
#
# [tui]
# status_line = ["model-with-reasoning", "current-dir", "qwendex-manager"]
#
# [tui.keymap.global]
# qwendex_toggle_manager = "alt-m"
# qwendex_toggle_kaveman = "alt-k"
# qwendex_toggle_local = "alt-l"
EOF
}

write_wrappers() {
  local dev_root_shell
  local source_root_shell
  local main_codex_shell
  local dev_codex_default_shell
  dev_root_shell="$(shell_quote "$DEV_ROOT")"
  source_root_shell="$(shell_quote "$SOURCE_ROOT")"
  main_codex_shell="$(shell_quote "$MAIN_CODEX_BIN")"
  dev_codex_default_shell="$(shell_quote "$DEV_CODEX_DEFAULT")"
  cat > "$DEV_ROOT/bin/qwendex" <<EOF
#!/usr/bin/env bash
dev_root=$dev_root_shell
exec "\$dev_root/scripts/qwendex" "\$@"
EOF
  cat > "$DEV_ROOT/bin/llmstack" <<EOF
#!/usr/bin/env bash
dev_root=$dev_root_shell
exec "\$dev_root/llmstack" "\$@"
EOF
  cat > "$DEV_ROOT/bin/qwendex-dev" <<EOF
#!/usr/bin/env bash
dev_root=$dev_root_shell
export QWENDEX_DEV_SOURCE_ROOT=$source_root_shell
export QWENDEX_MAIN_CODEX_BIN=$main_codex_shell
exec "\$dev_root/scripts/qwendex_dev_env" "\$@"
EOF
  cat > "$DEV_ROOT/bin/codex-main" <<EOF
#!/usr/bin/env bash
main_codex=$main_codex_shell
if [[ ! -x "\$main_codex" ]]; then
  printf 'main Codex fallback is not executable: %s\n' "\$main_codex" >&2
  exit 127
fi
exec "\$main_codex" "\$@"
EOF
  local legacy_codex="$DEV_ROOT/bin/codex"
  if [[ -e "$legacy_codex" ]]; then
    if grep -qE 'QWENDEX-GENERATED-CODEX-WRAPPER|dev_codex_default=.*codex-build/bin/codex' "$legacy_codex" 2>/dev/null; then
      rm -f "$legacy_codex"
    else
      die "refusing to replace unknown file at deprecated Qwendex wrapper path: $legacy_codex"
    fi
  fi
  cat > "$QWENDEX_CODEX_RUNTIME" <<EOF
#!/usr/bin/env bash
# QWENDEX-GENERATED-CODEX-RUNTIME-V1
dev_codex_default=$dev_codex_default_shell
main_codex=$main_codex_shell
dev_codex="\${QWENDEX_DEV_CODEX_BIN:-\$dev_codex_default}"
if [[ -x "\$dev_codex" ]]; then
  code_mode_host="\$(dirname "\$dev_codex")/codex-code-mode-host"
  if [[ ! -x "\$code_mode_host" ]]; then
    printf 'Codex code-mode host is missing or not executable: %s\n' "\$code_mode_host" >&2
    printf 'Rebuild with: qwendex-dev codex-source build\n' >&2
    exit 127
  fi
  exec "\$dev_codex" "\$@"
fi
printf 'Qwendex internal runtime: patched build unavailable; using the configured upstream Codex fallback.\n' >&2
if [[ ! -x "\$main_codex" ]]; then
  printf 'no dev Codex binary found and main fallback is not executable: %s\n' "\$main_codex" >&2
  exit 127
fi
exec "\$main_codex" "\$@"
EOF
  if [[ -f "$DEV_ROOT/scripts/qdex" ]]; then
    mkdir -p "$HOME/.local/bin"
    install -m 0755 "$DEV_ROOT/scripts/qdex" "$HOME/.local/bin/qdex"
  fi
  cat > "$DEV_ROOT/open.ps1" <<'EOF'
[CmdletBinding()]
param(
    [Parameter(Position = 0, ValueFromRemainingArguments = $true)]
    [string[]]$Args = @()
)

$ErrorActionPreference = "Stop"
$script = Join-Path $PSScriptRoot "scripts/windows/open.ps1"
& $script -RepoDir $PSScriptRoot @Args
EOF
  chmod +x "$DEV_ROOT/bin/qwendex" "$DEV_ROOT/bin/llmstack" "$DEV_ROOT/bin/qwendex-dev" "$DEV_ROOT/bin/codex-main" "$QWENDEX_CODEX_RUNTIME"
}

write_env_files() {
  printf '%s\n' "$SOURCE_ROOT" > "$WORK_ROOT/source-root"
  {
    printf 'export QWENDEX_DEV_ROOT=%q\n' "$DEV_ROOT"
    printf 'export QWENDEX_DEV_SOURCE_ROOT=%q\n' "$SOURCE_ROOT"
    printf 'export QWENDEX_MAIN_CODEX_BIN=%q\n' "$MAIN_CODEX_BIN"
    printf 'export QWENDEX_ROOT=%q\n' "$DEV_ROOT"
    printf 'export QWENDEX_STATE_DB=%q\n' "$STATE_DB"
    printf 'export QWENDEX_PERFORMANCE_DB=%q\n' "$PERFORMANCE_DB"
    printf 'export QWENDEX_LEDGER_DB=%q\n' "$LEDGER_DB"
    printf 'export QWENDEX_RESULTS_ROOT=%q\n' "$RESULTS_ROOT"
    printf 'export QWENDEX_META_ROOT=%q\n' "$META_ROOT"
    printf 'export QWENDEX_CODEX_STATUS_FILE=%q\n' "$STATUS_FILE"
    printf 'export QWENDEX_MODELS_CACHE_FILE=%q\n' "$QWENDEX_MODELS_CACHE_FILE"
    printf 'export QWENDEX_EXEC_CWD=%q\n' "$DEV_ROOT"
    printf 'export QWENDEX_MCP_TRUSTED_ROOTS=%q\n' "$DEV_ROOT:$SOURCE_ROOT"
    printf 'export QWENDEX_CODEX_HOME=%q\n' "$CODEX_HOME_DIR"
    printf 'export QWENDEX_CODEX_RUNTIME=%q\n' "$QWENDEX_CODEX_RUNTIME"
    printf 'export QWENDEX_RUNTIME_ROOT=%q\n' "$QWENDEX_RUNTIME_ROOT"
    # A source-only bootstrap remains usable for non-production development.
    # Once a validated selector exists, the dynamic block below makes the
    # generation boundary mandatory for every new Qdex process.
    printf 'export QWENDEX_RUNTIME_GENERATION_REQUIRED=0\n'
    printf 'export LOCAL_QWEN_CODEX_CWD=%q\n' "$DEV_ROOT"
    printf 'export LOCAL_QWEN_CODEX_ADD_DIRS=%q\n' "$DEV_ROOT:$SOURCE_ROOT"
    printf 'export LOCAL_QWEN_CANONICAL_LAUNCHER=%q\n' "$DEV_ROOT/scripts/run_local_qwen_codex.sh"
    printf 'export LOCAL_QWEN_MODEL_CATALOG_JSON=%q\n' "$DEV_ROOT/config/local_llm_stack/qwen_local_model_catalog.json"
    printf 'export LOCAL_QWEN_LOCAL_HARNESS_MCP=%q\n' "$DEV_ROOT/scripts/artifact_queue_mcp.py"
    printf 'export LOCAL_QWEN_LOCAL_HARNESS_TRUSTED_ROOTS=%q\n' "$DEV_ROOT:$SOURCE_ROOT"
    printf 'export LOCAL_QWEN_HARNESS_LEDGER_DB=%q\n' "$LOCAL_HARNESS_LEDGER_DB"
    printf 'export PATH=%q:%q:%q:%q:%q:$PATH\n' \
      "$DEV_ROOT/bin" "$HOME/.local/bin" "$HOME/.cargo/bin" "$DEV_ROOT" "$DEV_ROOT/scripts"
    cat <<'EOF'
if [[ -f "$QWENDEX_RUNTIME_ROOT/current.json" ]]; then
  eval "$(python3 - "$QWENDEX_RUNTIME_ROOT/current.json" "$QWENDEX_RUNTIME_ROOT" <<'PY'
import json
import shlex
import sys
from pathlib import Path

selection = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
runtime_root = Path(sys.argv[2]).resolve()
generation_id = str(selection.get("current") or "")
generation = (runtime_root / "generations" / generation_id).resolve()
generation.relative_to((runtime_root / "generations").resolve())
manifest = json.loads((generation / "generation.json").read_text(encoding="utf-8"))
if (
    manifest.get("schema_version") != "qwendex.runtime_generation.v1"
    or manifest.get("generation_id") != generation_id
    or manifest.get("status") != "validated"
):
    raise SystemExit(0)
values = {
    "QWENDEX_RUNTIME_GENERATION_ID": generation_id,
    "QWENDEX_RUNTIME_GENERATION_DIR": str(generation),
    "QWENDEX_RUNTIME_TREE": str(generation / "tree"),
    "QWENDEX_RUNTIME_CONTRACT_SHA256": str(manifest.get("contract_sha256") or ""),
    "QWENDEX_HOOK_GENERATION": generation_id,
    "QWENDEX_CODEX_HOME": str(generation / "codex_home"),
    "QWENDEX_CODEX_RUNTIME": str(generation / "bin" / "codex-runtime"),
    "QWENDEX_ROOT": str(generation / "tree"),
    "QWENDEX_RUNTIME_GENERATION_REQUIRED": "1",
}
for key, value in values.items():
    print(f"export {key}={shlex.quote(value)}")
PY
)"
fi
EOF
  } > "$WORK_ROOT/env.sh"
  cat > "$WORK_ROOT/README.md" <<EOF
# Qwendex Dev Environment

This folder is generated by \`scripts/qwendex_dev_env\`.

- Dev root: \`$DEV_ROOT\`
- Source root: \`$SOURCE_ROOT\`
- State DB: \`$STATE_DB\`
- Performance DB: \`$PERFORMANCE_DB\`
- Receipt ledger: \`$LEDGER_DB\`
- Local harness ledger: \`$LOCAL_HARNESS_LEDGER_DB\`
- Results: \`$RESULTS_ROOT\`
- Codex home: \`$CODEX_HOME_DIR\`
- Status file: \`$STATUS_FILE\`
- Main Codex fallback: \`$MAIN_CODEX_BIN\`

Use:

\`\`\`bash
source "$WORK_ROOT/env.sh"
qwendex-dev
qwendex-dev open
\`\`\`

Bare \`qwendex-dev\` opens Codex in \`$DEV_ROOT\` with the current Codex
yolo-equivalent flag: \`$QWENDEX_CODEX_YOLO_FLAG\`.

Developer workflow:

\`\`\`bash
qwendex-dev review
qwendex-dev verify --tier full
qwendex-dev diff
qwendex-dev stage
qwendex-dev snapshot
\`\`\`

The internal Qwendex runtime first uses \`QWENDEX_DEV_CODEX_BIN\` or
\`$DEV_CODEX_DEFAULT\` when present, then emits a boundary warning and falls
back to the main Codex binary. It is launched only through \`qdex\`; ordinary
\`codex\` remains the caller's upstream installation and normal Codex home.
EOF
}

link_codex_identity() {
  if [[ -d "$HOME/.codex/mcp-servers" && ! -e "$CODEX_HOME_DIR/mcp-servers" ]]; then
    ln -s "$HOME/.codex/mcp-servers" "$CODEX_HOME_DIR/mcp-servers"
  fi
  if [[ -f "$HOME/.codex/auth.json" && ! -e "$CODEX_HOME_DIR/auth.json" ]]; then
    ln -s "$HOME/.codex/auth.json" "$CODEX_HOME_DIR/auth.json"
  fi
  if [[ -L "$CODEX_HOME_DIR/version.json" ]]; then
    rm "$CODEX_HOME_DIR/version.json"
  fi
  if [[ -f "$HOME/.codex/version.json" && ! -e "$CODEX_HOME_DIR/version.json" ]]; then
    cp "$HOME/.codex/version.json" "$CODEX_HOME_DIR/version.json"
  fi
  if [[ -f "$HOME/.codex/installation_id" && ! -e "$CODEX_HOME_DIR/installation_id" ]]; then
    cp "$HOME/.codex/installation_id" "$CODEX_HOME_DIR/installation_id"
  fi
}

prepare() {
  ensure_layout
  write_codex_config
  write_wrappers
  write_env_files
  link_codex_identity
}

summary_json() {
  python3 - "$@" <<'PY'
import json
import sys
from pathlib import Path

for raw in sys.argv[1:]:
    path = Path(raw)
    if not path.is_file():
        print(f"{path}: missing")
        continue
    data = json.loads(path.read_text(encoding="utf-8"))
    print(f"{data.get('command', path.name)}: {data.get('status')} - {data.get('summary')}")
PY
}

run_logged_gate() {
  local receipt="$1"
  local gate_name="$2"
  local run_id="$3"
  shift 3
  local log_file="${receipt%.json}.log"
  local started_at
  started_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  mkdir -p "$(dirname "$receipt")"
  local rc=0
  local restore_errexit=0
  [[ "$-" == *e* ]] && restore_errexit=1
  set +e
  (
    # Gate functions contain multi-command validation sequences. Re-enable
    # fail-fast semantics inside an isolated subshell so an early failure
    # cannot be hidden by a later successful command while the caller captures
    # the pipeline status.
    set -e
    "$@"
  ) 2>&1 | tee "$log_file"
  rc="${PIPESTATUS[0]}"
  if [[ "$restore_errexit" -eq 1 ]]; then
    set -e
  fi
  python3 - "$receipt" "$gate_name" "$run_id" "$started_at" "$rc" "$log_file" "$@" <<'PY'
import hashlib
import json
import sys
from datetime import UTC, datetime
from pathlib import Path

receipt, gate_name, run_id, started_at, raw_rc, raw_log, *command = sys.argv[1:]
log = Path(raw_log)
log_bytes = log.read_bytes() if log.is_file() else b""
returncode = int(raw_rc)
data = {
    "schema_version": "qwendex.dev.gate.v1",
    "generated_at": datetime.now(UTC).isoformat(),
    "started_at": started_at,
    "run_id": run_id,
    "gate": gate_name,
    "status": "pass" if returncode == 0 else "fail",
    "success": returncode == 0,
    "returncode": returncode,
    "command": command,
    "log": log.name,
    "log_bytes": len(log_bytes),
    "log_sha256": hashlib.sha256(log_bytes).hexdigest(),
}
Path(receipt).write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")
PY
  return "$rc"
}

require_json_pass() {
  local path="$1"
  python3 - "$path" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
payload = json.loads(path.read_text(encoding="utf-8"))
passed = payload.get("status") == "pass" or payload.get("success") is True
if not passed:
    raise SystemExit(f"required receipt did not pass: {path}")
PY
}

bind_release_receipt() {
  local path="$1"
  local run_id="$2"
  local gate_name="$3"
  local command_id="$4"
  local source_commit="$5"
  local source_tree="$6"
  local health_mode="${7:-}"
  python3 - "$path" "$run_id" "$gate_name" "$command_id" "$source_commit" "$source_tree" "$health_mode" <<'PY'
import hashlib
import json
import sys
from datetime import UTC, datetime
from pathlib import Path

path = Path(sys.argv[1])
run_id, gate, command_id, source_commit, source_tree, health_mode = sys.argv[2:8]
payload = json.loads(path.read_text(encoding="utf-8"))
if not isinstance(payload, dict):
    raise SystemExit(f"release receipt must be a JSON object: {path}")
unbound = dict(payload)
unbound.pop("release_binding", None)
payload_sha256 = hashlib.sha256(
    json.dumps(unbound, sort_keys=True, separators=(",", ":")).encode("utf-8")
).hexdigest()
binding = {
    "schema_version": "qwendex.dev.receipt_binding.v1",
    "generated_at": datetime.now(UTC).isoformat(),
    "run_id": run_id,
    "gate": gate,
    "command_id": command_id,
    "source": {
        "commit": source_commit,
        "tree": source_tree,
    },
    "payload_sha256": payload_sha256,
}
if health_mode:
    binding["health_mode"] = health_mode
payload["release_binding"] = binding
path.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
PY
}

refresh_ci_attestation() {
  local commit="$1"
  local output="$2"
  local default_branch="$3"
  [[ -n "$default_branch" ]] || die "strict release verification requires a non-empty default branch"
  command -v gh >/dev/null 2>&1 || die "strict release verification requires gh to fetch CI attestation"
  local runs_json
  runs_json="$(gh run list \
    --commit "$commit" \
    --branch "$default_branch" \
    --event push \
    --workflow .github/workflows/ci.yml \
    --limit 20 \
    --json databaseId,conclusion,event,headBranch,headSha,status,workflowName)"
  local remote_run_id
  remote_run_id="$(python3 -c '
import json, sys
runs = json.load(sys.stdin)
for run in runs:
    if (
        run.get("headSha") == sys.argv[1]
        and run.get("headBranch") == sys.argv[2]
        and run.get("workflowName") == "CI"
        and run.get("event") == "push"
        and run.get("status") == "completed"
        and run.get("conclusion") == "success"
    ):
        print(run["databaseId"])
        break
' "$commit" "$default_branch" <<<"$runs_json")"
  [[ -n "$remote_run_id" ]] || die "no successful CI push run found for $commit"
  local download_root
  download_root="$(mktemp -d "$WORK_ROOT/ci-attestation.XXXXXX")"
  if ! gh run download \
    "$remote_run_id" \
    --name "qwendex-ci-attestation-$commit" \
    --dir "$download_root"; then
    rm -rf "$download_root"
    die "failed to download CI attestation artifact for $commit"
  fi
  local downloaded="$download_root/qwendex-ci-attestation.json"
  if [[ ! -f "$downloaded" ]]; then
    rm -rf "$download_root"
    die "CI artifact did not contain qwendex-ci-attestation.json"
  fi
  mkdir -p "$(dirname "$output")"
  install -m 0600 "$downloaded" "$output"
  rm -rf "$download_root"
}

cmd_validate_config_json() {
  local count=0
  while IFS= read -r -d '' json_path; do
    python3 -m json.tool "$json_path" >/dev/null
    count=$((count + 1))
  done < <(python3 - <<'PY'
import os
import sys
from pathlib import Path

for path in sorted(Path("config").rglob("*.json")):
    if not path.name.endswith(".local.json"):
        sys.stdout.buffer.write(os.fsencode(path) + b"\0")
PY
)
  python3 "$DEV_ROOT/scripts/validate_qwendex_config.py" --repo-root "$DEV_ROOT"
  printf 'validated %s public JSON configuration files\n' "$count"
}

write_validated_codex_build_receipt() {
  local source_receipt="$META_ROOT/codex_build.json"
  local output="$1"
  local run_id="$2"
  local binary="${QWENDEX_DEV_CODEX_BIN:-$DEV_CODEX_DEFAULT}"
  local code_mode_host
  code_mode_host="$(dirname "$binary")/codex-code-mode-host"
  [[ -f "$source_receipt" ]] || die "missing Codex build receipt: run qwendex-dev codex-source build"
  python3 - "$source_receipt" "$output" "$CODEX_SOURCE_DIR" "$binary" "$code_mode_host" "$META_ROOT/codex_build_inputs.json" "$META_ROOT/codex_source_preflight.json" "$run_id" <<'PY'
import hashlib
import json
import subprocess
import sys
from datetime import UTC, datetime
from pathlib import Path

source_receipt, output, source_root, binary, code_mode_host, build_inputs_path, preflight_path = map(Path, sys.argv[1:8])
run_id = sys.argv[8]
receipt = json.loads(source_receipt.read_text(encoding="utf-8"))
build_inputs = json.loads(build_inputs_path.read_text(encoding="utf-8"))


def sha256_file(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


if receipt.get("status") != "pass":
    raise SystemExit("Codex build receipt is not passing")
if not binary.is_file():
    raise SystemExit(f"built Codex binary is missing: {binary}")
if binary.is_symlink():
    raise SystemExit(f"built Codex binary must not be a symlink: {binary}")
if not code_mode_host.is_file():
    raise SystemExit(f"built Codex code-mode host is missing: {code_mode_host}")
if code_mode_host.is_symlink():
    raise SystemExit(f"built Codex code-mode host must not be a symlink: {code_mode_host}")
if not code_mode_host.stat().st_mode & 0o111:
    raise SystemExit(f"built Codex code-mode host is not executable: {code_mode_host}")
head = subprocess.run(
    ["git", "-C", str(source_root), "rev-parse", "HEAD"],
    text=True,
    capture_output=True,
    check=True,
    timeout=30,
).stdout.strip()
diff = subprocess.run(
    ["git", "-C", str(source_root), "diff", "HEAD", "--binary", "--full-index", "--no-ext-diff"],
    capture_output=True,
    check=True,
    timeout=30,
).stdout
patch_sha = hashlib.sha256(diff).hexdigest()
binary_sha = sha256_file(binary)
code_mode_host_sha = sha256_file(code_mode_host)
tree_manifest = subprocess.run(
    ["git", "-C", str(source_root), "ls-tree", "-r", "--full-tree", "HEAD"],
    capture_output=True,
    check=True,
    timeout=30,
).stdout
changed_paths = subprocess.run(
    ["git", "-C", str(source_root), "diff", "HEAD", "--name-only", "--no-ext-diff"],
    text=True,
    capture_output=True,
    check=True,
    timeout=30,
).stdout.splitlines()
lock_sha = sha256_file(source_root / "codex-rs" / "Cargo.lock")
cargo_version = subprocess.run(
    ["cargo", "--version", "--verbose"],
    cwd=source_root / "codex-rs",
    text=True,
    capture_output=True,
    check=True,
    timeout=30,
).stdout.strip()
rustc_version = subprocess.run(
    ["rustc", "-Vv"],
    cwd=source_root / "codex-rs",
    text=True,
    capture_output=True,
    check=True,
    timeout=30,
).stdout.strip()
source_ref = str(receipt.get("source_ref") or "")
ref_target = subprocess.run(
    ["git", "-C", str(source_root), "rev-parse", f"{source_ref}^{{commit}}"],
    text=True,
    capture_output=True,
    check=True,
    timeout=30,
).stdout.strip()
binary_version = subprocess.run(
    [str(binary), "--version"], text=True, capture_output=True, check=True, timeout=30
).stdout.strip()
if receipt.get("source_head") != head:
    raise SystemExit("Codex build source HEAD no longer matches the build receipt")
if ref_target != head or build_inputs.get("source_ref_target") != head:
    raise SystemExit("Codex build source ref no longer resolves to source HEAD")
if receipt.get("source_patch_sha256") != patch_sha:
    raise SystemExit("Codex build patch digest no longer matches the build receipt")
if receipt.get("source_tree_manifest_sha256") != hashlib.sha256(tree_manifest).hexdigest():
    raise SystemExit("Codex build source tree manifest no longer matches the build receipt")
if receipt.get("source_patch_paths") != sorted(path for path in changed_paths if path):
    raise SystemExit("Codex build patch path set no longer matches the build receipt")
if receipt.get("cargo_lock_sha256") != lock_sha:
    raise SystemExit("Codex Cargo.lock no longer matches the build receipt")
if receipt.get("cargo_version") != cargo_version or receipt.get("rustc_version") != rustc_version:
    raise SystemExit("Codex build toolchain no longer matches the build receipt")
if receipt.get("build_inputs_sha256") != sha256_file(build_inputs_path):
    raise SystemExit("Codex build input manifest digest does not match the build receipt")
if build_inputs.get("status") != "pass" or build_inputs.get("blockers"):
    raise SystemExit("Codex build input manifest is not passing")
for field in (
    "source_head",
    "source_patch_sha256",
    "expected_source_patch_sha256",
    "source_tree_manifest_sha256",
    "cargo_lock_sha256",
    "expected_cargo_lock_sha256",
    "cargo_version",
    "rustc_version",
    "build_isolation",
    "cargo_home_policy",
    "cargo_home_config_files",
    "project_cargo_config",
    "dependency_fetch_policy",
):
    if receipt.get(field) != build_inputs.get(field):
        raise SystemExit(f"Codex build receipt field does not match input manifest: {field}")
if receipt.get("preflight", {}).get("sha256") != sha256_file(preflight_path):
    raise SystemExit("Codex source preflight no longer matches the build receipt")
if receipt.get("binary_sha256") != binary_sha:
    raise SystemExit("Codex dev binary digest no longer matches the build receipt")
if receipt.get("binary") != str(binary) or receipt.get("binary_bytes") != binary.stat().st_size:
    raise SystemExit("Codex dev binary path/size no longer matches the build receipt")
if receipt.get("binary_version") != binary_version:
    raise SystemExit("Codex dev binary version no longer matches the build receipt")
host_receipt = receipt.get("code_mode_host")
if not isinstance(host_receipt, dict):
    raise SystemExit("Codex build receipt is missing the code-mode host contract")
if host_receipt.get("binary") != str(code_mode_host):
    raise SystemExit("Codex code-mode host path no longer matches the build receipt")
if host_receipt.get("binary_bytes") != code_mode_host.stat().st_size:
    raise SystemExit("Codex code-mode host size no longer matches the build receipt")
if host_receipt.get("binary_sha256") != code_mode_host_sha:
    raise SystemExit("Codex code-mode host digest no longer matches the build receipt")
validated = dict(receipt)
validated.update(
    {
        "generated_at": datetime.now(UTC).isoformat(),
        "validated_at": datetime.now(UTC).isoformat(),
        "run_id": run_id,
        "status": "pass",
        "build_inputs": build_inputs,
        "source_receipt_sha256": sha256_file(source_receipt),
    }
)
Path(output).write_text(json.dumps(validated, indent=2, sort_keys=True) + "\n", encoding="utf-8")
PY
}

write_bootstrap_json() {
  python3 - "$BOOTSTRAP_JSON" "$INSTALL_DEPS_JSON" "$DEV_ROOT" "$SOURCE_ROOT" "$WORK_ROOT" "$MAIN_CODEX_BIN" "$DEV_CODEX_DEFAULT" <<'PY'
import json
import shutil
import subprocess
import sys
from datetime import UTC, datetime
from pathlib import Path

out, install_deps, dev_root, source_root, work_root, main_codex, dev_codex = map(Path, sys.argv[1:8])

def version(cmd):
    exe = shutil.which(cmd) or (str(cmd) if Path(cmd).exists() else "")
    if not exe:
        return {"available": False, "path": "", "version": ""}
    try:
        args = [exe, "-V"] if Path(exe).name == "tmux" else [exe, "--version"]
        result = subprocess.run(args, text=True, capture_output=True, timeout=15, check=False)
        raw = (result.stdout or result.stderr).strip().splitlines()[0] if (result.stdout or result.stderr).strip() else ""
        return {"available": result.returncode == 0, "path": exe, "version": raw, "returncode": result.returncode}
    except Exception as exc:
        return {"available": False, "path": exe, "version": "", "error": str(exc)}

tools = {name: version(name) for name in ("python3", "git", "rsync", "tmux", "codex", "cargo", "rustfmt")}
tools["codex-main"] = version(str(main_codex))
tools["codex-dev"] = version(str(dev_codex))
data = {
    "schema_version": "qwendex.dev.bootstrap.v1",
    "generated_at": datetime.now(UTC).isoformat(),
    "dev_root": str(dev_root),
    "source_root": str(source_root),
    "work_root": str(work_root),
    "install_deps_receipt": str(install_deps),
    "tools": tools,
    "missing_required": [name for name in ("python3", "git", "rsync", "codex") if not tools[name]["available"]],
    "missing_optional": [name for name in ("tmux", "cargo", "rustfmt") if not tools[name]["available"]],
}
if install_deps.is_file():
    try:
        data["install_deps"] = json.loads(install_deps.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        data["install_deps"] = {"status": "blocked", "error": str(exc)}
else:
    data["install_deps"] = {"status": "missing"}
data["status"] = "pass" if not data["missing_required"] and data["install_deps"].get("status") == "pass" else "blocked"
out.parent.mkdir(parents=True, exist_ok=True)
out.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")
print(f"bootstrap: {data['status']} - {out}")
PY
}

write_dev_status_json() {
  local mode="${1:-status}"
  python3 - "$DEV_STATUS_JSON" "$mode" "$DEV_ROOT" "$SOURCE_ROOT" "$WORK_ROOT" "$STATE_DB" "$PERFORMANCE_DB" "$LEDGER_DB" "$LOCAL_HARNESS_LEDGER_DB" "$RESULTS_ROOT" "$STATUS_FILE" "$CODEX_SOURCE_DIR" "$DEV_CODEX_DEFAULT" "$DEV_CODE_MODE_HOST_DEFAULT" "$MAIN_CODEX_BIN" <<'PY'
import json
import os
import shutil
import subprocess
import sys
from datetime import UTC, datetime
from pathlib import Path

(
    out,
    mode,
    dev_root,
    source_root,
    work_root,
    state_db,
    performance_db,
    ledger_db,
    local_ledger_db,
    results_root,
    status_file,
    codex_source,
    dev_codex,
    dev_code_mode_host,
    main_codex,
) = sys.argv[1:16]
out = Path(out)
paths = {k: Path(v) for k, v in {
    "dev_root": dev_root,
    "source_root": source_root,
    "work_root": work_root,
    "state_db": state_db,
    "performance_db": performance_db,
    "ledger_db": ledger_db,
    "local_harness_ledger_db": local_ledger_db,
    "results_root": results_root,
    "status_file": status_file,
    "codex_source": codex_source,
    "dev_codex": dev_codex,
    "dev_code_mode_host": dev_code_mode_host,
    "main_codex": main_codex,
}.items()}

def run(cmd, cwd=None):
    try:
        result = subprocess.run(cmd, cwd=cwd, text=True, capture_output=True, timeout=20, check=False)
        return {"returncode": result.returncode, "stdout": result.stdout.strip(), "stderr": result.stderr.strip()}
    except Exception as exc:
        return {"returncode": 127, "stdout": "", "stderr": str(exc)}

def hook_source(path, scope):
    exists = path.is_file()
    events = []
    if exists:
        try:
            payload = json.loads(path.read_text(encoding="utf-8"))
            hooks = payload.get("hooks") if isinstance(payload, dict) else None
            if isinstance(hooks, dict):
                events = sorted(str(key) for key in hooks)
            elif isinstance(payload, dict):
                events = sorted(str(key) for key in payload if str(key).lower().endswith("hook"))
        except Exception:
            events = []
    return {
        "scope": scope,
        "path": str(path),
        "exists": exists,
        "events": events,
        "bytes": path.stat().st_size if exists else 0,
    }

def under(path, root):
    try:
        path.resolve().relative_to(root.resolve())
        return True
    except Exception:
        return False

dev_git = run(["git", "rev-parse", "--abbrev-ref", "HEAD"], cwd=paths["dev_root"])
source_git = run(["git", "rev-parse", "--abbrev-ref", "HEAD"], cwd=paths["source_root"])
dev_status = run(["git", "status", "--short"], cwd=paths["dev_root"])
source_status = run(["git", "status", "--short"], cwd=paths["source_root"])
tools = {name: bool(shutil.which(name)) for name in ("python3", "git", "rsync", "codex", "cargo", "rustfmt", "tmux")}
state_isolation = {
    "state_db_under_work_root": under(paths["state_db"], paths["work_root"]),
    "performance_db_under_work_root": under(paths["performance_db"], paths["work_root"]),
    "ledger_db_under_work_root": under(paths["ledger_db"], paths["work_root"]),
    "local_harness_ledger_db_under_work_root": under(paths["local_harness_ledger_db"], paths["work_root"]),
    "results_under_work_root": under(paths["results_root"], paths["work_root"]),
}
active_codex_home = Path(os.environ.get("QWENDEX_CODEX_HOME") or paths["work_root"] / "codex_home")
runtime_generation = str(os.environ.get("QWENDEX_RUNTIME_GENERATION_ID") or "")
runtime_tree = str(os.environ.get("QWENDEX_RUNTIME_TREE") or "")
active_hook_sources = [
    hook_source(active_codex_home / "hooks.json", "active-codex-home"),
    hook_source(paths["dev_root"] / ".codex" / "hooks.json", "project"),
    hook_source(paths["dev_root"] / "hooks" / "hooks.json", "project"),
]
global_hook_sources = [hook_source(Path.home() / ".codex" / "hooks.json", "global")]
active_hook_sources = [source for source in active_hook_sources if source["exists"]]
global_hook_sources = [source for source in global_hook_sources if source["exists"]]
data = {
    "schema_version": "qwendex.dev.status.v1",
    "generated_at": datetime.now(UTC).isoformat(),
    "mode": mode,
    "roots": {k: str(v) for k, v in paths.items()},
    "git": {
        "dev_branch": dev_git["stdout"],
        "source_branch": source_git["stdout"],
        "dev_status": dev_status["stdout"].splitlines(),
        "source_status": source_status["stdout"].splitlines(),
        "dev_is_worktree": (paths["dev_root"] / ".git").exists(),
    },
    "tools": tools,
    "state_isolation": state_isolation,
    "runtime": {
        "generation_required": os.environ.get("QWENDEX_RUNTIME_GENERATION_REQUIRED") == "1",
        "generation_id": runtime_generation,
        "tree": runtime_tree,
        "contract_sha256": str(os.environ.get("QWENDEX_RUNTIME_CONTRACT_SHA256") or ""),
        "hook_generation": str(os.environ.get("QWENDEX_HOOK_GENERATION") or ""),
    },
    "codex": {
        "dev_binary_exists": paths["dev_codex"].is_file(),
        "dev_code_mode_host_exists": paths["dev_code_mode_host"].is_file(),
        "dev_code_mode_host_executable": paths["dev_code_mode_host"].is_file() and bool(paths["dev_code_mode_host"].stat().st_mode & 0o111),
        "main_binary_exists": paths["main_codex"].is_file(),
        "source_exists": paths["codex_source"].is_dir(),
        "active_codex_home": str(active_codex_home),
        "hook_sources": active_hook_sources,
        "hook_source_count": len(active_hook_sources),
        "global_hook_sources": global_hook_sources,
        "global_hook_source_count": len(global_hook_sources),
    },
    "latest_receipts": sorted(str(p) for p in paths["results_root"].glob("**/*.json"))[-20:] if paths["results_root"].exists() else [],
}
blockers = []
warnings = []
if not all(state_isolation.values()):
    blockers.append("state paths are not fully isolated under .qwendex-dev")
if not data["git"]["dev_is_worktree"]:
    blockers.append("dev root is not a git worktree")
if not tools["python3"] or not tools["git"] or not tools["codex"]:
    blockers.append("required tool missing")
if data["codex"]["dev_binary_exists"] and not data["codex"]["dev_code_mode_host_executable"]:
    blockers.append("dev Codex binary is missing its executable codex-code-mode-host companion")
if not active_hook_sources and global_hook_sources:
    warnings.append("active dev CODEX_HOME has no hooks while ~/.codex has hooks")
data["blockers"] = blockers
data["warnings"] = warnings
data["status"] = "pass" if not blockers else "blocked"
out.parent.mkdir(parents=True, exist_ok=True)
out.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")
print(f"status-json: {data['status']} - {out}")
PY
}

cmd_env() {
  prepare
  cat "$WORK_ROOT/env.sh"
}

cmd_sync() {
  if ! dev_is_git_repo; then
    sync_project
  fi
  prepare
  # Keep the first status/state write on the generated isolated runtime. A
  # fresh shell has not loaded env.sh yet, so calling qwendex directly here
  # would otherwise fall back to ~/.local/state/qwendex.
  # shellcheck disable=SC1090
  source "$WORK_ROOT/env.sh"
  local runtime_build_json="$META_ROOT/runtime_generation_build.json"
  local runtime_activate_json="$META_ROOT/runtime_generation_activation.json"
  local runtime_codex="${QWENDEX_DEV_CODEX_BIN:-$DEV_CODEX_DEFAULT}"
  local runtime_host
  runtime_host="$(dirname "$runtime_codex")/codex-code-mode-host"
  local runtime_receipt="$META_ROOT/codex_build.json"
  if [[ -f "$runtime_receipt" && -x "$runtime_codex" && -x "$runtime_host" ]]; then
    "$DEV_ROOT/scripts/qwendex" runtime build \
      --source-root "$DEV_ROOT" \
      --runtime-root "$QWENDEX_RUNTIME_ROOT" \
      --codex-bin "$runtime_codex" \
      --code-mode-host "$runtime_host" \
      --json > "$runtime_build_json"
    local runtime_candidate
    runtime_candidate="$(python3 - "$runtime_build_json" <<'PY'
import json
import sys

payload = json.load(open(sys.argv[1], encoding="utf-8"))
if payload.get("status") != "pass":
    raise SystemExit(1)
print(payload["data"]["runtime_generation"]["generation_id"])
PY
    )"
    "$DEV_ROOT/scripts/qwendex" runtime activate --candidate "$runtime_candidate" --runtime-root "$QWENDEX_RUNTIME_ROOT" --json > "$runtime_activate_json"
  else
    python3 - "$runtime_build_json" "$runtime_receipt" "$runtime_codex" "$runtime_host" <<'PY'
import json
import sys
from datetime import UTC, datetime
from pathlib import Path

output, receipt, binary, host = map(Path, sys.argv[1:])
missing = [str(path) for path in (receipt, binary, host) if not path.is_file()]
payload = {
    "schema_version": "qwendex.runtime_bootstrap.v1",
    "generated_at": datetime.now(UTC).isoformat(),
    "status": "blocked",
    "summary": "Immutable runtime activation deferred until the pinned Codex build is available.",
    "missing_inputs": missing,
    "next_actions": ["qwendex-dev codex-source build", "qwendex-dev sync"],
}
output.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
PY
  fi
  install -m 0555 "$DEV_ROOT/scripts/qwendex_runtime.py" "$QWENDEX_RUNTIME_RECOVERY"
  # Reload the generation-aware values written by env.sh after atomic
  # activation; this command never rewrites an active session's generation.
  # shellcheck disable=SC1090
  source "$WORK_ROOT/env.sh"
  local qwendex_status_command="$DEV_ROOT/scripts/qwendex"
  if [[ -n "${QWENDEX_RUNTIME_TREE:-}" && -x "$QWENDEX_RUNTIME_TREE/scripts/qwendex" ]]; then
    qwendex_status_command="$QWENDEX_RUNTIME_TREE/scripts/qwendex"
  fi
  "$qwendex_status_command" codex-status --write "$QWENDEX_CODEX_STATUS_FILE" --json > "$META_ROOT/codex_status_write.json"
  write_dev_status_json sync >/dev/null
  printf 'Qwendex dev root ready: %s\n' "$DEV_ROOT"
  printf 'Load env with: source %s\n' "$WORK_ROOT/env.sh"
}

cmd_runtime() {
  prepare
  local action="${1:-status}"
  shift || true
  # Rollback must not depend on Qdex or mutable source being healthy. Prefer
  # the sync-installed standard-library recovery copy for all runtime actions.
  if [[ -x "$QWENDEX_RUNTIME_RECOVERY" ]]; then
    "$QWENDEX_RUNTIME_RECOVERY" "$action" --runtime-root "$QWENDEX_RUNTIME_ROOT" "$@"
  else
    "$DEV_ROOT/scripts/qwendex" runtime "$action" --runtime-root "$QWENDEX_RUNTIME_ROOT" "$@"
  fi
}

cmd_bootstrap() {
  local install=1
  local system=1
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --check|--check-only|--no-install)
        install=0
        ;;
      --no-system)
        system=0
        ;;
      --install-system)
        system=1
        ;;
      *)
        die "unknown bootstrap option: $1"
        ;;
    esac
    shift
  done
  prepare
  if [[ "$install" -eq 1 ]]; then
    local install_args=(--install --json)
    if [[ "$system" -eq 0 ]]; then
      install_args+=(--no-system)
    fi
    "$DEV_ROOT/scripts/qwendex_install_deps" "${install_args[@]}" > "$INSTALL_DEPS_JSON" || true
  else
    "$DEV_ROOT/scripts/qwendex_install_deps" --check --json > "$INSTALL_DEPS_JSON" || true
  fi
  if ! command -v cargo >/dev/null 2>&1 && [[ -x "$HOME/.cargo/bin/cargo" ]]; then
    export PATH="$HOME/.cargo/bin:$PATH"
  fi
  if command -v rustup >/dev/null 2>&1 && ! command -v rustfmt >/dev/null 2>&1; then
    rustup component add rustfmt >/dev/null
  fi
  write_bootstrap_json
  write_dev_status_json bootstrap >/dev/null
}

cmd_status() {
  prepare
  "$DEV_ROOT/scripts/qwendex" check --json > "$META_ROOT/qwendex_check.json"
  "$DEV_ROOT/scripts/qwendex" codex-status --write "$STATUS_FILE" --json > "$META_ROOT/codex_status_write.json"
  write_codex_patch_preflight_json
  write_dev_status_json status >/dev/null
  summary_json "$META_ROOT/qwendex_check.json" "$META_ROOT/codex_status_write.json" "$META_ROOT/codex_patch_preflight.json"
}

cmd_doctor() {
  prepare
  "$DEV_ROOT/scripts/qwendex" check --json > "$META_ROOT/qwendex_check.json"
  "$DEV_ROOT/scripts/qwendex" doctor --json > "$META_ROOT/qwendex_doctor.json"
  "$DEV_ROOT/scripts/qwendex" llmstack check --json > "$META_ROOT/llmstack_check.json"
  "$DEV_ROOT/scripts/qwendex" codex-status --write "$STATUS_FILE" --json > "$META_ROOT/codex_status_write.json"
  write_codex_patch_preflight_json
  write_dev_status_json doctor
  local dev_status_rc=0
  require_json_pass "$DEV_STATUS_JSON" || dev_status_rc=$?
  summary_json \
    "$META_ROOT/qwendex_check.json" \
    "$META_ROOT/qwendex_doctor.json" \
    "$META_ROOT/llmstack_check.json" \
    "$META_ROOT/codex_status_write.json" \
    "$META_ROOT/codex_patch_preflight.json"
  return "$dev_status_rc"
}

cmd_status_json() {
  prepare
  write_dev_status_json status
}

cmd_preflight() {
  prepare
  "$DEV_ROOT/scripts/qwendex" codex-status --write "$STATUS_FILE" --json > "$META_ROOT/codex_status_write.json"
  write_codex_patch_preflight_json
  write_dev_status_json preflight >/dev/null
  summary_json "$META_ROOT/codex_status_write.json" "$META_ROOT/codex_patch_preflight.json"
}

write_codex_patch_preflight_json() {
  local output="${1:-$META_ROOT/codex_patch_preflight.json}"
  local require_dev="${2:-0}"
  local codex_bin="${QWENDEX_DEV_CODEX_BIN:-$DEV_CODEX_DEFAULT}"
  if [[ ! -x "$codex_bin" ]]; then
    if [[ "$require_dev" -eq 1 ]]; then
      die "release verification requires a built dev Codex binary: $codex_bin"
    fi
    codex_bin="$MAIN_CODEX_BIN"
  fi
  [[ -x "$codex_bin" ]] || die "Codex binary is not executable: $codex_bin"
  if [[ -d "$CODEX_SOURCE_DIR" ]]; then
    "$DEV_ROOT/scripts/qwendex" codex-patch preflight \
      --codex-bin "$codex_bin" \
      --source "$CODEX_SOURCE_DIR" \
      --require-applied \
      --json > "$output"
  else
    "$DEV_ROOT/scripts/qwendex" codex-patch preflight \
      --codex-bin "$codex_bin" \
      --json > "$output"
  fi
}

cmd_patch_codex() {
  prepare
  local source="${1:-$WORK_ROOT/codex-source/codex}"
  "$DEV_ROOT/scripts/qwendex" codex-patch apply --source "$source" --json
}

cmd_codex_source() {
  prepare
  local action="${1:-preflight}"
  shift || true
  case "$action" in
    sync)
      if [[ -d "$CODEX_SOURCE_DIR/.git" ]]; then
        git -C "$CODEX_SOURCE_DIR" fetch --tags --depth 1 origin "$QWENDEX_CODEX_SOURCE_REF"
        git -C "$CODEX_SOURCE_DIR" checkout FETCH_HEAD
      else
        rm -rf "$CODEX_SOURCE_DIR"
        git clone --depth 1 --branch "$QWENDEX_CODEX_SOURCE_REF" "$QWENDEX_CODEX_SOURCE_REPO" "$CODEX_SOURCE_DIR"
      fi
      "$DEV_ROOT/scripts/qwendex" codex-patch preflight \
        --codex-bin "$MAIN_CODEX_BIN" \
        --source "$CODEX_SOURCE_DIR" \
        --json
      ;;
    patch)
      [[ -d "$CODEX_SOURCE_DIR" ]] || die "missing Codex source: run qwendex-dev codex-source sync"
      local patch_codex="${QWENDEX_DEV_CODEX_BIN:-$DEV_CODEX_DEFAULT}"
      if [[ ! -x "$patch_codex" ]]; then
        patch_codex="$MAIN_CODEX_BIN"
      fi
      [[ -x "$patch_codex" ]] || die "missing Codex binary for source-patch preflight"
      "$DEV_ROOT/scripts/qwendex" codex-patch apply \
        --codex-bin "$patch_codex" \
        --source "$CODEX_SOURCE_DIR" \
        --json
      "$DEV_ROOT/scripts/qwendex" codex-patch preflight \
        --codex-bin "$patch_codex" \
        --source "$CODEX_SOURCE_DIR" \
        --require-applied \
        --json > "$META_ROOT/codex_source_preflight.json"
      ;;
    preflight)
      [[ -d "$CODEX_SOURCE_DIR" ]] || die "missing Codex source: run qwendex-dev codex-source sync"
      local preflight_codex="${QWENDEX_DEV_CODEX_BIN:-$DEV_CODEX_DEFAULT}"
      if [[ ! -x "$preflight_codex" ]]; then
        preflight_codex="$MAIN_CODEX_BIN"
      fi
      [[ -x "$preflight_codex" ]] || die "missing Codex binary for source-patch preflight"
      "$DEV_ROOT/scripts/qwendex" codex-patch preflight \
        --codex-bin "$preflight_codex" \
        --source "$CODEX_SOURCE_DIR" \
        --require-applied \
        --json
      ;;
    build)
      [[ -d "$CODEX_SOURCE_DIR/codex-rs" ]] || die "missing Codex Rust source: run qwendex-dev codex-source sync"
      local source_head
      local source_ref_target
      source_head="$(git -C "$CODEX_SOURCE_DIR" rev-parse HEAD)"
      source_ref_target="$(git -C "$CODEX_SOURCE_DIR" rev-parse "$QWENDEX_CODEX_SOURCE_REF^{commit}")"
      [[ "$source_head" == "$source_ref_target" ]] || die "Codex source HEAD does not match $QWENDEX_CODEX_SOURCE_REF"
      [[ "$source_head" == "$QWENDEX_RELEASE_CODEX_SOURCE_COMMIT" ]] || die "Codex source HEAD does not match the canonical $QWENDEX_CODEX_SOURCE_REF commit"
      [[ "$(git -C "$CODEX_SOURCE_DIR" remote get-url origin)" == "$QWENDEX_RELEASE_CODEX_SOURCE_REPO" ]] || die "Codex source origin is not the canonical OpenAI repository"
      local prebuild_codex="$MAIN_CODEX_BIN"
      [[ -x "$prebuild_codex" ]] || prebuild_codex="$(command -v codex || true)"
      [[ -x "$prebuild_codex" ]] || die "missing Codex binary for source-version preflight"
      "$DEV_ROOT/scripts/qwendex" codex-patch preflight \
        --codex-bin "$prebuild_codex" \
        --source "$CODEX_SOURCE_DIR" \
        --require-applied \
        --json > "$META_ROOT/codex_source_preflight.json"
      local isolated_build_root
      local isolated_cargo_home
      isolated_build_root="$(mktemp -d "$WORK_ROOT/codex-build/source.XXXXXX")"
      isolated_cargo_home="$isolated_build_root/cargo-home"
      trap '[[ -z "${isolated_build_root:-}" ]] || rm -rf "$isolated_build_root"' EXIT
      mkdir -p "$isolated_cargo_home"
      # Normalize the release workspace package versions in Cargo.lock before
      # freezing build provenance. Metadata and compilation use one initially
      # empty, ephemeral CARGO_HOME so user/global Cargo config cannot alter
      # the deterministic lock or release build.
      (
        cd "$CODEX_SOURCE_DIR/codex-rs"
        env \
          -u CARGO_BUILD_RUSTFLAGS \
          -u CARGO_BUILD_TARGET \
          -u CARGO_ENCODED_RUSTFLAGS \
          -u RUSTC \
          -u RUSTC_WORKSPACE_WRAPPER \
          -u RUSTC_WRAPPER \
          -u RUSTDOC \
          -u RUSTDOCFLAGS \
          -u RUSTFLAGS \
          -u RUSTUP_TOOLCHAIN \
          CARGO_HOME="$isolated_cargo_home" \
          cargo metadata --format-version 1 >/dev/null
      )
      CARGO_HOME="$isolated_cargo_home" python3 - \
        "$META_ROOT/codex_build_inputs.json" \
        "$CODEX_SOURCE_DIR" \
        "$QWENDEX_CODEX_SOURCE_REF" \
        "$QWENDEX_RELEASE_CODEX_SOURCE_COMMIT" \
        "$QWENDEX_RELEASE_CODEX_SOURCE_REPO" \
        "$QWENDEX_RELEASE_CODEX_PATCH_SHA256" \
        "$QWENDEX_RELEASE_CODEX_CARGO_LOCK_SHA256" <<'PY'
import hashlib
import json
import os
import subprocess
import sys
from datetime import UTC, datetime
from pathlib import Path

(
    out,
    source,
    source_ref,
    expected_source_commit,
    expected_source_origin,
    expected_patch_sha256,
    expected_lock_sha256,
) = sys.argv[1:8]
source_path = Path(source)
allowed_changes = {
    "codex-rs/Cargo.lock",
    "codex-rs/config/src/tui_keymap.rs",
    "codex-rs/core/src/config/config_tests.rs",
    "codex-rs/core/src/config/mod.rs",
    "codex-rs/core/src/hook_runtime.rs",
    "codex-rs/core/src/tools/spec_plan.rs",
    "codex-rs/hooks/src/events/session_start.rs",
    "codex-rs/hooks/src/schema.rs",
    "codex-rs/models-manager/src/manager.rs",
    "codex-rs/tui/src/app/input.rs",
    "codex-rs/tui/src/bottom_pane/status_line_setup.rs",
    "codex-rs/tui/src/bottom_pane/status_line_style.rs",
    "codex-rs/tui/src/bottom_pane/status_surface_preview.rs",
    "codex-rs/tui/src/chatwidget/status_surfaces.rs",
    "codex-rs/tui/src/keymap.rs",
    "codex-rs/tui/src/terminal_visualization_instructions.rs",
}


def run(*args: str, binary: bool = False, cwd: Path | None = None) -> str | bytes:
    result = subprocess.run(
        args,
        cwd=cwd,
        capture_output=True,
        text=not binary,
        check=True,
        timeout=60,
    )
    return result.stdout if binary else result.stdout.strip()


def sha256_file(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


head = str(run("git", "-C", str(source_path), "rev-parse", "HEAD"))
ref_target = str(run("git", "-C", str(source_path), "rev-parse", f"{source_ref}^{{commit}}"))
source_origin = str(run("git", "-C", str(source_path), "remote", "get-url", "origin"))
status_lines = str(
    run("git", "-C", str(source_path), "status", "--porcelain=v1", "--untracked-files=all")
).splitlines()
untracked = [line[3:] for line in status_lines if line.startswith("?? ")]
unmerged = [line for line in status_lines if line[:2] in {"DD", "AU", "UD", "UA", "DU", "AA", "UU"}]
changed_paths = sorted(
    path
    for path in str(
        run("git", "-C", str(source_path), "diff", "HEAD", "--name-only", "--no-ext-diff")
    ).splitlines()
    if path
)
unexpected_changes = sorted(set(changed_paths) - allowed_changes)
missing_patch_paths = sorted((allowed_changes - {"codex-rs/Cargo.lock"}) - set(changed_paths))
source_diff = run(
    "git", "-C", str(source_path), "diff", "HEAD", "--binary", "--full-index", "--no-ext-diff", binary=True
)
tree_manifest = run("git", "-C", str(source_path), "ls-tree", "-r", "--full-tree", "HEAD", binary=True)
lock_path = source_path / "codex-rs" / "Cargo.lock"
source_patch_sha256 = hashlib.sha256(source_diff).hexdigest()
cargo_lock_sha256 = sha256_file(lock_path)
cargo_home = Path(os.environ["CARGO_HOME"])
cargo_home_configs = [
    path.relative_to(cargo_home).as_posix()
    for path in (cargo_home / "config", cargo_home / "config.toml")
    if path.exists()
]
project_cargo_config = source_path / "codex-rs" / ".cargo" / "config.toml"
blockers = []
if head != ref_target:
    blockers.append("source HEAD does not match the configured Codex source ref")
if head != expected_source_commit:
    blockers.append("source HEAD does not match the canonical Codex source commit")
if source_origin != expected_source_origin:
    blockers.append("source origin is not the canonical OpenAI Codex repository")
if untracked:
    blockers.append("Codex source has untracked files; isolated build input is ambiguous")
if unmerged:
    blockers.append("Codex source has unmerged paths")
if unexpected_changes:
    blockers.append("Codex source has changes outside the Qwendex patch allowlist")
if missing_patch_paths:
    blockers.append("Codex source is missing required Qwendex patch changes")
if cargo_home_configs:
    blockers.append("ephemeral Cargo home unexpectedly contains configuration")
if source_patch_sha256 != expected_patch_sha256:
    blockers.append("Codex source patch does not match the canonical Qwendex patch digest")
if cargo_lock_sha256 != expected_lock_sha256:
    blockers.append("Codex Cargo.lock does not match the canonical release digest")
data = {
    "schema_version": "qwendex.dev.codex_build_inputs.v1",
    "generated_at": datetime.now(UTC).isoformat(),
    "status": "pass" if not blockers else "blocked",
    "source_ref": source_ref,
    "source_head": head,
    "source_ref_target": ref_target,
    "expected_source_commit": expected_source_commit,
    "source_origin": source_origin,
    "expected_source_origin": expected_source_origin,
    "source_tree_manifest_sha256": hashlib.sha256(tree_manifest).hexdigest(),
    "source_patch_sha256": source_patch_sha256,
    "expected_source_patch_sha256": expected_patch_sha256,
    "source_patch_bytes": len(source_diff),
    "changed_paths": changed_paths,
    "unexpected_changes": unexpected_changes,
    "missing_patch_paths": missing_patch_paths,
    "untracked_paths": untracked,
    "unmerged_entries": unmerged,
    "cargo_lock_sha256": cargo_lock_sha256,
    "expected_cargo_lock_sha256": expected_lock_sha256,
    "cargo_version": str(run("cargo", "--version", "--verbose", cwd=source_path / "codex-rs")),
    "rustc_version": str(run("rustc", "-Vv", cwd=source_path / "codex-rs")),
    "build_isolation": "git-archive-plus-allowlisted-tracked-diff+ephemeral-cargo-home",
    "cargo_home_policy": "ephemeral-empty-no-user-config",
    "cargo_home_config_files": cargo_home_configs,
    "project_cargo_config": {
        "path": "codex-rs/.cargo/config.toml",
        "exists": project_cargo_config.is_file(),
        "sha256": sha256_file(project_cargo_config) if project_cargo_config.is_file() else "",
    },
    "dependency_fetch_policy": "locked-network-fetch-with-registry-checksums",
    "blockers": blockers,
}
Path(out).write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")
PY
      require_json_pass "$META_ROOT/codex_build_inputs.json"
      mkdir -p "$isolated_build_root/source"
      git -C "$CODEX_SOURCE_DIR" archive --format=tar HEAD | tar -xf - -C "$isolated_build_root/source"
      git -C "$CODEX_SOURCE_DIR" diff HEAD --binary --full-index --no-ext-diff > "$isolated_build_root/qwendex.patch"
      # The temp tree lives below the outer Qwendex worktree. Give it its own
      # Git boundary so `git apply` cannot discover and target the parent repo.
      git -C "$isolated_build_root/source" init --quiet
      if [[ -s "$isolated_build_root/qwendex.patch" ]]; then
        git -C "$isolated_build_root/source" apply --binary "$isolated_build_root/qwendex.patch"
      fi
      (
        cd "$isolated_build_root/source/codex-rs"
        env \
          -u CARGO_BUILD_RUSTFLAGS \
          -u CARGO_BUILD_TARGET \
          -u CARGO_ENCODED_RUSTFLAGS \
          -u RUSTC \
          -u RUSTC_WORKSPACE_WRAPPER \
          -u RUSTC_WRAPPER \
          -u RUSTDOC \
          -u RUSTDOCFLAGS \
          -u RUSTFLAGS \
          -u RUSTUP_TOOLCHAIN \
          CARGO_HOME="$isolated_cargo_home" \
          CARGO_TARGET_DIR="$isolated_build_root/target" \
          cargo build \
            --locked \
            --release \
            -p codex-cli \
            -p codex-code-mode-host \
            --bin codex \
            --bin codex-code-mode-host
      )
      mkdir -p "$(dirname "$DEV_CODEX_DEFAULT")"
      local tmp_codex
      local tmp_code_mode_host
      tmp_codex="$(mktemp "$(dirname "$DEV_CODEX_DEFAULT")/.codex.XXXXXX")"
      tmp_code_mode_host="$(mktemp "$(dirname "$DEV_CODE_MODE_HOST_DEFAULT")/.codex-code-mode-host.XXXXXX")"
      cp "$isolated_build_root/target/release/codex" "$tmp_codex"
      cp "$isolated_build_root/target/release/codex-code-mode-host" "$tmp_code_mode_host"
      local codex_unstripped_bytes
      local code_mode_host_unstripped_bytes
      local strip_tool
      codex_unstripped_bytes="$(stat -c %s "$tmp_codex")"
      code_mode_host_unstripped_bytes="$(stat -c %s "$tmp_code_mode_host")"
      strip_tool="$(command -v strip)" || die "strip is required to package the Qwendex Codex release binaries"
      "$strip_tool" --strip-unneeded "$tmp_codex" "$tmp_code_mode_host"
      chmod +x "$tmp_codex"
      chmod +x "$tmp_code_mode_host"
      mv -f "$tmp_code_mode_host" "$DEV_CODE_MODE_HOST_DEFAULT"
      mv -f "$tmp_codex" "$DEV_CODEX_DEFAULT"
      rm -rf "$isolated_build_root"
      isolated_build_root=""
      trap - EXIT
      "$DEV_ROOT/scripts/qwendex" codex-patch preflight \
        --codex-bin "$DEV_CODEX_DEFAULT" \
        --source "$CODEX_SOURCE_DIR" \
        --require-applied \
        --json > "$META_ROOT/codex_source_preflight.json"
      python3 - "$META_ROOT/codex_build.json" "$CODEX_SOURCE_DIR" "$QWENDEX_CODEX_SOURCE_REF" "$DEV_CODEX_DEFAULT" "$DEV_CODE_MODE_HOST_DEFAULT" "$META_ROOT/codex_source_preflight.json" "$META_ROOT/codex_build_inputs.json" "$strip_tool" "$codex_unstripped_bytes" "$code_mode_host_unstripped_bytes" <<'PY'
import hashlib
import json
import subprocess
import sys
from datetime import UTC, datetime
from pathlib import Path

(
    out,
    source,
    source_ref,
    binary,
    code_mode_host,
    preflight,
    build_inputs,
    strip_tool,
    codex_unstripped_bytes,
    code_mode_host_unstripped_bytes,
) = sys.argv[1:11]
source_path = Path(source)
binary_path = Path(binary)
code_mode_host_path = Path(code_mode_host)
preflight_path = Path(preflight)
build_inputs_path = Path(build_inputs)


def run(*args: str) -> str:
    result = subprocess.run(args, text=True, capture_output=True, check=True, timeout=30)
    return result.stdout.strip()


def sha256_file(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


source_diff = subprocess.run(
    ["git", "-C", str(source_path), "diff", "HEAD", "--binary", "--full-index", "--no-ext-diff"],
    capture_output=True,
    check=True,
    timeout=30,
).stdout
preflight_payload = json.loads(preflight_path.read_text(encoding="utf-8"))
build_inputs_payload = json.loads(build_inputs_path.read_text(encoding="utf-8"))
data = {
    "schema_version": "qwendex.dev.codex_build.v1",
    "generated_at": datetime.now(UTC).isoformat(),
    "status": "pass",
    "source_ref": source_ref,
    "source_head": run("git", "-C", str(source_path), "rev-parse", "HEAD"),
    "source_ref_target": build_inputs_payload.get("source_ref_target"),
    "expected_source_commit": build_inputs_payload.get("expected_source_commit"),
    "source_origin": build_inputs_payload.get("source_origin"),
    "expected_source_origin": build_inputs_payload.get("expected_source_origin"),
    "source_patch_sha256": hashlib.sha256(source_diff).hexdigest(),
    "expected_source_patch_sha256": build_inputs_payload.get("expected_source_patch_sha256"),
    "source_tree_manifest_sha256": build_inputs_payload.get("source_tree_manifest_sha256"),
    "source_patch_paths": build_inputs_payload.get("changed_paths", []),
    "cargo_lock_sha256": build_inputs_payload.get("cargo_lock_sha256"),
    "expected_cargo_lock_sha256": build_inputs_payload.get("expected_cargo_lock_sha256"),
    "cargo_version": build_inputs_payload.get("cargo_version"),
    "rustc_version": build_inputs_payload.get("rustc_version"),
    "build_isolation": build_inputs_payload.get("build_isolation"),
    "cargo_home_policy": build_inputs_payload.get("cargo_home_policy"),
    "cargo_home_config_files": build_inputs_payload.get("cargo_home_config_files"),
    "project_cargo_config": build_inputs_payload.get("project_cargo_config"),
    "dependency_fetch_policy": build_inputs_payload.get("dependency_fetch_policy"),
    "build_inputs_sha256": sha256_file(build_inputs_path),
    "binary": str(binary_path),
    "binary_bytes": binary_path.stat().st_size,
    "binary_unstripped_bytes": int(codex_unstripped_bytes),
    "binary_sha256": sha256_file(binary_path),
    "binary_version": run(str(binary_path), "--version"),
    "code_mode_host": {
        "binary": str(code_mode_host_path),
        "binary_bytes": code_mode_host_path.stat().st_size,
        "binary_unstripped_bytes": int(code_mode_host_unstripped_bytes),
        "binary_sha256": sha256_file(code_mode_host_path),
    },
    "packaging": {
        "strip_tool": strip_tool,
        "strip_mode": "--strip-unneeded",
    },
    "preflight": {
        "path": str(preflight_path),
        "sha256": sha256_file(preflight_path),
        "status": preflight_payload.get("status"),
        "summary": preflight_payload.get("summary"),
    },
}
Path(out).write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")
print(f"codex-build: pass - {out}")
PY
      "$DEV_ROOT/scripts/qwendex" runtime build \
        --source-root "$DEV_ROOT" \
        --runtime-root "$QWENDEX_RUNTIME_ROOT" \
        --codex-bin "$DEV_CODEX_DEFAULT" \
        --code-mode-host "$DEV_CODE_MODE_HOST_DEFAULT" \
        --json > "$META_ROOT/runtime_generation_build.json"
      ;;
    *)
      die "unknown codex-source action: $action (expected sync|patch|build|preflight)"
      ;;
  esac
}

cmd_shell() {
  prepare
  # shellcheck disable=SC1090
  source "$WORK_ROOT/env.sh"
  cd "$DEV_ROOT"
  exec "${SHELL:-/bin/bash}"
}

cmd_open_with_mode() {
  local launch_mode="$1"
  shift
  prepare
  # shellcheck disable=SC1090
  source "$WORK_ROOT/env.sh"
  local qdex_args=(-C "$DEV_ROOT")
  if [[ "$launch_mode" == "yolo" ]]; then
    :
  else
    qdex_args=(--qdex-permission-mode workspace-write "${qdex_args[@]}")
  fi
  cd "$DEV_ROOT"
  "$HOME/.local/bin/qdex" "${qdex_args[@]}" "$@"
}

cmd_open() {
  cmd_open_with_mode workspace "$@"
}

cmd_open_yolo() {
  cmd_open_with_mode yolo "$@"
}

cmd_tools() {
  prepare
  "$HOME/.cargo/bin/cargo" --version
  "$HOME/.cargo/bin/rustfmt" --version
  "$QWENDEX_CODEX_RUNTIME" --version
}

cmd_diff() {
  prepare
  if dev_is_git_repo; then
    git -C "$DEV_ROOT" status --short
    git -C "$DEV_ROOT" diff --stat
  else
    local output_file="$META_ROOT/dev_to_source_rsync_diff.txt"
    rsync -ain --checksum --omit-dir-times "${MANAGED_RSYNC_EXCLUDES[@]}" "$DEV_ROOT/" "$SOURCE_ROOT/" > "$output_file"
    if [[ -s "$output_file" ]]; then
      cat "$output_file"
    else
      printf 'No promotable differences from %s to %s.\n' "$DEV_ROOT" "$SOURCE_ROOT"
    fi
  fi
}

cmd_export_to_source() {
  prepare
  local dry_run=0
  local delete=0
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --dry-run)
        dry_run=1
        ;;
      --delete)
        delete=1
        ;;
      *)
        die "unknown promote option: $1"
        ;;
    esac
    shift
  done

  local args=(-a --checksum --omit-dir-times)
  if [[ "$delete" -eq 1 ]]; then
    args+=(--delete)
  fi
  if [[ "$dry_run" -eq 1 ]]; then
    args+=(-n -i)
  fi

  rsync "${args[@]}" "${MANAGED_RSYNC_EXCLUDES[@]}" "$DEV_ROOT/" "$SOURCE_ROOT/"
  if [[ "$dry_run" -eq 1 ]]; then
    return
  fi
  printf 'Promoted managed dev changes from %s to %s.\n' "$DEV_ROOT" "$SOURCE_ROOT"
}

cmd_promote() {
  printf 'promote is a fallback export alias; normal worktree flow uses qwendex-dev stage.\n' >&2
  cmd_export_to_source "$@"
}

cmd_repair_copy() {
  prepare
  local force=0
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --force)
        force=1
        ;;
      *)
        die "unknown repair-copy option: $1"
        ;;
    esac
    shift
  done
  [[ "$force" -eq 1 ]] || die "repair-copy overwrites the dev tree; rerun with --force"
  sync_project
  prepare
  printf 'Repaired generated copy from %s to %s.\n' "$SOURCE_ROOT" "$DEV_ROOT"
}

cmd_lint() {
  prepare
  # shellcheck disable=SC1090
  source "$WORK_ROOT/env.sh"
  cd "$DEV_ROOT"
  python3 -m py_compile scripts/*.py scripts/local_qwen_bridge/*.py
  bash -n \
    scripts/qdex \
    scripts/qwendex \
    scripts/qwendex_dev_env \
    scripts/qwendex_install_deps \
    scripts/qwendex_testbench \
    scripts/llm \
    scripts/*.sh
  if python3 -m ruff --version >/dev/null 2>&1; then
    python3 -m ruff check scripts tests --ignore E501
  else
    printf 'ruff unavailable; skipped ruff check.\n'
  fi
}

cmd_test() {
  local scope="all"
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --quick|quick)
        scope="quick"
        ;;
      --all|all)
        scope="all"
        ;;
      *)
        die "unknown test scope: $1 (expected quick|all)"
        ;;
    esac
    shift
  done
  prepare
  # shellcheck disable=SC1090
  source "$WORK_ROOT/env.sh"
  cd "$DEV_ROOT"
  if [[ "$scope" == "quick" ]]; then
    python3 -m pytest -q \
      tests/smoke/test_qwendex_cli.py \
      tests/smoke/test_qwendex_performance.py
  else
    python3 -m pytest -q tests/smoke
  fi
}

cmd_verify() {
  prepare
  local tier="quick"
  local candidate=0
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --tier)
        tier="${2:-}"
        shift
        ;;
      --candidate)
        candidate=1
        ;;
      quick|full|live|release)
        tier="$1"
        ;;
      *)
        die "unknown verify option: $1"
        ;;
    esac
    shift
  done
  case "$tier" in
    quick|full|live|release) ;;
    *) die "unknown verify tier: $tier" ;;
  esac
  if [[ "$candidate" -eq 1 && "$tier" != "release" ]]; then
    die "--candidate is valid only with --tier release"
  fi

  local run_started_at
  local run_id
  local run_meta_root
  local run_results_root
  run_started_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  run_id="verify-${tier}-$(date -u +%Y%m%dT%H%M%SZ)-$$-${RANDOM}"
  run_meta_root="$META_ROOT/verify/$run_id"
  run_results_root="$RESULTS_ROOT/verify/$run_id"
  mkdir -p "$run_meta_root" "$run_results_root"
  local release_source_commit=""
  local release_source_tree=""
  if [[ "$tier" == "release" ]]; then
    release_source_commit="$(git -C "$DEV_ROOT" rev-parse HEAD)"
    release_source_tree="$(git -C "$DEV_ROOT" rev-parse 'HEAD^{tree}')"
  fi

  if [[ "$tier" == "release" ]]; then
    rm -f "$RELEASE_SUMMARY_JSON"
    run_logged_gate \
      "$run_meta_root/bootstrap_command.json" \
      bootstrap_command \
      "$run_id" \
      cmd_bootstrap --check --no-system
    require_json_pass "$BOOTSTRAP_JSON"
    cp "$BOOTSTRAP_JSON" "$run_meta_root/bootstrap.json"
    write_validated_codex_build_receipt "$run_meta_root/codex_build.json" "$run_id"
    bind_release_receipt \
      "$run_meta_root/bootstrap.json" "$run_id" bootstrap qwendex.bootstrap.check \
      "$release_source_commit" "$release_source_tree"
    bind_release_receipt \
      "$run_meta_root/codex_build.json" "$run_id" codex_build qwendex.codex.build.validate \
      "$release_source_commit" "$release_source_tree"
  fi

  run_logged_gate "$run_meta_root/static_gate.json" static "$run_id" cmd_lint
  if [[ "$tier" == "quick" ]]; then
    run_logged_gate "$run_meta_root/test_gate.json" tests_quick "$run_id" cmd_test --quick
  else
    run_logged_gate "$run_meta_root/test_gate.json" tests_full "$run_id" cmd_test --all
  fi
  if [[ "$tier" == "release" ]]; then
    bind_release_receipt \
      "$run_meta_root/static_gate.json" "$run_id" static_gate qwendex.static.full \
      "$release_source_commit" "$release_source_tree"
    bind_release_receipt \
      "$run_meta_root/test_gate.json" "$run_id" test_gate qwendex.tests.full \
      "$release_source_commit" "$release_source_tree"
  fi
  # shellcheck disable=SC1090
  source "$WORK_ROOT/env.sh"
  cd "$DEV_ROOT"
  local health_mode="advisory"
  if [[ "$tier" == "release" ]]; then
    health_mode="strict"
    local release_state_db="$WORK_ROOT/state/release_verify_qwendex.sqlite"
    rm -f "$release_state_db" "$release_state_db-shm" "$release_state_db-wal"
    export QWENDEX_STATE_DB="$release_state_db"
  fi
  scripts/qwendex check --health-mode "$health_mode" --json > "$run_meta_root/qwendex_check.json"
  scripts/qwendex doctor --health-mode "$health_mode" --json > "$run_meta_root/qwendex_doctor.json"
  scripts/qwendex codex-status --write "$STATUS_FILE" --json > "$run_meta_root/codex_status_write.json"
  local require_dev_codex=0
  if [[ "$tier" == "release" ]]; then
    require_dev_codex=1
  fi
  write_codex_patch_preflight_json "$run_meta_root/codex_patch_preflight.json" "$require_dev_codex"
  if [[ "$tier" == "release" ]]; then
    bind_release_receipt \
      "$run_meta_root/qwendex_check.json" "$run_id" qwendex_check qwendex.check.strict \
      "$release_source_commit" "$release_source_tree" strict
    bind_release_receipt \
      "$run_meta_root/qwendex_doctor.json" "$run_id" qwendex_doctor qwendex.doctor.strict \
      "$release_source_commit" "$release_source_tree" strict
    bind_release_receipt \
      "$run_meta_root/codex_status_write.json" "$run_id" codex_status qwendex.codex-status.write \
      "$release_source_commit" "$release_source_tree"
    bind_release_receipt \
      "$run_meta_root/codex_patch_preflight.json" "$run_id" codex_patch qwendex.codex-patch.preflight \
      "$release_source_commit" "$release_source_tree"
  fi
  if [[ "$tier" == "full" || "$tier" == "live" || "$tier" == "release" ]]; then
    run_logged_gate "$run_meta_root/config_gate.json" config_json "$run_id" cmd_validate_config_json
    scripts/qwendex eval --all --results-root "$run_results_root/qwendex_eval" --json > "$run_meta_root/qwendex_eval_all.json"
    scripts/llm harness-gate --json > "$run_meta_root/llm_harness_gate.json"
    python3 scripts/local_qwen_harness_eval.py \
      --all \
      --results-root "$run_results_root/llm_harness_eval" \
      --ledger-db "$LOCAL_HARNESS_LEDGER_DB" \
      --json > "$run_meta_root/llm_harness_eval_all.json"
    if [[ "$tier" == "release" ]]; then
      bind_release_receipt \
        "$run_meta_root/config_gate.json" "$run_id" config_gate qwendex.config.validate \
        "$release_source_commit" "$release_source_tree"
      bind_release_receipt \
        "$run_meta_root/qwendex_eval_all.json" "$run_id" qwendex_eval qwendex.eval.all \
        "$release_source_commit" "$release_source_tree"
      bind_release_receipt \
        "$run_meta_root/llm_harness_gate.json" "$run_id" harness_gate qwendex.harness.gate \
        "$release_source_commit" "$release_source_tree"
      bind_release_receipt \
        "$run_meta_root/llm_harness_eval_all.json" "$run_id" harness_eval qwendex.harness.eval.all \
        "$release_source_commit" "$release_source_tree"
    fi
  fi
  local release_require_live="${QWENDEX_RELEASE_REQUIRE_LIVE:-0}"
  if [[ "$tier" == "live" || ( "$tier" == "release" && "$release_require_live" =~ ^(1|true|yes|on)$ ) ]]; then
    run_logged_gate \
      "$run_meta_root/local_qwen_launcher_check.json" \
      live_launcher \
      "$run_id" \
      scripts/run_local_qwen_codex.sh --check
    python3 scripts/validate_local_qwen_reliability.py \
      --require-live-bridge \
      --json > "$run_meta_root/local_qwen_reliability.json"
    require_json_pass "$run_meta_root/local_qwen_reliability.json"
    local live_codex_bin="${QWENDEX_DEV_CODEX_BIN:-$DEV_CODEX_DEFAULT}"
    if [[ ! -x "$live_codex_bin" ]]; then
      live_codex_bin="$MAIN_CODEX_BIN"
    fi
    [[ -x "$live_codex_bin" ]] || die "live verification requires an executable Codex binary"
    python3 scripts/validate_local_qwen_codex_acceptance.py \
      --launcher "$DEV_ROOT/scripts/run_local_qwen_codex.sh" \
      --codex-bin "$live_codex_bin" \
      --workdir "$DEV_ROOT" \
      --fresh-home "$run_results_root/live/fresh-codex-home" \
      --normal-home "$run_results_root/live/normal-home-decoy" \
      --final-output "$run_results_root/live/final-message.txt" \
      --json > "$run_meta_root/local_qwen_codex_acceptance.json"
    require_json_pass "$run_meta_root/local_qwen_codex_acceptance.json"
    if [[ "$tier" == "release" ]]; then
      bind_release_receipt \
        "$run_meta_root/local_qwen_launcher_check.json" "$run_id" live_launcher qwendex.local-launcher.check \
        "$release_source_commit" "$release_source_tree"
      bind_release_receipt \
        "$run_meta_root/local_qwen_reliability.json" "$run_id" live_reliability qwendex.local-reliability.live \
        "$release_source_commit" "$release_source_tree"
      bind_release_receipt \
        "$run_meta_root/local_qwen_codex_acceptance.json" "$run_id" live_codex_acceptance qwendex.local-codex.fresh-home \
        "$release_source_commit" "$release_source_tree"
    fi
  fi
  write_dev_status_json "verify-$tier" >/dev/null
  cp "$DEV_STATUS_JSON" "$run_meta_root/dev_status.json"
  if [[ "$tier" == "release" ]]; then
    bind_release_receipt \
      "$run_meta_root/dev_status.json" "$run_id" dev_status qwendex.dev-status.release \
      "$release_source_commit" "$release_source_tree"
  fi

  local latest_name
  for latest_name in \
    qwendex_check.json \
    qwendex_doctor.json \
    codex_status_write.json \
    codex_patch_preflight.json \
    qwendex_eval_all.json \
    llm_harness_gate.json \
    llm_harness_eval_all.json; do
    if [[ -f "$run_meta_root/$latest_name" ]]; then
      cp "$run_meta_root/$latest_name" "$META_ROOT/$latest_name"
    fi
  done
  if [[ -f "$run_meta_root/local_qwen_launcher_check.log" ]]; then
    cp "$run_meta_root/local_qwen_launcher_check.log" "$META_ROOT/local_qwen_launcher_check.txt"
  fi

  local release_gate_rc=0
  if [[ "$tier" == "release" ]]; then
    local version
    version="$(python3 -c 'import json; print(json.load(open("config/qwendex/qwendex.json", encoding="utf-8"))["version"])')"
    local release_default_branch="${QWENDEX_RELEASE_DEFAULT_BRANCH:-main}"
    [[ -n "$release_default_branch" ]] || die "QWENDEX_RELEASE_DEFAULT_BRANCH must not be empty"
    local ci_attestation
    if [[ "$candidate" -eq 0 ]]; then
      # Publish-ready evidence is always fetched from the matching GitHub run.
      # A caller-supplied local JSON file is not an authority source.
      ci_attestation="$META_ROOT/qwendex-ci-attestation.json"
      refresh_ci_attestation "$release_source_commit" "$ci_attestation" "$release_default_branch"
      install -m 0600 \
        "$ci_attestation" \
        "$run_meta_root/qwendex-ci-attestation.json"
      ci_attestation="$run_meta_root/qwendex-ci-attestation.json"
    else
      ci_attestation="${QWENDEX_CI_ATTESTATION:-$META_ROOT/qwendex-ci-attestation.json}"
    fi
    local release_args=(
      --repo-root "$DEV_ROOT"
      --meta-root "$run_meta_root"
      --results-root "$run_results_root"
      --dev-status "$run_meta_root/dev_status.json"
      --output "$run_meta_root/release_validation_summary.json"
      --tier release
      --expected-version "$version"
      --expected-tag "v$version"
      --expected-codex-version "$QWENDEX_RELEASE_CODEX_VERSION"
      --run-id "$run_id"
      --run-started-at "$run_started_at"
      --default-branch "$release_default_branch"
    )
    if [[ -f "$ci_attestation" ]]; then
      release_args+=(--ci-attestation "$ci_attestation")
    fi
    if [[ -n "${QWENDEX_RELEASE_TRUSTED_ORIGIN:-}" ]]; then
      release_args+=(--trusted-origin "$QWENDEX_RELEASE_TRUSTED_ORIGIN")
    fi
    if [[ "$release_require_live" =~ ^(1|true|yes|on)$ ]]; then
      release_args+=(--require-live)
    fi
    if [[ "$candidate" -eq 1 ]]; then
      release_args+=(--candidate)
    fi
    python3 scripts/qwendex_release_gate.py "${release_args[@]}" || release_gate_rc=$?
    if [[ "$release_gate_rc" -eq 0 ]]; then
      local verify_summary_args=(
        verify-summary
        --summary "$run_meta_root/release_validation_summary.json"
        --repo-root "$DEV_ROOT"
      )
      if [[ "$candidate" -eq 0 ]]; then
        verify_summary_args+=(--require-publish-ready)
      fi
      python3 scripts/qwendex_release_gate.py "${verify_summary_args[@]}"
      cp "$run_meta_root/release_validation_summary.json" "$RELEASE_SUMMARY_JSON"
    fi
  fi
  summary_json \
    "$run_meta_root/qwendex_check.json" \
    "$run_meta_root/qwendex_doctor.json" \
    "$run_meta_root/codex_status_write.json" \
    "$run_meta_root/codex_patch_preflight.json"
  if [[ "$release_gate_rc" -ne 0 ]]; then
    return "$release_gate_rc"
  fi
}

cmd_snapshot() {
  prepare
  local stamp
  stamp="$(utc_stamp)"
  local snap="$WORK_ROOT/snapshots/$stamp"
  mkdir -p "$snap"
  write_dev_status_json snapshot >/dev/null
  cp "$DEV_STATUS_JSON" "$snap/dev_status.json"
  rsync -ain --checksum --omit-dir-times "${MANAGED_RSYNC_EXCLUDES[@]}" "$DEV_ROOT/" "$SOURCE_ROOT/" > "$snap/dev_to_source_rsync_diff.txt"
  if dev_is_git_repo; then
    git -C "$DEV_ROOT" status --short > "$snap/dev_git_status.txt"
    git -C "$DEV_ROOT" diff --stat > "$snap/dev_diff_stat.txt"
  fi
  if source_is_git_repo; then
    git -C "$SOURCE_ROOT" status --short > "$snap/source_git_status.txt"
    git -C "$SOURCE_ROOT" diff --stat > "$snap/source_diff_stat.txt"
  fi
  cp "$WORK_ROOT/env.sh" "$snap/env.sh"
  printf 'snapshot: %s\n' "$snap"
}

cmd_clean() {
  prepare
  find "$DEV_ROOT" \
    \( -path "$WORK_ROOT" -o -path "$DEV_ROOT/.git" \) -prune \
    -o \( -name '__pycache__' -o -name '.pytest_cache' -o -name '.ruff_cache' -o -name '.mypy_cache' \) \
    -print -exec rm -rf {} +
  printf 'Removed Python/tool caches outside %s.\n' "$WORK_ROOT"
}

cmd_stage() {
  local skip_verify=0
  local dry_run=0
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --skip-verify)
        skip_verify=1
        ;;
      --dry-run)
        dry_run=1
        ;;
      *)
        die "unknown stage option: $1"
        ;;
    esac
    shift
  done

  dev_is_git_repo || die "dev root is not a git repo: $DEV_ROOT"
  if [[ "$dry_run" -eq 1 ]]; then
    git -C "$DEV_ROOT" status --short
    return
  fi

  if [[ "$skip_verify" -eq 0 ]]; then
    cmd_verify --tier quick
  fi
  git -C "$DEV_ROOT" add -A "${MANAGED_GIT_PATHS[@]}"
  git -C "$DEV_ROOT" status --short
}

cmd_review() {
  prepare
  cmd_status
  printf '\nDev worktree changes:\n'
  cmd_diff
  if source_is_git_repo; then
    printf '\nCanonical source status:\n'
    git -C "$SOURCE_ROOT" status --short
  fi
  printf '\nLatest dev status:\n'
  write_dev_status_json review
}

usage() {
  cat <<EOF
Qwendex Dev Environment

Commands:
  scripts/qwendex_dev_env sync
  scripts/qwendex_dev_env bootstrap
  scripts/qwendex_dev_env env
  scripts/qwendex_dev_env status
  scripts/qwendex_dev_env status-json
  scripts/qwendex_dev_env doctor
  scripts/qwendex_dev_env review
  scripts/qwendex_dev_env diff
  scripts/qwendex_dev_env promote [--dry-run] [--delete]
  scripts/qwendex_dev_env export-to-source [--dry-run] [--delete]
  scripts/qwendex_dev_env repair-copy --force
  scripts/qwendex_dev_env stage [--dry-run] [--skip-verify]
  scripts/qwendex_dev_env lint
  scripts/qwendex_dev_env test [quick|all]
  scripts/qwendex_dev_env verify --tier quick|full|live|release [--candidate]
  scripts/qwendex_dev_env snapshot
  scripts/qwendex_dev_env clean
  scripts/qwendex_dev_env preflight
  scripts/qwendex_dev_env patch-codex [source]
  scripts/qwendex_dev_env codex-source sync|patch|build|preflight
  scripts/qwendex_dev_env runtime status|generations|build|activate|rollback|prune [options]
  scripts/qwendex_dev_env open [initial prompt...]
  scripts/qwendex_dev_env open-yolo [initial prompt...]
  scripts/qwendex_dev_env shell
  scripts/qwendex_dev_env tools

Default:
  scripts/qwendex_dev_env
      opens Codex in $DEV_ROOT with $QWENDEX_CODEX_YOLO_FLAG

Defaults:
  QWENDEX_DEV_ROOT=$DEV_ROOT
  QWENDEX_DEV_SOURCE_ROOT=$SOURCE_ROOT
EOF
}

if [[ "$#" -eq 0 ]]; then
  cmd_open_yolo
  exit
fi

case "$1" in
  sync)
    cmd_sync
    ;;
  bootstrap)
    shift
    cmd_bootstrap "$@"
    ;;
  env)
    cmd_env
    ;;
  status)
    cmd_status
    ;;
  status-json)
    cmd_status_json
    ;;
  doctor)
    cmd_doctor
    ;;
  review)
    cmd_review
    ;;
  diff)
    cmd_diff
    ;;
  promote)
    shift
    cmd_promote "$@"
    ;;
  export-to-source)
    shift
    cmd_export_to_source "$@"
    ;;
  repair-copy)
    shift
    cmd_repair_copy "$@"
    ;;
  stage)
    shift
    cmd_stage "$@"
    ;;
  lint)
    cmd_lint
    ;;
  test)
    shift
    cmd_test "$@"
    ;;
  verify)
    shift
    cmd_verify "$@"
    ;;
  snapshot)
    cmd_snapshot
    ;;
  clean)
    cmd_clean
    ;;
  preflight)
    cmd_preflight
    ;;
  patch-codex)
    shift
    cmd_patch_codex "$@"
    ;;
  codex-source)
    shift
    cmd_codex_source "$@"
    ;;
  runtime)
    shift
    cmd_runtime "$@"
    ;;
  open)
    shift
    cmd_open "$@"
    ;;
  open-yolo|yolo)
    shift
    cmd_open_yolo "$@"
    ;;
  shell)
    cmd_shell
    ;;
  tools)
    cmd_tools
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    usage >&2
    die "unknown command: $1"
    ;;
esac
