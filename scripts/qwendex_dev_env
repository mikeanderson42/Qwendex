#!/usr/bin/env bash
set -euo pipefail

SCRIPT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"
if [[ -f "$SCRIPT_ROOT/.qwendex-dev/source-root" ]]; then
  DEFAULT_SOURCE_ROOT="$(<"$SCRIPT_ROOT/.qwendex-dev/source-root")"
else
  DEFAULT_SOURCE_ROOT="$SCRIPT_ROOT"
fi

SOURCE_ROOT="${QWENDEX_DEV_SOURCE_ROOT:-$DEFAULT_SOURCE_ROOT}"
DEV_ROOT="${QWENDEX_DEV_ROOT:-$HOME/qwendex-dev}"
WORK_ROOT="$DEV_ROOT/.qwendex-dev"
STATE_DB="$WORK_ROOT/state/qwendex.sqlite"
RESULTS_ROOT="$WORK_ROOT/results/qwendex"
META_ROOT="$WORK_ROOT/results/meta"
CODEX_HOME_DIR="$WORK_ROOT/codex_home"
STATUS_FILE="$WORK_ROOT/codex_status.json"
LEDGER_DB="$WORK_ROOT/state/qwendex_ledger.sqlite"
LOCAL_HARNESS_LEDGER_DB="$WORK_ROOT/state/local_qwen_harness.sqlite"
BOOTSTRAP_JSON="$META_ROOT/bootstrap.json"
INSTALL_DEPS_JSON="$META_ROOT/install_deps.json"
DEV_STATUS_JSON="$META_ROOT/dev_status.json"
RELEASE_SUMMARY_JSON="$META_ROOT/release_validation_summary.json"
MAIN_CODEX_BIN="${QWENDEX_MAIN_CODEX_BIN:-$(command -v codex || true)}"
DEV_CODEX_DEFAULT="$WORK_ROOT/codex-build/bin/codex"
CODEX_SOURCE_DIR="$WORK_ROOT/codex-source/codex"
QWENDEX_CODEX_YOLO_FLAG="--dangerously-bypass-approvals-and-sandbox"
QWENDEX_CODEX_SOURCE_REPO="${QWENDEX_CODEX_SOURCE_REPO:-https://github.com/openai/codex.git}"
QWENDEX_CODEX_SOURCE_REF="${QWENDEX_CODEX_SOURCE_REF:-rust-v0.143.0}"
MANAGED_RSYNC_EXCLUDES=(
  --exclude '.git'
  --exclude '.git/'
  --exclude '.pytest_cache/'
  --exclude '.ruff_cache/'
  --exclude '.qwendex-dev/'
  --exclude 'results/'
  --exclude 'state/'
  --exclude '__pycache__/'
  --exclude '*.pyc'
  --exclude '/bin/'
  --exclude '/open.ps1'
)
MANAGED_GIT_PATHS=(
  .gitignore
  AGENTS.md
  QWENDEX_STARTUP.md
  README.md
  RELEASE.md
  .codex
  llmstack
  config
  docs
  public
  scripts
  tests
)

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

guard_dev_root() {
  [[ -n "$DEV_ROOT" ]] || die "QWENDEX_DEV_ROOT resolved to an empty path"
  [[ "$DEV_ROOT" != "/" ]] || die "refusing to use / as QWENDEX_DEV_ROOT"
  [[ "$DEV_ROOT" != "$HOME" ]] || die "refusing to use HOME as QWENDEX_DEV_ROOT"
}

ensure_layout() {
  guard_dev_root
  mkdir -p "$WORK_ROOT/state" "$RESULTS_ROOT" "$META_ROOT" "$CODEX_HOME_DIR/logs"
  mkdir -p "$WORK_ROOT/codex-source" "$WORK_ROOT/codex-build/bin" "$DEV_ROOT/bin"
}

sync_project() {
  guard_dev_root
  [[ -d "$SOURCE_ROOT" ]] || die "source root does not exist: $SOURCE_ROOT"
  if [[ "$(cd "$SOURCE_ROOT" && pwd)" == "$(mkdir -p "$DEV_ROOT" && cd "$DEV_ROOT" && pwd)" ]]; then
    die "source root and dev root are the same; set QWENDEX_DEV_SOURCE_ROOT to the tracked repo"
  fi
  rsync -a --delete \
    --omit-dir-times \
    "${MANAGED_RSYNC_EXCLUDES[@]}" \
    "$SOURCE_ROOT/" "$DEV_ROOT/"
}

source_is_git_repo() {
  git -C "$SOURCE_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

dev_is_git_repo() {
  git -C "$DEV_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

utc_stamp() {
  date -u +%Y%m%dT%H%M%SZ
}

write_codex_config() {
  cat > "$CODEX_HOME_DIR/config.toml" <<EOF
approval_policy = "never"
sandbox_mode = "workspace-write"
persistent_instructions = "Qwendex dev environment active. Act as the senior Qwendex product maintainer: keep changes scoped, verify before staging, use qwendex-dev doctor/verify/review/stage, protect public/private boundaries, and keep generated .qwendex-dev state out of public artifacts. QWENDEX_ROOT, QWENDEX_STATE_DB, QWENDEX_LEDGER_DB, QWENDEX_RESULTS_ROOT, QWENDEX_CODEX_STATUS_FILE, and QWENDEX_DEV_ROOT are set by the launcher. Use qwendex, qwendex-dev, and llmstack for harness controls. After context compaction, resume from the newest user request, re-run the Qwendex posture checks, and inspect existing diffs/state before editing; use qwendex-dev snapshot and scripts/qwendex context snapshot/reminder/compact-plan at phase boundaries or before manual compaction so the next session has objective, decisions, evidence, open files, blockers, and next actions. At the start of substantial tasks, check Agent Manager/Kaveman/Local state. When Agent Manager is in Manager Mode, use manager planning/preflight first. Spawn bounded subagents only when current tool policy, task shape, and write-surface separation make delegation safe; keep critical-path implementation local, avoid duplicate/conflicting writes, treat subagent output as advisory until integrated and verified, and close spawned agents and matching Qwendex manager sessions after integration. If subagents are not used, record or state the direct-work reason and validation path. When QWENDEX_CODEX_STATUS_FILE reports kaveman_enabled true, keep output terse and direct."

[features]
multi_agent = true

[projects."$DEV_ROOT"]
trust_level = "trusted"

[projects."$SOURCE_ROOT"]
trust_level = "trusted"
EOF

  if [[ -x "$DEV_CODEX_DEFAULT" || -n "${QWENDEX_DEV_CODEX_BIN:-}" ]]; then
    cat >> "$CODEX_HOME_DIR/config.toml" <<'EOF'

[tui]
status_line = ["model-with-reasoning", "current-dir", "qwendex-manager"]

[tui.keymap.global]
qwendex_toggle_manager = "alt-m"
qwendex_toggle_kaveman = "alt-k"
qwendex_toggle_local = "alt-l"
EOF
  fi

  cat > "$CODEX_HOME_DIR/patched-tui.example.toml" <<'EOF'
# Copy these sections into config.toml only after running a patched Codex build.
#
# [tui]
# status_line = ["model-with-reasoning", "current-dir", "qwendex-manager"]
#
# [tui.keymap.global]
# qwendex_toggle_manager = "alt-m"
# qwendex_toggle_kaveman = "alt-k"
# qwendex_toggle_local = "alt-l"
EOF
}

write_wrappers() {
  cat > "$DEV_ROOT/bin/qwendex" <<EOF
#!/usr/bin/env bash
exec "$DEV_ROOT/scripts/qwendex" "\$@"
EOF
  cat > "$DEV_ROOT/bin/llmstack" <<EOF
#!/usr/bin/env bash
exec "$DEV_ROOT/llmstack" "\$@"
EOF
  cat > "$DEV_ROOT/bin/qwendex-dev" <<EOF
#!/usr/bin/env bash
export QWENDEX_DEV_SOURCE_ROOT="$SOURCE_ROOT"
export QWENDEX_MAIN_CODEX_BIN="$MAIN_CODEX_BIN"
exec "$DEV_ROOT/scripts/qwendex_dev_env" "\$@"
EOF
  cat > "$DEV_ROOT/bin/codex-main" <<EOF
#!/usr/bin/env bash
if [[ ! -x "$MAIN_CODEX_BIN" ]]; then
  echo "main Codex fallback is not executable: $MAIN_CODEX_BIN" >&2
  exit 127
fi
exec "$MAIN_CODEX_BIN" "\$@"
EOF
  cat > "$DEV_ROOT/bin/codex" <<EOF
#!/usr/bin/env bash
dev_codex="\${QWENDEX_DEV_CODEX_BIN:-$DEV_CODEX_DEFAULT}"
if [[ -x "\$dev_codex" ]]; then
  exec "\$dev_codex" "\$@"
fi
if [[ ! -x "$MAIN_CODEX_BIN" ]]; then
  echo "no dev Codex binary found and main fallback is not executable: $MAIN_CODEX_BIN" >&2
  exit 127
fi
exec "$MAIN_CODEX_BIN" "\$@"
EOF
  if [[ -f "$DEV_ROOT/scripts/qdex" ]]; then
    mkdir -p "$HOME/.local/bin"
    install -m 0755 "$DEV_ROOT/scripts/qdex" "$HOME/.local/bin/qdex"
  fi
  cat > "$DEV_ROOT/open.ps1" <<'EOF'
[CmdletBinding()]
param(
    [Parameter(Position = 0, ValueFromRemainingArguments = $true)]
    [string[]]$Args = @()
)

$ErrorActionPreference = "Stop"
$script = Join-Path $PSScriptRoot "scripts/windows/open.ps1"
& $script -RepoDir $PSScriptRoot @Args
EOF
  chmod +x "$DEV_ROOT/bin/qwendex" "$DEV_ROOT/bin/llmstack" "$DEV_ROOT/bin/qwendex-dev" "$DEV_ROOT/bin/codex-main" "$DEV_ROOT/bin/codex"
}

write_env_files() {
  printf '%s\n' "$SOURCE_ROOT" > "$WORK_ROOT/source-root"
  cat > "$WORK_ROOT/env.sh" <<EOF
export QWENDEX_DEV_ROOT='$DEV_ROOT'
export QWENDEX_DEV_SOURCE_ROOT='$SOURCE_ROOT'
export QWENDEX_MAIN_CODEX_BIN='$MAIN_CODEX_BIN'
export QWENDEX_ROOT='$DEV_ROOT'
export QWENDEX_STATE_DB='$STATE_DB'
export QWENDEX_LEDGER_DB='$LEDGER_DB'
export QWENDEX_RESULTS_ROOT='$RESULTS_ROOT'
export QWENDEX_META_ROOT='$META_ROOT'
export QWENDEX_CODEX_STATUS_FILE='$STATUS_FILE'
export QWENDEX_EXEC_CWD='$DEV_ROOT'
export QWENDEX_MCP_TRUSTED_ROOTS='$DEV_ROOT:$SOURCE_ROOT'
export CODEX_HOME='$CODEX_HOME_DIR'
export LOCAL_QWEN_CODEX_CWD='$DEV_ROOT'
export LOCAL_QWEN_CODEX_ADD_DIRS='$DEV_ROOT:$SOURCE_ROOT'
export LOCAL_QWEN_CANONICAL_LAUNCHER='$DEV_ROOT/scripts/run_local_qwen_codex.sh'
export LOCAL_QWEN_MODEL_CATALOG_JSON='$DEV_ROOT/config/local_llm_stack/qwen_local_model_catalog.json'
export LOCAL_QWEN_LOCAL_HARNESS_MCP='$DEV_ROOT/scripts/artifact_queue_mcp.py'
export LOCAL_QWEN_LOCAL_HARNESS_TRUSTED_ROOTS='$DEV_ROOT:$SOURCE_ROOT'
export LOCAL_QWEN_HARNESS_LEDGER_DB='$LOCAL_HARNESS_LEDGER_DB'
export PATH='$HOME/.local/bin':'$HOME/.cargo/bin':'$DEV_ROOT/bin':'$DEV_ROOT':'$DEV_ROOT/scripts':"\$PATH"
EOF
  cat > "$WORK_ROOT/README.md" <<EOF
# Qwendex Dev Environment

This folder is generated by \`scripts/qwendex_dev_env\`.

- Dev root: \`$DEV_ROOT\`
- Source root: \`$SOURCE_ROOT\`
- State DB: \`$STATE_DB\`
- Receipt ledger: \`$LEDGER_DB\`
- Local harness ledger: \`$LOCAL_HARNESS_LEDGER_DB\`
- Results: \`$RESULTS_ROOT\`
- Codex home: \`$CODEX_HOME_DIR\`
- Status file: \`$STATUS_FILE\`
- Main Codex fallback: \`$MAIN_CODEX_BIN\`

Use:

\`\`\`bash
source "$WORK_ROOT/env.sh"
qwendex-dev
qwendex-dev open
\`\`\`

Bare \`qwendex-dev\` opens Codex in \`$DEV_ROOT\` with the current Codex
yolo-equivalent flag: \`$QWENDEX_CODEX_YOLO_FLAG\`.

Developer workflow:

\`\`\`bash
qwendex-dev review
qwendex-dev verify --tier full
qwendex-dev diff
qwendex-dev stage
qwendex-dev snapshot
\`\`\`

The \`codex\` wrapper first uses \`QWENDEX_DEV_CODEX_BIN\` or
\`$DEV_CODEX_DEFAULT\` when present, then falls back to the main Codex binary.
EOF
}

link_codex_identity() {
  if [[ -d "$HOME/.codex/mcp-servers" && ! -e "$CODEX_HOME_DIR/mcp-servers" ]]; then
    ln -s "$HOME/.codex/mcp-servers" "$CODEX_HOME_DIR/mcp-servers"
  fi
  if [[ -f "$HOME/.codex/auth.json" && ! -e "$CODEX_HOME_DIR/auth.json" ]]; then
    ln -s "$HOME/.codex/auth.json" "$CODEX_HOME_DIR/auth.json"
  fi
  if [[ -f "$HOME/.codex/version.json" && ! -e "$CODEX_HOME_DIR/version.json" ]]; then
    ln -s "$HOME/.codex/version.json" "$CODEX_HOME_DIR/version.json"
  fi
  if [[ -f "$HOME/.codex/installation_id" && ! -e "$CODEX_HOME_DIR/installation_id" ]]; then
    cp "$HOME/.codex/installation_id" "$CODEX_HOME_DIR/installation_id"
  fi
}

prepare() {
  ensure_layout
  write_codex_config
  write_wrappers
  write_env_files
  link_codex_identity
}

summary_json() {
  python3 - "$@" <<'PY'
import json
import sys
from pathlib import Path

for raw in sys.argv[1:]:
    path = Path(raw)
    if not path.is_file():
        print(f"{path}: missing")
        continue
    data = json.loads(path.read_text(encoding="utf-8"))
    print(f"{data.get('command', path.name)}: {data.get('status')} - {data.get('summary')}")
PY
}

write_bootstrap_json() {
  python3 - "$BOOTSTRAP_JSON" "$INSTALL_DEPS_JSON" "$DEV_ROOT" "$SOURCE_ROOT" "$WORK_ROOT" "$MAIN_CODEX_BIN" "$DEV_CODEX_DEFAULT" <<'PY'
import json
import shutil
import subprocess
import sys
from datetime import UTC, datetime
from pathlib import Path

out, install_deps, dev_root, source_root, work_root, main_codex, dev_codex = map(Path, sys.argv[1:8])

def version(cmd):
    exe = shutil.which(cmd) or (str(cmd) if Path(cmd).exists() else "")
    if not exe:
        return {"available": False, "path": "", "version": ""}
    try:
        args = [exe, "-V"] if Path(exe).name == "tmux" else [exe, "--version"]
        result = subprocess.run(args, text=True, capture_output=True, timeout=15, check=False)
        raw = (result.stdout or result.stderr).strip().splitlines()[0] if (result.stdout or result.stderr).strip() else ""
        return {"available": result.returncode == 0, "path": exe, "version": raw, "returncode": result.returncode}
    except Exception as exc:
        return {"available": False, "path": exe, "version": "", "error": str(exc)}

tools = {name: version(name) for name in ("python3", "git", "rsync", "tmux", "codex", "cargo", "rustfmt")}
tools["codex-main"] = version(str(main_codex))
tools["codex-dev"] = version(str(dev_codex))
data = {
    "schema_version": "qwendex.dev.bootstrap.v1",
    "generated_at": datetime.now(UTC).isoformat(),
    "dev_root": str(dev_root),
    "source_root": str(source_root),
    "work_root": str(work_root),
    "install_deps_receipt": str(install_deps),
    "tools": tools,
    "missing_required": [name for name in ("python3", "git", "rsync", "codex") if not tools[name]["available"]],
    "missing_optional": [name for name in ("tmux", "cargo", "rustfmt") if not tools[name]["available"]],
}
if install_deps.is_file():
    try:
        data["install_deps"] = json.loads(install_deps.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        data["install_deps"] = {"status": "blocked", "error": str(exc)}
else:
    data["install_deps"] = {"status": "missing"}
data["status"] = "pass" if not data["missing_required"] and data["install_deps"].get("status") == "pass" else "blocked"
out.parent.mkdir(parents=True, exist_ok=True)
out.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")
print(f"bootstrap: {data['status']} - {out}")
PY
}

write_dev_status_json() {
  local mode="${1:-status}"
  python3 - "$DEV_STATUS_JSON" "$mode" "$DEV_ROOT" "$SOURCE_ROOT" "$WORK_ROOT" "$STATE_DB" "$LEDGER_DB" "$LOCAL_HARNESS_LEDGER_DB" "$RESULTS_ROOT" "$STATUS_FILE" "$CODEX_SOURCE_DIR" "$DEV_CODEX_DEFAULT" "$MAIN_CODEX_BIN" <<'PY'
import json
import os
import shutil
import subprocess
import sys
from datetime import UTC, datetime
from pathlib import Path

(
    out,
    mode,
    dev_root,
    source_root,
    work_root,
    state_db,
    ledger_db,
    local_ledger_db,
    results_root,
    status_file,
    codex_source,
    dev_codex,
    main_codex,
) = sys.argv[1:14]
out = Path(out)
paths = {k: Path(v) for k, v in {
    "dev_root": dev_root,
    "source_root": source_root,
    "work_root": work_root,
    "state_db": state_db,
    "ledger_db": ledger_db,
    "local_harness_ledger_db": local_ledger_db,
    "results_root": results_root,
    "status_file": status_file,
    "codex_source": codex_source,
    "dev_codex": dev_codex,
    "main_codex": main_codex,
}.items()}

def run(cmd, cwd=None):
    try:
        result = subprocess.run(cmd, cwd=cwd, text=True, capture_output=True, timeout=20, check=False)
        return {"returncode": result.returncode, "stdout": result.stdout.strip(), "stderr": result.stderr.strip()}
    except Exception as exc:
        return {"returncode": 127, "stdout": "", "stderr": str(exc)}

def hook_source(path, scope):
    exists = path.is_file()
    events = []
    if exists:
        try:
            payload = json.loads(path.read_text(encoding="utf-8"))
            hooks = payload.get("hooks") if isinstance(payload, dict) else None
            if isinstance(hooks, dict):
                events = sorted(str(key) for key in hooks)
            elif isinstance(payload, dict):
                events = sorted(str(key) for key in payload if str(key).lower().endswith("hook"))
        except Exception:
            events = []
    return {
        "scope": scope,
        "path": str(path),
        "exists": exists,
        "events": events,
        "bytes": path.stat().st_size if exists else 0,
    }

def under(path, root):
    try:
        path.resolve().relative_to(root.resolve())
        return True
    except Exception:
        return False

dev_git = run(["git", "rev-parse", "--abbrev-ref", "HEAD"], cwd=paths["dev_root"])
source_git = run(["git", "rev-parse", "--abbrev-ref", "HEAD"], cwd=paths["source_root"])
dev_status = run(["git", "status", "--short"], cwd=paths["dev_root"])
source_status = run(["git", "status", "--short"], cwd=paths["source_root"])
tools = {name: bool(shutil.which(name)) for name in ("python3", "git", "rsync", "codex", "cargo", "rustfmt", "tmux")}
state_isolation = {
    "state_db_under_work_root": under(paths["state_db"], paths["work_root"]),
    "ledger_db_under_work_root": under(paths["ledger_db"], paths["work_root"]),
    "local_harness_ledger_db_under_work_root": under(paths["local_harness_ledger_db"], paths["work_root"]),
    "results_under_work_root": under(paths["results_root"], paths["work_root"]),
}
active_codex_home = paths["work_root"] / "codex_home"
active_hook_sources = [
    hook_source(active_codex_home / "hooks.json", "active-codex-home"),
    hook_source(paths["dev_root"] / ".codex" / "hooks.json", "project"),
    hook_source(paths["dev_root"] / "hooks" / "hooks.json", "project"),
]
global_hook_sources = [hook_source(Path.home() / ".codex" / "hooks.json", "global")]
active_hook_sources = [source for source in active_hook_sources if source["exists"]]
global_hook_sources = [source for source in global_hook_sources if source["exists"]]
data = {
    "schema_version": "qwendex.dev.status.v1",
    "generated_at": datetime.now(UTC).isoformat(),
    "mode": mode,
    "roots": {k: str(v) for k, v in paths.items()},
    "git": {
        "dev_branch": dev_git["stdout"],
        "source_branch": source_git["stdout"],
        "dev_status": dev_status["stdout"].splitlines(),
        "source_status": source_status["stdout"].splitlines(),
        "dev_is_worktree": (paths["dev_root"] / ".git").exists(),
    },
    "tools": tools,
    "state_isolation": state_isolation,
    "codex": {
        "dev_binary_exists": paths["dev_codex"].is_file(),
        "main_binary_exists": paths["main_codex"].is_file(),
        "source_exists": paths["codex_source"].is_dir(),
        "active_codex_home": str(active_codex_home),
        "hook_sources": active_hook_sources,
        "hook_source_count": len(active_hook_sources),
        "global_hook_sources": global_hook_sources,
        "global_hook_source_count": len(global_hook_sources),
    },
    "latest_receipts": sorted(str(p) for p in paths["results_root"].glob("**/*.json"))[-20:] if paths["results_root"].exists() else [],
}
blockers = []
warnings = []
if not all(state_isolation.values()):
    blockers.append("state paths are not fully isolated under .qwendex-dev")
if not data["git"]["dev_is_worktree"]:
    blockers.append("dev root is not a git worktree")
if not tools["python3"] or not tools["git"] or not tools["codex"]:
    blockers.append("required tool missing")
if not active_hook_sources and global_hook_sources:
    warnings.append("active dev CODEX_HOME has no hooks while ~/.codex has hooks")
data["blockers"] = blockers
data["warnings"] = warnings
data["status"] = "pass" if not blockers else "blocked"
out.parent.mkdir(parents=True, exist_ok=True)
out.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")
print(f"status-json: {data['status']} - {out}")
PY
}

write_release_summary_json() {
  local tier="${1:-release}"
  python3 - "$RELEASE_SUMMARY_JSON" "$tier" "$DEV_STATUS_JSON" "$META_ROOT" "$RESULTS_ROOT" <<'PY'
import json
import re
import sys
from collections import Counter
from datetime import UTC, datetime
from pathlib import Path

out = Path(sys.argv[1])
tier = sys.argv[2]
status_path = Path(sys.argv[3])
meta_root = Path(sys.argv[4])
results_root = Path(sys.argv[5])
markers = (
    "LOCAL_MODEL_TOOL_CALL_TOO_LARGE",
    "LOCAL_MODEL_TOOL_CALL_TRUNCATED",
    "LOCAL_MODEL_TOOL_MARKUP_SUPPRESSED",
    "LOCAL_MODEL_LOOP_DETECTED",
    "QWENDEX_TIMEOUT",
)
counts = Counter()
contract_counts = Counter()
expected_counts = Counter()
unexpected_counts = Counter()
marker_regex = re.compile("|".join(re.escape(marker) for marker in markers))
expected_marker_cases = {
    "failed_validator_recovery",
    "malformed_tool_envelope_suppression",
    "oversized_generated_command_recovery",
    "local_model_unavailable_fallback",
    "fresh_home_ab_probe",
}
contract_marker_files = {
    "llmstack_check.json",
}


def marker_hits(text):
    return Counter(marker_regex.findall(text))


def is_marker_name_metadata_path(path):
    parts = tuple(str(part) for part in path)
    return parts[-3:] == ("effective_policy", "guard", "markers")


def json_marker_hits(value, path=(), *, skip_marker_name_metadata=True):
    hits = Counter()
    if skip_marker_name_metadata and is_marker_name_metadata_path(path):
        return hits
    if isinstance(value, dict):
        for key, child in value.items():
            hits.update(marker_hits(str(key)))
            hits.update(
                json_marker_hits(
                    child,
                    (*path, str(key)),
                    skip_marker_name_metadata=skip_marker_name_metadata,
                )
            )
    elif isinstance(value, list):
        for child in value:
            hits.update(
                json_marker_hits(
                    child,
                    path,
                    skip_marker_name_metadata=skip_marker_name_metadata,
                )
            )
    elif isinstance(value, str):
        hits.update(marker_hits(value))
    return hits


def path_marker_hits(path, text, *, contract):
    if path.suffix == ".json":
        try:
            return json_marker_hits(
                json.loads(text),
                skip_marker_name_metadata=not contract,
            )
        except json.JSONDecodeError:
            pass
    return marker_hits(text)


for root in (meta_root, results_root):
    if root.exists():
        for path in root.rglob("*"):
            if path.resolve() == out.resolve():
                continue
            if path.is_file() and path.stat().st_size <= 5_000_000:
                text = path.read_text(encoding="utf-8", errors="replace")
                expected = any(case in path.name or case in str(path.parent) for case in expected_marker_cases)
                contract = path.name in contract_marker_files
                path_hits = path_marker_hits(path, text, contract=contract)
                for marker, hits in path_hits.items():
                    counts[marker] += hits
                    if hits and contract:
                        contract_counts[marker] += hits
                    elif hits and expected:
                        expected_counts[marker] += hits
                    elif hits:
                        unexpected_counts[marker] += hits
status = json.loads(status_path.read_text(encoding="utf-8")) if status_path.exists() else {}
blockers = list(status.get("blockers") or [])
if any(unexpected_counts[m] for m in markers[:4]):
    blockers.append("release marker scan found unexpected local-model guard markers")
data = {
    "schema_version": "qwendex.dev.release_summary.v1",
    "generated_at": datetime.now(UTC).isoformat(),
    "tier": tier,
    "status": "pass" if not blockers else "blocked",
    "recommendation": "publish-ready" if not blockers else "blocked",
    "blockers": blockers,
    "marker_counts": dict(counts),
    "contract_marker_counts": dict(contract_counts),
    "expected_marker_counts": dict(expected_counts),
    "unexpected_marker_counts": dict(unexpected_counts),
    "dev_status_path": str(status_path),
    "meta_root": str(meta_root),
    "results_root": str(results_root),
}
out.parent.mkdir(parents=True, exist_ok=True)
out.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")
print(f"release-summary: {data['status']} - {out}")
PY
}

cmd_env() {
  prepare
  cat "$WORK_ROOT/env.sh"
}

cmd_sync() {
  if ! dev_is_git_repo; then
    sync_project
  fi
  prepare
  "$DEV_ROOT/scripts/qwendex" codex-status --write "$STATUS_FILE" --json > "$META_ROOT/codex_status_write.json"
  write_dev_status_json sync >/dev/null
  printf 'Qwendex dev root ready: %s\n' "$DEV_ROOT"
  printf 'Load env with: source %s\n' "$WORK_ROOT/env.sh"
}

cmd_bootstrap() {
  local install=1
  local system=1
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --check|--check-only|--no-install)
        install=0
        ;;
      --no-system)
        system=0
        ;;
      --install-system)
        system=1
        ;;
      *)
        die "unknown bootstrap option: $1"
        ;;
    esac
    shift
  done
  prepare
  if [[ "$install" -eq 1 ]]; then
    local install_args=(--install --json)
    if [[ "$system" -eq 0 ]]; then
      install_args+=(--no-system)
    fi
    "$DEV_ROOT/scripts/qwendex_install_deps" "${install_args[@]}" > "$INSTALL_DEPS_JSON" || true
  else
    "$DEV_ROOT/scripts/qwendex_install_deps" --check --json > "$INSTALL_DEPS_JSON" || true
  fi
  if ! command -v cargo >/dev/null 2>&1 && [[ -x "$HOME/.cargo/bin/cargo" ]]; then
    export PATH="$HOME/.cargo/bin:$PATH"
  fi
  if command -v rustup >/dev/null 2>&1 && ! command -v rustfmt >/dev/null 2>&1; then
    rustup component add rustfmt >/dev/null
  fi
  write_bootstrap_json
  write_dev_status_json bootstrap >/dev/null
}

cmd_status() {
  prepare
  "$DEV_ROOT/scripts/qwendex" check --json > "$META_ROOT/qwendex_check.json"
  "$DEV_ROOT/scripts/qwendex" codex-status --write "$STATUS_FILE" --json > "$META_ROOT/codex_status_write.json"
  write_codex_patch_preflight_json
  write_dev_status_json status >/dev/null
  summary_json "$META_ROOT/qwendex_check.json" "$META_ROOT/codex_status_write.json" "$META_ROOT/codex_patch_preflight.json"
}

cmd_doctor() {
  prepare
  "$DEV_ROOT/scripts/qwendex" check --json > "$META_ROOT/qwendex_check.json"
  "$DEV_ROOT/scripts/qwendex" doctor --json > "$META_ROOT/qwendex_doctor.json"
  "$DEV_ROOT/scripts/qwendex" llmstack check --json > "$META_ROOT/llmstack_check.json"
  "$DEV_ROOT/scripts/qwendex" codex-status --write "$STATUS_FILE" --json > "$META_ROOT/codex_status_write.json"
  write_codex_patch_preflight_json
  write_dev_status_json doctor
  summary_json \
    "$META_ROOT/qwendex_check.json" \
    "$META_ROOT/qwendex_doctor.json" \
    "$META_ROOT/llmstack_check.json" \
    "$META_ROOT/codex_status_write.json" \
    "$META_ROOT/codex_patch_preflight.json"
}

cmd_status_json() {
  prepare
  write_dev_status_json status
}

cmd_preflight() {
  prepare
  "$DEV_ROOT/scripts/qwendex" codex-status --write "$STATUS_FILE" --json > "$META_ROOT/codex_status_write.json"
  write_codex_patch_preflight_json
  write_dev_status_json preflight >/dev/null
  summary_json "$META_ROOT/codex_status_write.json" "$META_ROOT/codex_patch_preflight.json"
}

write_codex_patch_preflight_json() {
  if [[ -d "$CODEX_SOURCE_DIR" ]]; then
    "$DEV_ROOT/scripts/qwendex" codex-patch preflight --source "$CODEX_SOURCE_DIR" --require-applied --json > "$META_ROOT/codex_patch_preflight.json"
  else
    "$DEV_ROOT/scripts/qwendex" codex-patch preflight --json > "$META_ROOT/codex_patch_preflight.json"
  fi
}

cmd_patch_codex() {
  prepare
  local source="${1:-$WORK_ROOT/codex-source/codex}"
  "$DEV_ROOT/scripts/qwendex" codex-patch apply --source "$source" --json
}

cmd_codex_source() {
  prepare
  local action="${1:-preflight}"
  shift || true
  case "$action" in
    sync)
      if [[ -d "$CODEX_SOURCE_DIR/.git" ]]; then
        git -C "$CODEX_SOURCE_DIR" fetch --tags --depth 1 origin "$QWENDEX_CODEX_SOURCE_REF"
        git -C "$CODEX_SOURCE_DIR" checkout FETCH_HEAD
      else
        rm -rf "$CODEX_SOURCE_DIR"
        git clone --depth 1 --branch "$QWENDEX_CODEX_SOURCE_REF" "$QWENDEX_CODEX_SOURCE_REPO" "$CODEX_SOURCE_DIR"
      fi
      "$DEV_ROOT/scripts/qwendex" codex-patch preflight --source "$CODEX_SOURCE_DIR" --json
      ;;
    patch)
      [[ -d "$CODEX_SOURCE_DIR" ]] || die "missing Codex source: run qwendex-dev codex-source sync"
      "$DEV_ROOT/scripts/qwendex" codex-patch apply --source "$CODEX_SOURCE_DIR" --json
      "$DEV_ROOT/scripts/qwendex" codex-patch preflight --source "$CODEX_SOURCE_DIR" --require-applied --json > "$META_ROOT/codex_source_preflight.json"
      ;;
    preflight)
      [[ -d "$CODEX_SOURCE_DIR" ]] || die "missing Codex source: run qwendex-dev codex-source sync"
      "$DEV_ROOT/scripts/qwendex" codex-patch preflight --source "$CODEX_SOURCE_DIR" --require-applied --json
      ;;
    build)
      [[ -d "$CODEX_SOURCE_DIR/codex-rs" ]] || die "missing Codex Rust source: run qwendex-dev codex-source sync"
      (cd "$CODEX_SOURCE_DIR/codex-rs" && cargo build --release -p codex-cli --bin codex)
      mkdir -p "$(dirname "$DEV_CODEX_DEFAULT")"
      local tmp_codex
      tmp_codex="$(mktemp "$(dirname "$DEV_CODEX_DEFAULT")/.codex.XXXXXX")"
      cp "$CODEX_SOURCE_DIR/codex-rs/target/release/codex" "$tmp_codex"
      chmod +x "$tmp_codex"
      mv -f "$tmp_codex" "$DEV_CODEX_DEFAULT"
      "$DEV_CODEX_DEFAULT" --version
      ;;
    *)
      die "unknown codex-source action: $action (expected sync|patch|build|preflight)"
      ;;
  esac
}

cmd_shell() {
  prepare
  # shellcheck disable=SC1090
  source "$WORK_ROOT/env.sh"
  cd "$DEV_ROOT"
  exec "${SHELL:-/bin/bash}"
}

cmd_open_with_mode() {
  local launch_mode="$1"
  shift
  prepare
  # shellcheck disable=SC1090
  source "$WORK_ROOT/env.sh"
  "$DEV_ROOT/scripts/qwendex" codex-status --write "$STATUS_FILE" --json > "$META_ROOT/codex_status_write.json"
  local codex_args=(--no-alt-screen)
  if [[ "$launch_mode" == "yolo" ]]; then
    codex_args+=("$QWENDEX_CODEX_YOLO_FLAG")
  else
    codex_args+=(--sandbox workspace-write)
  fi
  codex_args+=(-C "$DEV_ROOT")
  cd "$DEV_ROOT"
  "$DEV_ROOT/bin/codex" "${codex_args[@]}" "$@"
}

cmd_open() {
  cmd_open_with_mode workspace "$@"
}

cmd_open_yolo() {
  cmd_open_with_mode yolo "$@"
}

cmd_tools() {
  prepare
  "$HOME/.cargo/bin/cargo" --version
  "$HOME/.cargo/bin/rustfmt" --version
  "$DEV_ROOT/bin/codex" --version
}

cmd_diff() {
  prepare
  if dev_is_git_repo; then
    git -C "$DEV_ROOT" status --short
    git -C "$DEV_ROOT" diff --stat
  else
    local output_file="$META_ROOT/dev_to_source_rsync_diff.txt"
    rsync -ain --checksum --omit-dir-times "${MANAGED_RSYNC_EXCLUDES[@]}" "$DEV_ROOT/" "$SOURCE_ROOT/" > "$output_file"
    if [[ -s "$output_file" ]]; then
      cat "$output_file"
    else
      printf 'No promotable differences from %s to %s.\n' "$DEV_ROOT" "$SOURCE_ROOT"
    fi
  fi
}

cmd_export_to_source() {
  prepare
  local dry_run=0
  local delete=0
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --dry-run)
        dry_run=1
        ;;
      --delete)
        delete=1
        ;;
      *)
        die "unknown promote option: $1"
        ;;
    esac
    shift
  done

  local args=(-a --checksum --omit-dir-times)
  if [[ "$delete" -eq 1 ]]; then
    args+=(--delete)
  fi
  if [[ "$dry_run" -eq 1 ]]; then
    args+=(-n -i)
  fi

  rsync "${args[@]}" "${MANAGED_RSYNC_EXCLUDES[@]}" "$DEV_ROOT/" "$SOURCE_ROOT/"
  if [[ "$dry_run" -eq 1 ]]; then
    return
  fi
  printf 'Promoted managed dev changes from %s to %s.\n' "$DEV_ROOT" "$SOURCE_ROOT"
}

cmd_promote() {
  printf 'promote is a fallback export alias; normal worktree flow uses qwendex-dev stage.\n' >&2
  cmd_export_to_source "$@"
}

cmd_repair_copy() {
  prepare
  local force=0
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --force)
        force=1
        ;;
      *)
        die "unknown repair-copy option: $1"
        ;;
    esac
    shift
  done
  [[ "$force" -eq 1 ]] || die "repair-copy overwrites the dev tree; rerun with --force"
  sync_project
  prepare
  printf 'Repaired generated copy from %s to %s.\n' "$SOURCE_ROOT" "$DEV_ROOT"
}

cmd_lint() {
  prepare
  # shellcheck disable=SC1090
  source "$WORK_ROOT/env.sh"
  cd "$DEV_ROOT"
  python3 -m py_compile scripts/qwendex_cli.py tests/smoke/test_qwendex_cli.py scripts/local_qwen_bridge/*.py
  bash -n scripts/qwendex_dev_env scripts/qwendex_testbench scripts/run_local_qwen_codex.sh
  if python3 -m ruff --version >/dev/null 2>&1; then
    python3 -m ruff check scripts/qwendex_cli.py tests/smoke/test_qwendex_cli.py --ignore E501
  else
    printf 'ruff unavailable; skipped ruff check.\n'
  fi
}

cmd_test() {
  prepare
  # shellcheck disable=SC1090
  source "$WORK_ROOT/env.sh"
  cd "$DEV_ROOT"
  python3 -m pytest -q tests/smoke/test_qwendex_cli.py
}

cmd_verify() {
  prepare
  local tier="quick"
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --tier)
        tier="${2:-}"
        shift
        ;;
      quick|full|live|release)
        tier="$1"
        ;;
      *)
        die "unknown verify option: $1"
        ;;
    esac
    shift
  done
  case "$tier" in
    quick|full|live|release) ;;
    *) die "unknown verify tier: $tier" ;;
  esac

  cmd_lint
  cmd_test
  # shellcheck disable=SC1090
  source "$WORK_ROOT/env.sh"
  cd "$DEV_ROOT"
  local health_mode="advisory"
  if [[ "$tier" == "release" ]]; then
    health_mode="strict"
    local release_state_db="$WORK_ROOT/state/release_verify_qwendex.sqlite"
    rm -f "$release_state_db" "$release_state_db-shm" "$release_state_db-wal"
    export QWENDEX_STATE_DB="$release_state_db"
  fi
  scripts/qwendex check --health-mode "$health_mode" --json > "$META_ROOT/qwendex_check.json"
  scripts/qwendex doctor --health-mode "$health_mode" --json > "$META_ROOT/qwendex_doctor.json"
  scripts/qwendex codex-status --write "$STATUS_FILE" --json > "$META_ROOT/codex_status_write.json"
  scripts/qwendex codex-patch preflight --json > "$META_ROOT/codex_patch_preflight.json"
  if [[ "$tier" == "full" || "$tier" == "live" || "$tier" == "release" ]]; then
    python3 -m json.tool config/qwendex/qwendex.json >/dev/null
    python3 -m json.tool config/qwendex/model-catalog.json >/dev/null
    python3 -m json.tool config/qwendex/profiles.json >/dev/null
    local stamp
    stamp="$(utc_stamp)"
    scripts/qwendex eval --all --results-root "$RESULTS_ROOT/qwendex_eval_$stamp" --json > "$META_ROOT/qwendex_eval_all.json"
    scripts/llm harness-gate --json > "$META_ROOT/llm_harness_gate.json" || true
    python3 scripts/local_qwen_harness_eval.py --all --results-root "$RESULTS_ROOT/llm_harness_eval_$stamp" --ledger-db "$LOCAL_HARNESS_LEDGER_DB" --json > "$META_ROOT/llm_harness_eval_all.json"
  fi
  local release_require_live="${QWENDEX_RELEASE_REQUIRE_LIVE:-0}"
  if [[ "$tier" == "live" || ( "$tier" == "release" && "$release_require_live" =~ ^(1|true|yes|on)$ ) ]]; then
    scripts/run_local_qwen_codex.sh --check > "$META_ROOT/local_qwen_launcher_check.txt"
  elif [[ "$tier" == "release" ]]; then
    printf 'skipped: local stack live check is separate; run qwendex-dev verify --tier live when intentionally running it.\n' > "$META_ROOT/local_qwen_launcher_check.txt"
  fi
  write_dev_status_json "verify-$tier" >/dev/null
  if [[ "$tier" == "release" ]]; then
    write_release_summary_json "$tier"
  fi
  summary_json \
    "$META_ROOT/qwendex_check.json" \
    "$META_ROOT/qwendex_doctor.json" \
    "$META_ROOT/codex_status_write.json" \
    "$META_ROOT/codex_patch_preflight.json"
}

cmd_snapshot() {
  prepare
  local stamp
  stamp="$(utc_stamp)"
  local snap="$WORK_ROOT/snapshots/$stamp"
  mkdir -p "$snap"
  write_dev_status_json snapshot >/dev/null
  cp "$DEV_STATUS_JSON" "$snap/dev_status.json"
  rsync -ain --checksum --omit-dir-times "${MANAGED_RSYNC_EXCLUDES[@]}" "$DEV_ROOT/" "$SOURCE_ROOT/" > "$snap/dev_to_source_rsync_diff.txt"
  if dev_is_git_repo; then
    git -C "$DEV_ROOT" status --short > "$snap/dev_git_status.txt"
    git -C "$DEV_ROOT" diff --stat > "$snap/dev_diff_stat.txt"
  fi
  if source_is_git_repo; then
    git -C "$SOURCE_ROOT" status --short > "$snap/source_git_status.txt"
    git -C "$SOURCE_ROOT" diff --stat > "$snap/source_diff_stat.txt"
  fi
  cp "$WORK_ROOT/env.sh" "$snap/env.sh"
  printf 'snapshot: %s\n' "$snap"
}

cmd_clean() {
  prepare
  find "$DEV_ROOT" \
    \( -path "$WORK_ROOT" -o -path "$DEV_ROOT/.git" \) -prune \
    -o \( -name '__pycache__' -o -name '.pytest_cache' -o -name '.ruff_cache' -o -name '.mypy_cache' \) \
    -print -exec rm -rf {} +
  printf 'Removed Python/tool caches outside %s.\n' "$WORK_ROOT"
}

cmd_stage() {
  local skip_verify=0
  local dry_run=0
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --skip-verify)
        skip_verify=1
        ;;
      --dry-run)
        dry_run=1
        ;;
      *)
        die "unknown stage option: $1"
        ;;
    esac
    shift
  done

  dev_is_git_repo || die "dev root is not a git repo: $DEV_ROOT"
  if [[ "$dry_run" -eq 1 ]]; then
    git -C "$DEV_ROOT" status --short
    return
  fi

  if [[ "$skip_verify" -eq 0 ]]; then
    cmd_verify --tier quick
  fi
  git -C "$DEV_ROOT" add -A "${MANAGED_GIT_PATHS[@]}"
  git -C "$DEV_ROOT" status --short
}

cmd_review() {
  prepare
  cmd_status
  printf '\nDev worktree changes:\n'
  cmd_diff
  if source_is_git_repo; then
    printf '\nCanonical source status:\n'
    git -C "$SOURCE_ROOT" status --short
  fi
  printf '\nLatest dev status:\n'
  write_dev_status_json review
}

usage() {
  cat <<EOF
Qwendex Dev Environment

Commands:
  scripts/qwendex_dev_env sync
  scripts/qwendex_dev_env bootstrap
  scripts/qwendex_dev_env env
  scripts/qwendex_dev_env status
  scripts/qwendex_dev_env status-json
  scripts/qwendex_dev_env doctor
  scripts/qwendex_dev_env review
  scripts/qwendex_dev_env diff
  scripts/qwendex_dev_env promote [--dry-run] [--delete]
  scripts/qwendex_dev_env export-to-source [--dry-run] [--delete]
  scripts/qwendex_dev_env repair-copy --force
  scripts/qwendex_dev_env stage [--dry-run] [--skip-verify]
  scripts/qwendex_dev_env lint
  scripts/qwendex_dev_env test
  scripts/qwendex_dev_env verify --tier quick|full|live|release
  scripts/qwendex_dev_env snapshot
  scripts/qwendex_dev_env clean
  scripts/qwendex_dev_env preflight
  scripts/qwendex_dev_env patch-codex [source]
  scripts/qwendex_dev_env codex-source sync|patch|build|preflight
  scripts/qwendex_dev_env open [initial prompt...]
  scripts/qwendex_dev_env open-yolo [initial prompt...]
  scripts/qwendex_dev_env shell
  scripts/qwendex_dev_env tools

Default:
  scripts/qwendex_dev_env
      opens Codex in $DEV_ROOT with $QWENDEX_CODEX_YOLO_FLAG

Defaults:
  QWENDEX_DEV_ROOT=$DEV_ROOT
  QWENDEX_DEV_SOURCE_ROOT=$SOURCE_ROOT
EOF
}

if [[ "$#" -eq 0 ]]; then
  cmd_open_yolo
  exit
fi

case "$1" in
  sync)
    cmd_sync
    ;;
  bootstrap)
    shift
    cmd_bootstrap "$@"
    ;;
  env)
    cmd_env
    ;;
  status)
    cmd_status
    ;;
  status-json)
    cmd_status_json
    ;;
  doctor)
    cmd_doctor
    ;;
  review)
    cmd_review
    ;;
  diff)
    cmd_diff
    ;;
  promote)
    shift
    cmd_promote "$@"
    ;;
  export-to-source)
    shift
    cmd_export_to_source "$@"
    ;;
  repair-copy)
    shift
    cmd_repair_copy "$@"
    ;;
  stage)
    shift
    cmd_stage "$@"
    ;;
  lint)
    cmd_lint
    ;;
  test)
    cmd_test
    ;;
  verify)
    shift
    cmd_verify "$@"
    ;;
  snapshot)
    cmd_snapshot
    ;;
  clean)
    cmd_clean
    ;;
  preflight)
    cmd_preflight
    ;;
  patch-codex)
    shift
    cmd_patch_codex "$@"
    ;;
  codex-source)
    shift
    cmd_codex_source "$@"
    ;;
  open)
    shift
    cmd_open "$@"
    ;;
  open-yolo|yolo)
    shift
    cmd_open_yolo "$@"
    ;;
  shell)
    cmd_shell
    ;;
  tools)
    cmd_tools
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    usage >&2
    die "unknown command: $1"
    ;;
esac
